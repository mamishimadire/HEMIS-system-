{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch HemisAudit",
            "type": "coreclr",
            "request": "launch",
            "program": "${env:ProgramFiles}\\dotnet\\dotnet.exe",
            "args": [
                "${workspaceFolder}\\bin\\Debug\\net8.0\\HemisAudit.dll"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5076"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(http://\\S+)"
            }
        }
    ]
}
