@model HemisAudit.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HEMIS Audit - Forgot Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <script>
        (function () {
            var theme = localStorage.getItem('hemis-theme') || 'dark';
            if (theme === 'light') document.documentElement.classList.add('light');
        })();
    </script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-page">
    <div class="login-wrap">
        <div class="login-card">
            <div class="login-brand">
                <div class="login-brand__icon" aria-hidden="true">H</div>
                <div>
                    <div class="login-brand__title">HEMIS Audit</div>
                    <div class="login-brand__sub">Management System</div>
                </div>
            </div>

            <h2 class="login-heading">Reset your password</h2>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert--success" style="margin-bottom:16px">@ViewBag.Message</div>
            }

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="field-group" style="margin-bottom:20px">
                    <label asp-for="Email">Email address</label>
                    <input asp-for="Email" type="email" autocomplete="email" placeholder="you@sng.gt.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px">
                    Send reset link ->
                </button>
            </form>

            <div style="margin-top:16px;text-align:center">
                <a href="/Account/Login" style="font-size:12px;text-decoration:none;font-weight:600;">Back to sign in</a>
            </div>
        </div>
    </div>
</body>
</html>
