@using System.Text.Json
@model HemisAudit.ViewModels.Rule26RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 26 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload = ViewBag.CanDownloadSavedRun is bool allowed && allowed;
    var canManageEngagement = ViewBag.CanManageEngagement is bool manageEngagement && manageEngagement;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool openWorkspace && openWorkspace;
    var isArchived = ViewBag.IsArchived is bool archived && archived;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<style>
    .code-panel { background:#0f172a; border-radius:18px; color:#e2e8f0; overflow:auto; padding:18px; }
    .code-panel pre { margin:0; white-space:pre-wrap; word-break:break-word; }
</style>

<div class="page-header">
    <div>
        <h1>Rule 26 Saved Run</h1>
        <p>
            @Model.EngagementName
            <span style="padding:0 8px">|</span>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            Run #@Model.RunId
            <span style="padding:0 8px">|</span>
            @Model.Summary.Timestamp
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Back to Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The saved run is available for review and download only.
    </div>
}

@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">
        The data analyst signoff is still outstanding. Assigned users can still review and download this run.
    </div>
}

<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">
                @(Model.CurrentUserHasSignedOff ? $"Signed Off as {Model.CurrentUserEngagementRole}" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>

        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">Remove Signoff</button>
            </form>
        }
    }
    else if (!Model.IsCurrentRun && !isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">History results are read-only for signoff. Signoff is only available on the current run.</div>
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Reviewer</th>
                    <th>Comment</th>
                    <th>Signed At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td><strong>@signoff.ReviewerName</strong><br /><small style="color:#757575">@signoff.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:0 0 24px">
    <div class="review-tabs">
        <button type="button" class="review-tab is-active" data-review-tab="analysis">Analysis</button>
        <button type="button" class="review-tab" data-review-tab="exceptions">Exceptions</button>
        <button type="button" class="review-tab" data-review-tab="dashboard">Dashboard</button>
        <button type="button" class="review-tab" data-review-tab="sql">SQL Code</button>
        <button type="button" class="review-tab" data-review-tab="downloads">Downloads</button>
    </div>

    <div class="review-panel is-active" data-review-panel="analysis" style="padding:24px">
        <div class="stats-grid" style="margin-bottom:24px">
            <div class="stat-card">
                <div class="stat-card__label">Total Control Tests</div>
                <div class="stat-card__value">@Model.Summary.TotalValidated.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Linked Records</div>
                <div class="stat-card__value">@Model.Summary.LinkedRecordCount.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">Exceptions</div>
                <div class="stat-card__value">@Model.Summary.FailCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Status</div>
                <div class="stat-card__value">@Model.Summary.Status</div>
            </div>
        </div>

        <div class="card" style="padding:20px;margin-bottom:20px">
            <h3 class="section-title" style="margin-top:0">Population Summary</h3>
            <div class="form-grid">
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div>
                    <div>@Model.Summary.Database</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">PROF Records</div>
                    <div>@Model.Summary.ProfRecordCount.ToString("N0")</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Payroll Records</div>
                    <div>@Model.Summary.PayrollRecordCount.ToString("N0")</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Linked Records</div>
                    <div>@Model.Summary.LinkedRecordCount.ToString("N0")</div>
                </div>
            </div>
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Control Summary</h3>
            <div style="overflow:auto">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Direction</th>
                            <th>Control</th>
                            <th>Tested</th>
                            <th>Exceptions</th>
                            <th>Status</th>
                            <th>Explanation</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var direction in Model.Summary.Directions)
                        {
                            @foreach (var control in direction.Controls)
                            {
                                <tr>
                                    <td>@direction.DirectionLabel</td>
                                    <td>@control.ControlNumber - @control.ControlName</td>
                                    <td>@control.TotalTested.ToString("N0")</td>
                                    <td>@control.ExceptionCount.ToString("N0")</td>
                                    <td>@(control.Passed ? "PASS" : "FAIL")</td>
                                    <td>@control.Explanation</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="review-panel" data-review-panel="exceptions" style="padding:24px">
        @if (Model.Summary.Exceptions.Any())
        {
            <div class="card" style="padding:20px" id="rule26ReviewExceptionsHost">
                <div class="alert alert--info" style="margin-bottom:16px">
                    Exceptions show where dbo_PROF values are missing or mismatched in Payroll_Sample. Use the filters below to focus on one control.
                </div>
                <div class="form-grid" style="margin-bottom:8px">
                    <div class="field-group">
                        <label for="rule26ReviewDirectionFilter">Filter by Direction</label>
                        <select id="rule26ReviewDirectionFilter"></select>
                    </div>
                    <div class="field-group">
                        <label for="rule26ReviewControlFilter">Filter by Control</label>
                        <select id="rule26ReviewControlFilter"></select>
                    </div>
                </div>
                <div id="rule26ReviewExceptionsSummary" style="color:#64748b;margin-bottom:8px"></div>
                <div id="rule26ReviewExceptionGroups"></div>
            </div>
        }
        else
        {
            <div class="alert alert--success" style="margin:0">No exceptions were recorded in this run.</div>
        }
    </div>

    <div class="review-panel" data-review-panel="dashboard" style="padding:24px">
        <div id="rule26ReviewDashboardHost"></div>
    </div>

    <div class="review-panel" data-review-panel="sql" style="padding:24px">
        <div class="card" style="padding:20px;margin-bottom:20px">
            <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap">
                <div>
                    <h3 class="section-title" style="margin:0">Saved SQL Preview</h3>
                    <div style="color:#64748b;margin-top:4px">Review the SQL generated from the saved run configuration.</div>
                </div>
                @if (canDownload)
                {
                    <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-primary">Download SQL</a>
                }
            </div>
        </div>
        <div class="code-panel"><pre><code>@Model.GeneratedSql</code></pre></div>
    </div>

    <div class="review-panel" data-review-panel="downloads" style="padding:24px">
        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Downloads</h3>
            <div class="alert alert--info" style="margin-bottom:16px">
                Excel includes the population summary, control summary, employee exception summary, and a single dbo_PROF to Payroll_Sample exception sheet. CSV includes the exception list.
            </div>
            @if (canDownload)
            {
                <div style="display:flex;gap:10px;flex-wrap:wrap">
                    <a asp-action="DownloadSavedExcel" asp-route-runId="@Model.RunId" class="btn btn-success">Excel</a>
                    <a asp-action="DownloadSavedCsv" asp-route-runId="@Model.RunId" class="btn btn-info">CSV</a>
                    <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-primary">SQL</a>
                </div>
            }
            else
            {
                <div class="alert alert--warning" style="margin:0">
                    Download is available to the assigned data analyst immediately, and to other assigned users after the data analyst signoff.
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
(() => {
    const exceptionRows = @Html.Raw(JsonSerializer.Serialize(Model.Summary.Exceptions.Select(row => new
    {
        row.DirectionKey,
        row.DirectionLabel,
        row.ControlNumber,
        row.ControlName,
        row.PersonnelNumber,
        row.PersonnelName,
        row.ExceptionReason,
        row.BaseValue,
        row.ReferenceValue
    })));
    const directionOptions = @Html.Raw(JsonSerializer.Serialize(Model.Summary.Directions.Select(direction => new
    {
        direction.DirectionKey,
        direction.DirectionLabel
    })));
    const controlOptions = @Html.Raw(JsonSerializer.Serialize(
        Model.Summary.Directions
            .SelectMany(direction => direction.Controls)
            .GroupBy(control => control.ControlNumber)
            .OrderBy(group => group.Key)
            .Select(group => new
            {
                ControlNumber = group.Key,
                ControlName = group.First().ControlName
            })));
    const directionSummaries = @Html.Raw(JsonSerializer.Serialize(Model.Summary.Directions.Select(direction => new
    {
        direction.DirectionKey,
        direction.DirectionLabel,
        direction.BaseRecordCount,
        direction.LinkedRecordCount,
        direction.TotalExceptions,
        Controls = direction.Controls.Select(control => new
        {
            control.ControlNumber,
            control.ControlName,
            control.TotalTested,
            control.ExceptionCount,
            control.Passed
        })
    })));

    const tabs = Array.from(document.querySelectorAll('[data-review-tab]'));
    const panels = Array.from(document.querySelectorAll('[data-review-panel]'));
    const directionFilter = document.getElementById('rule26ReviewDirectionFilter');
    const controlFilter = document.getElementById('rule26ReviewControlFilter');
    const summaryHost = document.getElementById('rule26ReviewExceptionsSummary');
    const groupsHost = document.getElementById('rule26ReviewExceptionGroups');
    const dashboardHost = document.getElementById('rule26ReviewDashboardHost');
    let selectedDirection = '';
    let selectedControl = '';
    const chartInstances = [];

    function setActiveTab(name) {
        tabs.forEach(tab => tab.classList.toggle('is-active', tab.getAttribute('data-review-tab') === name));
        panels.forEach(panel => panel.classList.toggle('is-active', panel.getAttribute('data-review-panel') === name));
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatNumber(value) {
        return Number(value || 0).toLocaleString();
    }

    function destroyCharts() {
        chartInstances.forEach(instance => {
            try {
                instance.destroy();
            } catch {}
        });
        chartInstances.length = 0;
    }

    function formatDirectionQuality(direction) {
        const totalTested = (direction?.Controls || []).reduce((sum, control) => sum + Number(control.TotalTested || 0), 0);
        const totalExceptions = (direction?.Controls || []).reduce((sum, control) => sum + Number(control.ExceptionCount || 0), 0);
        return totalTested > 0 ? ((totalTested - totalExceptions) / totalTested) * 100 : 100;
    }

    function getQualityColor(score) {
        if (score >= 95) return '#4CAF50';
        if (score >= 90) return '#F59E0B';
        return '#F44336';
    }

    function renderReviewExceptionGroups() {
        if (!directionFilter || !controlFilter || !summaryHost || !groupsHost) {
            return;
        }

        const filteredRows = exceptionRows.filter(row => {
            if (selectedDirection && row.DirectionKey !== selectedDirection) return false;
            if (selectedControl && String(row.ControlNumber) !== selectedControl) return false;
            return true;
        });

        const groupedRows = new Map();
        filteredRows.forEach(row => {
            const key = `${row.DirectionKey || ''}|${row.PersonnelNumber || ''}`;
            if (!groupedRows.has(key)) {
                groupedRows.set(key, {
                    DirectionLabel: row.DirectionLabel || '',
                    PersonnelNumber: row.PersonnelNumber || '',
                    PersonnelName: row.PersonnelName || '-',
                    Rows: []
                });
            }

            const group = groupedRows.get(key);
            if ((!group.PersonnelName || group.PersonnelName === '-') && row.PersonnelName) {
                group.PersonnelName = row.PersonnelName;
            }
            group.Rows.push(row);
        });

        summaryHost.textContent = `Filtered exceptions: ${formatNumber(filteredRows.length)} across ${formatNumber(groupedRows.size)} employee(s)`;

        if (!filteredRows.length) {
            groupsHost.innerHTML = '<div class="alert alert--warning" style="margin:0">No exceptions match the selected direction/control filters.</div>';
            return;
        }

        groupsHost.innerHTML = Array.from(groupedRows.values())
            .sort((left, right) => {
                const exceptionCountCompare = right.Rows.length - left.Rows.length;
                if (exceptionCountCompare !== 0) return exceptionCountCompare;
                return (left.PersonnelNumber || '').localeCompare(right.PersonnelNumber || '');
            })
            .map(group => `
                <div class="card" style="padding:20px;margin-top:16px">
                    <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:12px">
                        <div>
                            <h3 class="section-title" style="margin:0">${escapeHtml(group.PersonnelNumber)}${group.PersonnelName ? ` - ${escapeHtml(group.PersonnelName)}` : ''}</h3>
                            <div style="color:#64748b;margin-top:4px">
                                Direction: ${escapeHtml(group.DirectionLabel || '')} |
                                Exceptions shown: ${formatNumber(group.Rows.length)}
                            </div>
                        </div>
                    </div>
                    <div style="overflow:auto">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Control</th>
                                    <th>Exception Reason</th>
                                    <th>Base Value</th>
                                    <th>Reference Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${group.Rows
                                    .sort((left, right) => {
                                        if ((left.ControlNumber || 0) !== (right.ControlNumber || 0)) {
                                            return (left.ControlNumber || 0) - (right.ControlNumber || 0);
                                        }
                                        return (left.ExceptionReason || '').localeCompare(right.ExceptionReason || '');
                                    })
                                    .map(row => `
                                        <tr>
                                            <td>${escapeHtml(`C${row.ControlNumber} - ${row.ControlName || ''}`)}</td>
                                            <td>${escapeHtml(row.ExceptionReason || '')}</td>
                                            <td>${escapeHtml(row.BaseValue || '')}</td>
                                            <td>${escapeHtml(row.ReferenceValue || '')}</td>
                                        </tr>
                                    `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            `).join('');
    }

    function populateReviewFilters() {
        if (!directionFilter || !controlFilter) {
            return;
        }

        directionFilter.innerHTML = '<option value="">All Directions</option>' + directionOptions
            .map(option => `<option value="${escapeHtml(option.DirectionKey)}">${escapeHtml(option.DirectionLabel)}</option>`)
            .join('');

        controlFilter.innerHTML = '<option value="">All Controls</option>' + controlOptions
            .map(option => `<option value="${escapeHtml(option.ControlNumber)}">${escapeHtml(option.ControlNumber)} - ${escapeHtml(option.ControlName)}</option>`)
            .join('');

        directionFilter.addEventListener('change', () => {
            selectedDirection = directionFilter.value || '';
            renderReviewExceptionGroups();
        });

        controlFilter.addEventListener('change', () => {
            selectedControl = controlFilter.value || '';
            renderReviewExceptionGroups();
        });

        renderReviewExceptionGroups();
    }

    function renderDashboard() {
        if (!dashboardHost) {
            return;
        }

        destroyCharts();

        dashboardHost.innerHTML = `
            <div class="form-grid">
                ${directionSummaries.map((direction, index) => `
                    <div class="card" style="padding:20px">
                        <h3 class="section-title" style="margin-top:0">Rule 26: dbo_PROF to Payroll_Sample Validation</h3>
                        <div style="margin-bottom:16px;color:#64748b">
                            Base records: ${formatNumber(direction.BaseRecordCount)} |
                            Linked records: ${formatNumber(direction.LinkedRecordCount)} |
                            Exceptions: ${formatNumber(direction.TotalExceptions)}
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px">
                            <div class="chart-card">
                                <h4>Control Status</h4>
                                <canvas id="rule26ReviewStatusChart_${index}" height="220"></canvas>
                            </div>
                            <div class="chart-card">
                                <h4>Exception Count</h4>
                                <canvas id="rule26ReviewExceptionChart_${index}" height="220"></canvas>
                            </div>
                            <div class="chart-card">
                                <h4>Overall: ${formatNumber(direction.Controls.filter(control => control.Passed).length)}/${formatNumber(direction.Controls.length)} Passed</h4>
                                <canvas id="rule26ReviewPieChart_${index}" height="220"></canvas>
                            </div>
                            <div class="chart-card">
                                <h4>Data Quality: ${formatDirectionQuality(direction).toFixed(2)}%</h4>
                                <canvas id="rule26ReviewQualityChart_${index}" height="220"></canvas>
                            </div>
                        </div>
                    </div>
                `).join('')}
            </div>`;

        if (typeof Chart === 'undefined') {
            dashboardHost.insertAdjacentHTML('afterbegin', '<div class="alert alert--warning" style="margin-bottom:16px">Dashboard charts could not load. Chart.js is unavailable.</div>');
            return;
        }

        directionSummaries.forEach((direction, index) => {
            const labels = direction.Controls.map(control => `C${control.ControlNumber}`);
            const passedValues = direction.Controls.map(control => control.Passed ? 1 : 0);
            const failedValues = direction.Controls.map(control => control.Passed ? 0 : 1);
            const exceptionValues = direction.Controls.map(control => Number(control.ExceptionCount || 0));
            const passedCount = direction.Controls.filter(control => control.Passed).length;
            const failedCount = direction.Controls.length - passedCount;
            const qualityScore = formatDirectionQuality(direction);
            const qualityColor = getQualityColor(qualityScore);

            const statusCanvas = document.getElementById(`rule26ReviewStatusChart_${index}`);
            if (statusCanvas) {
                chartInstances.push(new Chart(statusCanvas, {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [
                            { label: 'Passed', data: passedValues, backgroundColor: '#4CAF50', borderColor: '#2E7D32', borderWidth: 1.5 },
                            { label: 'Failed', data: failedValues, backgroundColor: '#FF3B30', borderColor: '#C62828', borderWidth: 1.5 }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, max: 1.2, ticks: { stepSize: 0.2 } }
                        },
                        plugins: {
                            legend: { position: 'top' }
                        }
                    }
                }));
            }

            const exceptionCanvas = document.getElementById(`rule26ReviewExceptionChart_${index}`);
            if (exceptionCanvas) {
                chartInstances.push(new Chart(exceptionCanvas, {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: 'Exceptions',
                                data: exceptionValues,
                                backgroundColor: '#FF3B30',
                                borderColor: '#C62828',
                                borderWidth: 1.5
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true }
                        },
                        plugins: {
                            legend: { display: false }
                        }
                    }
                }));
            }

            const pieCanvas = document.getElementById(`rule26ReviewPieChart_${index}`);
            if (pieCanvas) {
                chartInstances.push(new Chart(pieCanvas, {
                    type: 'pie',
                    data: {
                        labels: ['Passed', 'Failed'],
                        datasets: [
                            {
                                data: [passedCount, failedCount],
                                backgroundColor: ['#4CAF50', '#FF3B30'],
                                borderColor: ['#2E7D32', '#C62828'],
                                borderWidth: 1.5
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'right' }
                        }
                    }
                }));
            }

            const qualityCanvas = document.getElementById(`rule26ReviewQualityChart_${index}`);
            if (qualityCanvas) {
                chartInstances.push(new Chart(qualityCanvas, {
                    type: 'bar',
                    data: {
                        labels: ['Quality Score'],
                        datasets: [
                            {
                                label: 'Quality Score',
                                data: [qualityScore],
                                backgroundColor: qualityColor,
                                borderColor: qualityColor,
                                borderWidth: 1.5
                            }
                        ]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { beginAtZero: true, max: 100 }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: (context) => `${Number(context.raw || 0).toFixed(2)}%`
                                }
                            }
                        }
                    },
                    plugins: [{
                        id: `rule26ReviewQualityLabel_${index}`,
                        afterDatasetsDraw(chart) {
                            const { ctx } = chart;
                            const meta = chart.getDatasetMeta(0);
                            const bar = meta?.data?.[0];
                            if (!bar) return;
                            ctx.save();
                            ctx.fillStyle = '#ffffff';
                            ctx.font = '700 16px Segoe UI';
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';
                            ctx.fillText(`${qualityScore.toFixed(2)}%`, (bar.x + bar.base) / 2, bar.y);
                            ctx.restore();
                        }
                    }]
                }));
            }
        });
    }

    tabs.forEach(tab => tab.addEventListener('click', () => setActiveTab(tab.getAttribute('data-review-tab'))));
    populateReviewFilters();
    renderDashboard();
})();
</script>

