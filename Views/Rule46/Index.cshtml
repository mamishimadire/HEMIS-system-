@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 46 – Foundation Student PQM Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int cid ? cid : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager",  StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee",  StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

<style>
.r46-tbl { border-collapse:collapse; width:100%; font-size:.82rem; }
.r46-tbl th { background:#1565A6; color:#fff; padding:5px 8px; border:1px solid #bbb; white-space:nowrap; text-align:center; }
.r46-tbl td { padding:4px 7px; border:1px solid #ddd; vertical-align:middle; }
.r46-tbl tr.pass-row { background:#F1F8E9; }
.r46-tbl tr.fail-row { background:#FFEBEE; }
.r46-pass { display:inline-block; padding:2px 8px; border-radius:4px; font-size:.74rem; font-weight:700; background:#E8F5E9; color:#1E8449; }
.r46-fail { display:inline-block; padding:2px 8px; border-radius:4px; font-size:.74rem; font-weight:700; background:#FFEBEE; color:#C0392B; }
.workspace-signoff-actions { display:flex; gap:10px; flex-wrap:wrap; padding-top:4px; }
.col-mapping-grid { display:grid; grid-template-columns: repeat(auto-fill,minmax(200px,1fr)); gap:12px; }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="r46ClientId">Engagement</label>
        <select id="r46ClientId" onchange="r46OnClientChange(this.value)">
            <option value="">Select engagement</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R46</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 46: Foundation Student PQM Validation</h1>
            <p class="rule-header__sub">
                Select foundation students (<code>STUD._106 = 'Y'</code>) and validate through two controls:<br />
                <strong>Control 1</strong>: STUD → QUAL → CRED linkage check &nbsp;|&nbsp;
                <strong>Control 2</strong>: STUD → QUAL → PQM qualification name match
            </p>
        </div>
        <div class="rule-header__badge" id="r46StatusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
    <div class="accordion-stack">
        <!-- Database Connection -->
        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r46-conn')">
                <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r46-conn">
                <div class="form-grid">
                    <div class="field-group">
                        <label for="r46Server">Server Name</label>
                        <input id="r46Server" type="text" placeholder="SERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label for="r46Driver">Driver</label>
                        <select id="r46Driver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="r46Db">Database</label>
                        <select id="r46Db" onchange="r46LoadTables()"></select>
                    </div>
                </div>
                <div class="action-bar" style="justify-content:flex-start;margin:10px 0 0">
                    <button type="button" class="btn btn-primary" onclick="r46Connect()">Connect</button>
                </div>
                <div id="r46ConnOut" class="status-output"></div>
            </div>
        </div>

        <!-- Table & Column Configuration -->
        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r46-cfg')">
                <span class="acc-icon">CF</span><span>Table &amp; Column Configuration</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r46-cfg" style="display:none">
                <div class="info-box info-box--red" style="margin-bottom:14px">
                    <strong>Rule 46 logic:</strong><br />
                    Step 1: Select foundation students where <code>STUD.[Filter Col] = 'Filter Value'</code><br />
                    Control 1: JOIN STUD → QUAL (on Student Key = QUAL Key) → CRED (on Student Key = CRED Student Key) — PASS if CRED record exists<br />
                    Control 2: JOIN STUD → QUAL (on Student Key) → PQM (on QUAL Name Col = PQM Name Col) — PASS if PQM name matches<br />
                    All columns and tables are configurable. Auto-detected on connect.
                </div>

                <h4 style="margin:0 0 10px;font-size:.9rem;color:#555">STUD Table</h4>
                <div class="col-mapping-grid" style="margin-bottom:16px">
                    <div class="field-group">
                        <label for="r46StudTable">STUD Table</label>
                        <select id="r46StudTable" onchange="r46LoadCols('stud',this.value)"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46StudKey">Student Key Column <small>(_001)</small></label>
                        <select id="r46StudKey"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46StudFilterCol">Foundation Filter Column <small>(_106)</small></label>
                        <select id="r46StudFilterCol"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46StudFilterValue">Filter Value <small>(Y)</small></label>
                        <input id="r46StudFilterValue" type="text" value="Y" />
                    </div>
                </div>

                <h4 style="margin:0 0 10px;font-size:.9rem;color:#555">QUAL Bridge Table</h4>
                <div class="col-mapping-grid" style="margin-bottom:16px">
                    <div class="field-group">
                        <label for="r46QualTable">QUAL Table</label>
                        <select id="r46QualTable" onchange="r46LoadCols('qual',this.value)"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46QualKey">QUAL Key Column <small>(_001, joins to STUD key)</small></label>
                        <select id="r46QualKey"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46QualNameCol">QUAL Name Column <small>(_003, used for PQM match)</small></label>
                        <select id="r46QualNameCol"></select>
                    </div>
                </div>

                <h4 style="margin:0 0 10px;font-size:.9rem;color:#555">CRED Table (Control 1)</h4>
                <div class="col-mapping-grid" style="margin-bottom:16px">
                    <div class="field-group">
                        <label for="r46CredTable">CRED Table</label>
                        <select id="r46CredTable" onchange="r46LoadCols('cred',this.value)"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46CredStudKey">CRED Student Key <small>(_001, joins to STUD key)</small></label>
                        <select id="r46CredStudKey"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46CredCourseCol">CRED Course Column <small>(_030)</small></label>
                        <select id="r46CredCourseCol"></select>
                    </div>
                </div>

                <h4 style="margin:0 0 10px;font-size:.9rem;color:#555">PQM Reference Table (Control 2)</h4>
                <div class="col-mapping-grid" style="margin-bottom:16px">
                    <div class="field-group">
                        <label for="r46PqmTable">PQM Table</label>
                        <select id="r46PqmTable" onchange="r46LoadCols('pqm',this.value)"></select>
                    </div>
                    <div class="field-group">
                        <label for="r46PqmNameCol">PQM Qualification Name Column</label>
                        <select id="r46PqmNameCol"></select>
                    </div>
                </div>

                <div class="action-bar" style="justify-content:flex-start;margin:4px 0">
                    <button type="button" class="btn btn-info" onclick="r46Verify()">Verify Tables</button>
                    <button type="button" class="btn btn-secondary" onclick="r46DetectColumns()">Auto-Detect Columns</button>
                </div>
                <div id="r46CfgOut" class="status-output"></div>
            </div>
        </div>
    </div>
    }

    <!-- Workspace Signoff Card -->
    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 46 configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="r46RunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">Select an engagement to load the saved Rule 46 workspace.</div>
        <div class="workspace-signoff-grid">
            <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div><div id="r46RunLabel">No saved run yet</div></div>
            <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div id="r46StatusLabel">-</div></div>
            <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div><div id="r46EditedLabel">-</div></div>
            <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div><div id="r46RoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div></div>
            <div class="field-group" style="grid-column:1/-1">
                <label for="r46SignoffComment">Signoff Comment</label>
                <textarea id="r46SignoffComment" rows="2" placeholder="Add the final review note confirming this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button class="btn btn-success" id="r46SaveBtn" onclick="r46SaveWorkspace()">Save Workspace</button>
            }
            <button class="btn btn-primary"  id="r46SignoffBtn"       onclick="r46SignOff()">Sign Off</button>
            <button class="btn btn-warning"  id="r46RemoveSignoffBtn" onclick="r46RemoveSignoff()" style="display:none">Remove Signoff</button>
        </div>
    </div>

    <div class="action-bar">
        @if (!isResultsOnlyRole)
        {
            <button class="btn btn-success" onclick="r46Run()">&#9654; Run Rule 46</button>
            <button class="btn btn-primary" onclick="r46GenSql()">Generate SQL</button>
        }
        <button class="btn btn-warning" id="r46DlAllBtn" onclick="r46DlCsv()" disabled>Download CSV</button>
        <button class="btn btn-secondary" id="r46DlSqlBtn" onclick="r46DlSql()" disabled>Download SQL</button>
    </div>

    <!-- Results Tabs -->
    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="r46-analysis" onclick="r46Tab('r46-analysis')">Analysis</button>
            <button class="tab-btn" type="button" data-tab="r46-ctrl1" onclick="r46Tab('r46-ctrl1')">Control 1 (STUD→CRED)</button>
            <button class="tab-btn" type="button" data-tab="r46-ctrl2" onclick="r46Tab('r46-ctrl2')">Control 2 (STUD→PQM)</button>
            <button class="tab-btn" type="button" data-tab="r46-sql" onclick="r46Tab('r46-sql')">SQL Code</button>
        </div>
        <div class="tab-pane active" data-tab-panel="r46-analysis"><div id="r46AnalysisPane"><div class="empty-state"><p>Run Rule 46 to see results here.</p></div></div></div>
        <div class="tab-pane" data-tab-panel="r46-ctrl1">
            <div class="results-filter-bar" style="padding:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                <label style="font-size:.85rem">Filter: </label>
                <button class="btn btn-sm btn-secondary r46-filter-btn active" data-filter="ALL" onclick="r46SetFilter(this,'ctrl1')">All</button>
                <button class="btn btn-sm btn-secondary r46-filter-btn" data-filter="PASS" onclick="r46SetFilter(this,'ctrl1')">PASS only</button>
                <button class="btn btn-sm btn-secondary r46-filter-btn" data-filter="FAIL" onclick="r46SetFilter(this,'ctrl1')">FAIL only</button>
            </div>
            <div id="r46Ctrl1Pane"><div class="empty-state"><p>Run validation first.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r46-ctrl2">
            <div class="results-filter-bar" style="padding:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                <label style="font-size:.85rem">Filter: </label>
                <button class="btn btn-sm btn-secondary r46-filter-btn active" data-filter="ALL" onclick="r46SetFilter(this,'ctrl2')">All</button>
                <button class="btn btn-sm btn-secondary r46-filter-btn" data-filter="PASS" onclick="r46SetFilter(this,'ctrl2')">PASS only</button>
                <button class="btn btn-sm btn-secondary r46-filter-btn" data-filter="FAIL" onclick="r46SetFilter(this,'ctrl2')">FAIL only</button>
            </div>
            <div id="r46Ctrl2Pane"><div class="empty-state"><p>Run validation first.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r46-sql">
            <textarea id="r46SqlText" rows="22" readonly style="width:100%;font-family:monospace;font-size:12px"></textarea>
        </div>
    </div>

    <div id="r46Spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box"><div class="spinner-ring"></div><p id="r46SpinMsg">Processing...</p></div>
    </div>
</div>

<form id="r46AntiForgery" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = window.toggleAccordion || function(s) {
    var b = document.getElementById('body-' + s);
    if (b) b.style.display = b.style.display === 'none' ? '' : 'none';
};

window.r46Tab = function(tab) {
    document.querySelectorAll('#app .results-panel .tab-btn').forEach(function(b) { b.classList.toggle('active', b.dataset.tab === tab); });
    document.querySelectorAll('#app .results-panel .tab-pane').forEach(function(p) { p.classList.toggle('active', p.dataset.tabPanel === tab); });
    if (tab === 'r46-ctrl1' || tab === 'r46-ctrl2') renderResults();
};

(function() {
    var API  = '/Rule46';
    var ROLE = '@currentSystemRole';
    var IS_RESULTS_ONLY = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    var TOKEN = (document.querySelector('#r46AntiForgery input[name="__RequestVerificationToken"]') || {}).value || '';

    var st = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        runId: null, summary: null,
        isWorkspaceSaved: false, currentUserHasSignedOff: false,
        resultsVisible: false, currentUserEngagementRole: '',
        filterCtrl1: 'ALL', filterCtrl2: 'ALL',
        studCols: [], qualCols: [], credCols: [], pqmCols: []
    };

    function g(id)  { return document.getElementById(id); }
    function gv(id) { var e = g(id); return e ? e.value : ''; }
    function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function fmt(n) { return Number(n || 0).toLocaleString(); }
    function show(id, v) { var e = g(id); if (e) e.style.display = v ? '' : 'none'; }
    function setHtml(id, html) { var e = g(id); if (e) e.innerHTML = html; }
    function setWs(msg, type) { var e = g('workspaceInfo'); if (e) { e.className = 'alert alert--' + (type || 'info'); e.textContent = msg; } }
    function setStatus(id, msg, type) { var e = g(id); if (e) { e.className = 'alert alert--' + (type || 'info'); e.textContent = msg; } }
    function spin(msg) { var e = g('r46SpinMsg'); if (e) e.textContent = msg || 'Processing...'; show('r46Spinner', true); }
    function unspin() { show('r46Spinner', false); }

    function fillSel(id, items, selected) {
        var sel = typeof id === 'string' ? g(id) : id; if (!sel) return;
        sel.innerHTML = '';
        (items || []).forEach(function(item) {
            var o = document.createElement('option');
            o.value = o.textContent = item;
            if (selected && selected === item) o.selected = true;
            sel.appendChild(o);
        });
    }

    function post(url, body) {
        return fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify(body)
        }).then(function(r) { return r.json(); });
    }

    function setStatusBadge(status) {
        var b = g('r46StatusBadge'); if (!b) return;
        if (!status) { b.style.display = 'none'; return; }
        b.style.display = ''; b.textContent = status;
        b.className = 'rule-header__badge ' + (String(status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail');
    }

    function buildReq() {
        return {
            clientId: st.clientId, runId: st.runId,
            server: gv('r46Server').trim(), database: gv('r46Db'),
            driver: gv('r46Driver') || 'ODBC Driver 17 for SQL Server',
            studTable:       gv('r46StudTable')       || 'dbo_STUD',
            studKey:         gv('r46StudKey')          || '_001',
            studFilterCol:   gv('r46StudFilterCol')    || '_106',
            studFilterValue: gv('r46StudFilterValue')  || 'Y',
            qualTable:       gv('r46QualTable')        || 'dbo_QUAL',
            qualKey:         gv('r46QualKey')          || '_001',
            qualNameCol:     gv('r46QualNameCol')      || '_003',
            credTable:       gv('r46CredTable')        || 'dbo_CRED',
            credStudKey:     gv('r46CredStudKey')      || '_001',
            credCourseCol:   gv('r46CredCourseCol')    || '_030',
            pqmTable:        gv('r46PqmTable')         || '[dbo].[PQM]',
            pqmNameCol:      gv('r46PqmNameCol')       || 'Authorised_Qualification_Name'
        };
    }

    // ── Connection & discovery ──

    window.r46Connect = function() {
        var server = gv('r46Server').trim();
        if (!server) { setWs('Enter a server name first.', 'warning'); return; }
        spin('Connecting...');
        post(API + '/GetDatabases', { server: server, driver: gv('r46Driver') })
        .then(function(d) {
            unspin();
            if (!d.success) { setStatus('r46ConnOut', d.error || 'Connection failed.', 'error'); return; }
            fillSel('r46Db', d.databases || []);
            setStatus('r46ConnOut', 'Connected — ' + (d.databases || []).length + ' database(s) found.', 'success');
            if ((d.databases || []).length) r46LoadTables();
        }).catch(function(e) { unspin(); setStatus('r46ConnOut', e.message, 'error'); });
    };

    window.r46LoadTables = function() {
        var db = gv('r46Db'); if (!db) return;
        spin('Loading tables...');
        post(API + '/GetTables', { server: gv('r46Server').trim(), database: db, driver: gv('r46Driver') })
        .then(function(d) {
            unspin();
            if (!d.success) { setStatus('r46CfgOut', d.error || 'Failed.', 'error'); return; }
            var tables = d.tables || [];
            fillSel('r46StudTable', tables, d.autoStudTable || 'dbo_STUD');
            fillSel('r46QualTable', tables, d.autoQualTable || 'dbo_QUAL');
            fillSel('r46CredTable', tables, d.autoCredTable || 'dbo_CRED');
            fillSel('r46PqmTable',  tables, d.autoPqmTable  || '[dbo].[PQM]');
            show('body-r46-cfg', true);
            setStatus('r46CfgOut', 'Tables loaded. Detecting columns...', 'success');
            r46DetectColumns();
        }).catch(function(e) { unspin(); setStatus('r46CfgOut', e.message, 'error'); });
    };

    function r46LoadColsInner(role, tableName) {
        if (!tableName || !gv('r46Server') || !gv('r46Db')) return Promise.resolve();
        return post(API + '/GetColumns', {
            server: gv('r46Server').trim(), database: gv('r46Db'),
            driver: gv('r46Driver'), tableName: tableName
        }).then(function(d) {
            if (!d.success) return;
            var cols = d.columns || [];
            var def = function(col, fallback) { return cols.find(c => c === col) || cols[0] || fallback; };
            if (role === 'stud')  {
                st.studCols = cols;
                fillSel('r46StudKey',       cols, def('_001','_001'));
                fillSel('r46StudFilterCol', cols, def('_106','_106'));
            }
            if (role === 'qual')  {
                st.qualCols = cols;
                fillSel('r46QualKey',     cols, def('_001','_001'));
                fillSel('r46QualNameCol', cols, def('_003','_003'));
            }
            if (role === 'cred')  {
                st.credCols = cols;
                fillSel('r46CredStudKey',   cols, def('_001','_001'));
                fillSel('r46CredCourseCol', cols, def('_030','_030'));
            }
            if (role === 'pqm')   {
                st.pqmCols = cols;
                fillSel('r46PqmNameCol', cols, def('Authorised_Qualification_Name','Authorised_Qualification_Name'));
            }
        });
    }

    window.r46LoadCols = function(role, tbl) { r46LoadColsInner(role, tbl); };

    window.r46DetectColumns = function() {
        spin('Detecting columns...');
        Promise.all([
            r46LoadColsInner('stud',  gv('r46StudTable')),
            r46LoadColsInner('qual',  gv('r46QualTable')),
            r46LoadColsInner('cred',  gv('r46CredTable')),
            r46LoadColsInner('pqm',   gv('r46PqmTable'))
        ]).then(function() {
            unspin();
            setStatus('r46CfgOut', 'Column mapping detected from selected tables.', 'success');
        }).catch(function(e) { unspin(); setStatus('r46CfgOut', e.message, 'error'); });
    };

    window.r46Verify = function() {
        spin('Verifying tables...');
        post(API + '/VerifyTables', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { setStatus('r46CfgOut', d.error || 'Verification failed.', 'error'); return; }
            setStatus('r46CfgOut',
                'STUD: ' + fmt(d.studCount) + ' rows | QUAL: ' + fmt(d.qualCount) + ' rows | CRED: ' + fmt(d.credCount) + ' rows | PQM: ' + fmt(d.pqmCount) + ' rows',
                'success');
        }).catch(function(e) { unspin(); setStatus('r46CfgOut', e.message, 'error'); });
    };

    // ── Validation ──

    window.r46Run = function() {
        if (!st.clientId) { setWs('Select an engagement before running.', 'warning'); return; }
        spin('Running Rule 46...');
        post(API + '/RunValidation', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Validation failed.', 'error'); return; }
            st.runId = d.savedRunId || st.runId;
            st.currentUserHasSignedOff = false; st.isWorkspaceSaved = false; st.resultsVisible = true;
            st.summary = d;
            setStatusBadge(d.status);
            renderAnalysis(d);
            renderResults();
            setWs('Rule 46 complete. Total: ' + fmt(d.totalValidated) +
                ' | Pass: ' + fmt(d.passCount) + ' | Fail: ' + fmt(d.failCount) +
                ' | Status: ' + d.status, d.status === 'PASS' ? 'success' : 'warning');
            var dlBtn = g('r46DlAllBtn'); if (dlBtn) dlBtn.disabled = false;
            var dlSql = g('r46DlSqlBtn'); if (dlSql) dlSql.disabled = false;
            updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r46GenSql = function() {
        spin('Generating SQL...');
        post(API + '/GenerateSql', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { alert(d.error || 'Failed.'); return; }
            var t = g('r46SqlText'); if (t) t.value = d.sql || '';
            r46Tab('r46-sql');
        }).catch(function(e) { unspin(); alert(e.message); });
    };

    // ── Workspace ──

    window.r46SaveWorkspace = function() {
        spin('Saving workspace...');
        post(API + '/SaveWorkspace', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Save failed.', 'error'); return; }
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Workspace saved.', d.signoffsCleared ? 'warning' : 'success');
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r46SignOff = function() {
        spin('Saving signoff...');
        post(API + '/SignOffWorkspace', { clientId: st.clientId, runId: st.runId, comment: gv('r46SignoffComment') })
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Signoff failed.', 'error'); return; }
            st.currentUserHasSignedOff = true;
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Signoff saved.', 'success'); updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r46RemoveSignoff = function() {
        spin('Removing signoff...');
        post(API + '/RemoveWorkspaceSignoff', { clientId: st.clientId, runId: st.runId, comment: '' })
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Failed.', 'error'); return; }
            st.currentUserHasSignedOff = false;
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Signoff removed.', 'warning'); updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    function applyWsMeta(ws) {
        st.isWorkspaceSaved = !!ws.isWorkspaceSaved;
        st.currentUserHasSignedOff = !!ws.currentUserHasSignedOff;
        if (ws.currentUserEngagementRole) st.currentUserEngagementRole = ws.currentUserEngagementRole;
        var b  = g('r46RunState');    if (b)  b.textContent  = ws.runId ? 'Run #' + ws.runId : 'No saved run loaded';
        var rl = g('r46RunLabel');    if (rl) rl.textContent = ws.runId ? 'Rule 46 Run #' + ws.runId : 'No saved run yet';
        var sl = g('r46StatusLabel'); if (sl) sl.textContent = ws.currentStatus || ws.status || '-';
        var el = g('r46EditedLabel'); if (el) el.textContent = ws.lastEditedAt ? new Date(ws.lastEditedAt).toLocaleString() : '-';
        var rl2= g('r46RoleLabel');   if (rl2)rl2.textContent= ws.currentUserEngagementRole || ROLE || '-';
        var sc = g('r46SignoffComment'); if (sc && ws.currentUserSignoffComment) sc.value = ws.currentUserSignoffComment;
        updateButtons();
    }

    function updateButtons() {
        var engRole = (st.currentUserEngagementRole || ROLE || '').toLowerCase();
        var nSys    = (ROLE || '').toLowerCase();
        var canEdit = !IS_RESULTS_ONLY && (nSys === 'dataanalyst' || engRole === 'dataanalyst');
        var canSign = !!st.runId && !!st.isWorkspaceSaved &&
            (engRole === 'dataanalyst' || (st.resultsVisible && (engRole === 'manager' || engRole === 'director')));
        var signed  = st.currentUserHasSignedOff;
        var sw = g('r46SaveBtn');    if (sw) sw.disabled = signed || !canEdit || !st.runId;
        var so = g('r46SignoffBtn'); if (so) { so.disabled = signed || !canSign; so.textContent = signed ? 'Signed Off' : 'Sign Off'; }
        show('r46RemoveSignoffBtn', signed);
    }

    window.r46SetFilter = function(btn, ctrl) {
        var filter = btn.dataset.filter || 'ALL';
        document.querySelectorAll('.r46-filter-btn').forEach(function(b) {
            if ((ctrl === 'ctrl1' && b.closest('[data-tab-panel="r46-ctrl1"]')) ||
                (ctrl === 'ctrl2' && b.closest('[data-tab-panel="r46-ctrl2"]')))
                b.classList.remove('active');
        });
        btn.classList.add('active');
        if (ctrl === 'ctrl1') st.filterCtrl1 = filter;
        else                  st.filterCtrl2 = filter;
        renderResults();
    };

    // ── Workspace Load ──

    window.r46OnClientChange = function(val) {
        st.clientId = parseInt(val) || 0;
        if (!st.clientId) { setWs('Select an engagement to load the saved Rule 46 workspace.', 'info'); return; }
        loadWorkspace();
    };

    function loadWorkspace() {
        if (!st.clientId) return;
        setWs('Loading saved workspace...', 'info');
        (window.fetchJsonWithProgress || function(url, opts) { return fetch(url, opts).then(function(r) { return r.json(); }); })(API + '/GetWorkspaceState?clientId=' + st.clientId, { method: 'GET' })
        .then(function(d) {
            if (!d.success) { setWs(d.error || 'Failed to load workspace.', 'error'); return; }
            applyWorkspace(d.workspace, d.resultsVisible);
        }).catch(function(e) { setWs(e.message, 'error'); });
    }

    function applyWorkspace(ws, resultsVisible) {
        if (!ws) {
            st.runId = null; st.summary = null; st.isWorkspaceSaved = false;
            st.currentUserHasSignedOff = false; st.resultsVisible = false; st.currentUserEngagementRole = '';
            setWs('No saved Rule 46 workspace for this engagement yet.', 'info');
            var b = g('r46RunState'); if (b) b.textContent = 'No saved run loaded';
            renderAnalysis(null); renderResults(); updateButtons(); return;
        }
        st.runId = ws.runId || null;
        st.isWorkspaceSaved = !!ws.isWorkspaceSaved;
        st.currentUserHasSignedOff = !!ws.currentUserHasSignedOff;
        st.resultsVisible = !!resultsVisible;
        st.currentUserEngagementRole = ws.currentUserEngagementRole || '';

        if (!IS_RESULTS_ONLY) {
            var sv = g('r46Server'); if (sv && ws.server) sv.value = ws.server;
            var dv = g('r46Driver'); if (dv && ws.driver) dv.value = ws.driver;
            if (ws.database) fillSel('r46Db', [ws.database], ws.database);
            if (ws.studTable) fillSel('r46StudTable', [ws.studTable], ws.studTable);
            if (ws.qualTable) fillSel('r46QualTable', [ws.qualTable], ws.qualTable);
            if (ws.credTable) fillSel('r46CredTable', [ws.credTable], ws.credTable);
            if (ws.pqmTable)  fillSel('r46PqmTable',  [ws.pqmTable],  ws.pqmTable);
            if (ws.studKey)         fillSel('r46StudKey',         [ws.studKey],          ws.studKey);
            if (ws.studFilterCol)   fillSel('r46StudFilterCol',   [ws.studFilterCol],    ws.studFilterCol);
            if (ws.studFilterValue) { var sfv = g('r46StudFilterValue'); if (sfv) sfv.value = ws.studFilterValue; }
            if (ws.qualKey)         fillSel('r46QualKey',         [ws.qualKey],          ws.qualKey);
            if (ws.qualNameCol)     fillSel('r46QualNameCol',     [ws.qualNameCol],      ws.qualNameCol);
            if (ws.credStudKey)     fillSel('r46CredStudKey',     [ws.credStudKey],      ws.credStudKey);
            if (ws.credCourseCol)   fillSel('r46CredCourseCol',   [ws.credCourseCol],    ws.credCourseCol);
            if (ws.pqmNameCol)      fillSel('r46PqmNameCol',      [ws.pqmNameCol],       ws.pqmNameCol);
        }

        applyWsMeta(ws);

        if (!resultsVisible) {
            setWs('Saved Rule 46 results are not available for your role.', 'info');
            renderAnalysis(null); renderResults(); updateButtons(); return;
        }

        st.summary = ws.summary || null;
        setStatusBadge(ws.summary ? ws.summary.status : ws.currentStatus);
        setWs(ws.summary ? 'Saved Rule 46 workspace loaded.' : 'Rule 46 workspace loaded. Run validation to generate results.', 'success');
        renderAnalysis(ws.summary);
        renderResults();
        var dlBtn = g('r46DlAllBtn'); if (dlBtn) dlBtn.disabled = !ws.runId;
        var dlSql = g('r46DlSqlBtn'); if (dlSql) dlSql.disabled = !ws.runId;
    }

    // ── Rendering ──

    function renderAnalysis(s) {
        var pane = g('r46AnalysisPane'); if (!pane) return;
        if (!s) { pane.innerHTML = '<div class="empty-state"><p>Run Rule 46 to see results here.</p></div>'; return; }
        var sc = String(s.status || '').toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail';
        var ctrlHtml = (s.controlSummaries || []).map(function(c) {
            var cs = String(c.status || '').toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail';
            return '<div class="card" style="padding:14px;margin-bottom:10px">' +
                '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">' +
                '<strong style="font-size:.88rem">' + esc(c.controlLabel) + '</strong>' +
                '<span class="badge ' + cs + '">' + esc(c.status) + '</span></div>' +
                '<div style="font-size:.8rem;color:#666;margin-bottom:4px">' + esc(c.criteriaText) + '</div>' +
                '<div style="display:flex;gap:16px;font-size:.82rem">' +
                '<span>Total: <strong>' + fmt(c.totalCount) + '</strong></span>' +
                '<span style="color:#1E8449">Pass: <strong>' + fmt(c.passCount) + '</strong></span>' +
                '<span style="color:#C0392B">Fail: <strong>' + fmt(c.failCount) + '</strong></span>' +
                '<span>Exception Rate: <strong>' + Number(c.exceptionRate || 0).toFixed(2) + '%</strong></span>' +
                '</div></div>';
        }).join('');
        pane.innerHTML =
            '<div class="stats-grid" style="margin-bottom:16px">' +
            statCard('Total', fmt(s.totalValidated || 0), '') +
            statCard('Pass',  fmt(s.passCount  || 0), 'pass') +
            statCard('Fail',  fmt(s.failCount  || 0), s.failCount > 0 ? 'fail' : '') +
            statCard('Exception Rate', Number(s.exceptionRate || 0).toFixed(2) + '%', s.exceptionRate > 0 ? 'fail' : 'pass') +
            statCard('Overall', '<span class="badge ' + sc + '">' + esc(s.status) + '</span>', '') +
            '</div>' +
            '<div class="card" style="padding:12px;margin-bottom:16px"><div class="form-grid">' +
            '<div><div class="stat-label">Database</div><div>' + esc(s.database || '') + '</div></div>' +
            '<div><div class="stat-label">STUD Table</div><div>' + esc(s.studTable || '') + ' (' + esc(s.studFilterCol||'_106') + '=\'' + esc(s.studFilterValue||'Y') + '\')</div></div>' +
            '<div><div class="stat-label">QUAL Table</div><div>' + esc(s.qualTable || '') + '</div></div>' +
            '<div><div class="stat-label">CRED Table</div><div>' + esc(s.credTable || '') + '</div></div>' +
            '<div><div class="stat-label">PQM Table</div><div>' + esc(s.pqmTable || '') + '</div></div>' +
            '<div><div class="stat-label">Timestamp</div><div>' + esc(s.timestamp || '') + '</div></div>' +
            '</div></div>' + ctrlHtml;
    }

    function renderResults() {
        if (!st.summary) {
            setHtml('r46Ctrl1Pane', '<div class="empty-state"><p>Run validation first.</p></div>');
            setHtml('r46Ctrl2Pane', '<div class="empty-state"><p>Run validation first.</p></div>');
            return;
        }
        var rows = st.summary.validationRows || [];
        var c1 = rows.filter(function(r) { return r.controlType === 'Control_1'; });
        var c2 = rows.filter(function(r) { return r.controlType === 'Control_2'; });
        setHtml('r46Ctrl1Pane', buildCtrl1Table(c1, st.filterCtrl1));
        setHtml('r46Ctrl2Pane', buildCtrl2Table(c2, st.filterCtrl2));
    }

    function buildCtrl1Table(rows, filter) {
        var filtered = filter === 'ALL' ? rows : rows.filter(function(r) { return r.validationResult === filter; });
        if (!filtered.length) return '<div class="empty-state"><p>No rows match the selected filter.</p></div>';
        var body = filtered.map(function(r) {
            var cls = r.validationResult === 'PASS' ? 'pass-row' : 'fail-row';
            var badge = r.validationResult === 'PASS' ? '<span class="r46-pass">&#10003; PASS</span>' : '<span class="r46-fail">&#x2717; FAIL</span>';
            return '<tr class="' + cls + '"><td>' + esc(r.studId) + '</td><td>' + esc(r.studFilterValue) + '</td><td>' + esc(r.qualId) + '</td><td>' + esc(r.qualName) + '</td><td>' + esc(r.credId) + '</td><td>' + esc(r.credCourse) + '</td><td>' + badge + '</td><td style="font-size:.75rem">' + esc(r.resultDetail) + '</td></tr>';
        }).join('');
        return '<div style="overflow-x:auto"><table class="r46-tbl"><thead><tr>' +
            '<th>STUD Key</th><th>Filter Val</th><th>QUAL Key</th><th>QUAL Name</th><th>CRED Key</th><th>CRED Course</th><th>Result</th><th>Detail</th>' +
            '</tr></thead><tbody>' + body + '</tbody></table>' +
            '<p style="font-size:.78rem;color:#777;padding:4px 0">Showing ' + filtered.length + ' of ' + rows.length + ' rows.</p></div>';
    }

    function buildCtrl2Table(rows, filter) {
        var filtered = filter === 'ALL' ? rows : rows.filter(function(r) { return r.validationResult === filter; });
        if (!filtered.length) return '<div class="empty-state"><p>No rows match the selected filter.</p></div>';
        var body = filtered.map(function(r) {
            var cls = r.validationResult === 'PASS' ? 'pass-row' : 'fail-row';
            var badge = r.validationResult === 'PASS' ? '<span class="r46-pass">&#10003; PASS</span>' : '<span class="r46-fail">&#x2717; FAIL</span>';
            return '<tr class="' + cls + '"><td>' + esc(r.studId) + '</td><td>' + esc(r.studFilterValue) + '</td><td>' + esc(r.qualId) + '</td><td>' + esc(r.qualName) + '</td><td>' + esc(r.pqmName) + '</td><td>' + badge + '</td><td style="font-size:.75rem">' + esc(r.resultDetail) + '</td></tr>';
        }).join('');
        return '<div style="overflow-x:auto"><table class="r46-tbl"><thead><tr>' +
            '<th>STUD Key</th><th>Filter Val</th><th>QUAL Key</th><th>QUAL Name</th><th>PQM Name</th><th>Result</th><th>Detail</th>' +
            '</tr></thead><tbody>' + body + '</tbody></table>' +
            '<p style="font-size:.78rem;color:#777;padding:4px 0">Showing ' + filtered.length + ' of ' + rows.length + ' rows.</p></div>';
    }

    function statCard(label, value, mod) {
        var cls = mod === 'pass' ? ' stat-card--pass' : mod === 'fail' ? ' stat-card--fail' : '';
        return '<div class="stat-card' + cls + '"><div class="stat-card__label">' + label + '</div><div class="stat-card__value">' + value + '</div></div>';
    }

    window.r46DlCsv = function() { if (st.runId) window.open(API + '/DownloadCsv?runId=' + st.runId, '_blank'); };
    window.r46DlSql = function() { if (st.runId) window.open(API + '/DownloadSql?runId=' + st.runId, '_blank'); };

    // ── Init ──
    renderAnalysis(null);
    renderResults();
    updateButtons();
    if (st.clientId) loadWorkspace();
})();
</script>
