@model HemisAudit.ViewModels.DashboardViewModel
@using HemisAudit.Helpers
@{
    ViewData["Title"] = "My engagements";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = string.Equals(Model.CurrentUserRole, "Admin", StringComparison.OrdinalIgnoreCase);
    var isDirector = string.Equals(Model.CurrentUserRole, "Director", StringComparison.OrdinalIgnoreCase);
    var isDataAnalyst = string.Equals(Model.CurrentUserRole, "DataAnalyst", StringComparison.OrdinalIgnoreCase);
    var isManager = string.Equals(Model.CurrentUserRole, "Manager", StringComparison.OrdinalIgnoreCase);
    var isTrainee = string.Equals(Model.CurrentUserRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var isResultsOnlyRole = !isAdmin && !isDataAnalyst;
    var currentScope = (Model.CurrentScope ?? "active").ToLowerInvariant();
    var scopeTitle = currentScope switch
    {
        "archived" => "Archived engagements",
        "favorites" => "Favourite engagements",
        _ => "Active engagements"
    };
    var scopeSubtitle = currentScope switch
    {
        "archived" => "Archived engagements remain available for review and downloads only.",
        "favorites" => "Starred engagements you return to most often.",
        _ when isDataAnalyst => "These are the active engagements assigned to you. Open a workspace to run and sign off the validation modules.",
        _ => "Showing active engagements first. Use the tabs to switch to archived or favourited engagements."
    };
    var reviewedAndCompletedRuns = Model.ReviewedAndCompletedRuns;
    var needsReviewRuns = Model.NeedsReviewRuns;
    var passedRuleRuns = Model.PassedRuleRuns;
    var failedRuleRuns = Model.FailedRuleRuns;
    var passedRuleRecords = Model.PassedRuleRecords;
    var failedRuleRecords = Model.FailedRuleRecords;
    var passedRuleRecordRate = Model.PassedRuleRecordRate;
    var failedRuleRecordRate = Model.FailedRuleRecordRate;
    var analystSignedRuns = Model.AnalystSignedRuns;
    var managerSignedRuns = Model.ManagerSignedRuns;
    var directorSignedRuns = Model.DirectorSignedRuns;
    var recentInsightRuns = Model.RecentRuns.Take(6).ToList();
    var archiveReadyEngagements = Model.ArchiveReadyEngagements;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

<div class="dashboard-page">
<section class="dashboard-hero">
    <div class="dashboard-hero__copy">
        <div class="dashboard-hero__eyebrow">Portfolio command center</div>
        <div class="page-header" style="margin-bottom:0">
            <div>
                <h1>My engagements</h1>
                <p>Welcome back, <strong>@Model.CurrentUserName</strong> | @Model.CurrentUserRole</p>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                @if (isAdmin || isDirector)
                {
                    <a asp-controller="Admin" asp-action="CreateClient" class="btn btn-success">New Engagement</a>
                }
                @if (isAdmin || isDirector)
                {
                    <a asp-controller="Admin" asp-action="Clients" class="btn btn-secondary">All Engagements</a>
                }
            </div>
        </div>
    </div>
</section>

<div class="dashboard-tabs">
    <a class="dashboard-tab is-active" href="#engagements" data-dashboard-tab="engagements">Engagements</a>
    @if (!isResultsOnlyRole)
    {
        <a class="dashboard-tab" href="#modules" data-dashboard-tab="modules">Modules</a>
    }
    <a class="dashboard-tab" href="#insights" data-dashboard-tab="insights">Insights</a>
    <a class="dashboard-tab" href="#recent-runs" data-dashboard-tab="recent-runs">Recent Validation Runs</a>
</div>

<div class="dashboard-panel is-active" data-dashboard-panel="engagements">

<div class="dashboard-scope-grid">
    <a class="card dashboard-scope-card @(currentScope == "favorites" ? "is-active" : "")"
       asp-action="Index"
       asp-route-scope="favorites"
       asp-route-q="@Model.CurrentSearch">
        <div>
            <div class="dashboard-scope-card__label">Favorites</div>
            <div class="dashboard-scope-card__value">@Model.FavoriteClients</div>
        </div>
        <div class="dashboard-scope-card__icon">★</div>
    </a>
    <a class="card dashboard-scope-card @(currentScope == "active" ? "is-active" : "")"
       asp-action="Index"
       asp-route-scope="active"
       asp-route-q="@Model.CurrentSearch">
        <div>
            <div class="dashboard-scope-card__label">Active</div>
            <div class="dashboard-scope-card__value">@Model.ApprovedClients</div>
        </div>
        <div class="dashboard-scope-card__icon">●</div>
    </a>
    <a class="card dashboard-scope-card @(currentScope == "archived" ? "is-active" : "")"
       asp-action="Index"
       asp-route-scope="archived"
       asp-route-q="@Model.CurrentSearch">
        <div>
            <div class="dashboard-scope-card__label">Archived</div>
            <div class="dashboard-scope-card__value">@Model.ArchivedClients</div>
        </div>
        <div class="dashboard-scope-card__icon">◌</div>
    </a>
</div>

<div class="dashboard-toolbar">
    <div>
        <h3 class="section-title" style="margin-bottom:6px">@scopeTitle</h3>
        <p class="dashboard-band__subtitle">@scopeSubtitle</p>
    </div>
    <form method="get" asp-action="Index" class="dashboard-filter-form">
        <input type="hidden" name="scope" value="@currentScope" />
        <input id="portfolioFilter" name="q" type="search" value="@Model.CurrentSearch" placeholder="Search engagements, industries, or maconomy numbers" />
        <button class="btn btn-secondary" type="submit">Search</button>
        @if (!string.IsNullOrWhiteSpace(Model.CurrentSearch))
        {
            <a class="dashboard-clear-link" asp-action="Index" asp-route-scope="@currentScope">Clear search</a>
        }
    </form>
</div>

@if (isAdmin)
{
    <div class="dashboard-band">
        <div class="dashboard-band__header">
            <div>
                <h3 class="section-title" style="margin-bottom:6px">Pending Approval Queue</h3>
                <p class="dashboard-band__subtitle">Director-created engagements stay here until an admin approves them.</p>
            </div>
        </div>

        @if (Model.PendingApprovalQueue.Any())
        {
            <div class="card">
                <table class="data-table dashboard-table">
                    <thead>
                        <tr>
                            <th>Engagement</th>
                            <th>Industry</th>
                            <th>Maconomy No.</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model.PendingApprovalQueue)
                        {
                            <tr>
                                <td>
                                    <strong>@client.EngagementName</strong><br />
                                    <small class="table-meta">by @client.CreatedByName</small>
                                </td>
                                <td>@client.Industry</td>
                                <td>@client.MaconomyNumber</td>
                                <td>@client.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="dashboard-actions">
                                        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@client.Id" class="btn btn-sm btn-secondary">Open</a>
                                        <form asp-controller="Admin" asp-action="ApproveClient" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@client.Id" />
                                            <input type="hidden" name="returnUrl" value="/Dashboard" />
                                            <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                        </form>
                                        <form asp-controller="Admin" asp-action="DeleteClient" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@client.Id" />
                                            <button type="submit" class="btn btn-sm btn-warning"
                                                    onclick="return confirm('Delete this engagement and all related assignments and validation runs?')">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-card">
                <p>No pending approvals.</p>
            </div>
        }
    </div>
}

<div class="dashboard-band">
    <div class="dashboard-band__header">
        <div>
            <h3 class="section-title" style="margin-bottom:6px">@scopeTitle</h3>
            <p class="dashboard-band__subtitle">Open an engagement to review results, sign off, or manage the module.</p>
        </div>
    </div>

    @if (Model.PortfolioClients.Any())
    {
        <div class="card">
            <table class="data-table dashboard-table">
                <thead>
                    <tr>
                        <th>Engagement</th>
                        <th>Industry</th>
                        <th>Status</th>
                        <th>Your Role</th>
                        <th>Runs</th>
                        <th>Last Run</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model.PortfolioClients)
                    {
                        var reviewStatus = client.LastRunStatus;
                        var reviewRunAt = client.LastRunAt;
                        var reviewBadge = !string.IsNullOrWhiteSpace(reviewStatus) && (reviewStatus.Contains("Completed", StringComparison.OrdinalIgnoreCase) || reviewStatus == "Pass")
                            ? "badge--pass"
                            : reviewStatus == "Fail" || reviewStatus == "Needs Review"
                                ? "badge--fail"
                                : "badge--role";
                        <tr>
                            <td>
                                <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@client.Id"><strong>@client.EngagementName</strong></a>
                                <br />
                                <small class="table-meta">@client.MaconomyNumber</small>
                            </td>
                            <td>@client.Industry</td>
                            <td>
                                <span class="badge @(
                                    client.IsArchived ? "badge--warning" :
                                    client.IsApproved ? "badge--pass" :
                                    "badge--neutral")">
                                    @client.Status
                                </span>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(client.CurrentUserEngagementRole) ? "-" : client.CurrentUserEngagementRole)</td>
                            <td>@client.ValidationRunsCount</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(reviewStatus))
                                {
                                    <span class="badge @reviewBadge">@reviewStatus</span>
                                    <br />
                                    <small class="table-meta">@reviewRunAt?.ToString("dd MMM yyyy HH:mm")</small>
                                }
                                else
                                {
                                    <span class="table-meta">No runs yet</span>
                                }
                            </td>
                            <td>
                                <div class="dashboard-actions">
                                    <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@client.Id" class="btn btn-sm btn-primary">Open Client</a>
                                    <form asp-action="ToggleFavorite" method="post" style="display:inline-flex;align-items:center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="clientId" value="@client.Id" />
                                        <input type="hidden" name="scope" value="@currentScope" />
                                        <input type="hidden" name="q" value="@Model.CurrentSearch" />
                                        <button type="submit"
                                                class="favorite-btn @(client.IsFavorite ? "is-on" : "is-off")"
                                                title="@(client.IsFavorite ? "Remove from favorites" : "Add to favorites")">
                                            @(client.IsFavorite ? "★" : "☆")
                                        </button>
                                    </form>
                                    @if (!client.IsApproved)
                                    {
                                        <span class="btn btn-sm btn-secondary" style="pointer-events:none;opacity:.7">Pending</span>
                                    }

                                    @if (isAdmin && !client.IsApproved && !client.IsArchived)
                                    {
                                        <form asp-controller="Admin" asp-action="ApproveClient" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@client.Id" />
                                            <input type="hidden" name="returnUrl" value="/Dashboard" />
                                            <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-card">
            <p>
                No engagements match this filter.
                @if (isAdmin || isDirector)
                {
                    <a asp-controller="Admin" asp-action="CreateClient">Create the first engagement</a>
                }
            </p>
        </div>
    }
</div>

</div>

@if (!isResultsOnlyRole)
{
    <div class="dashboard-panel" data-dashboard-panel="modules">
    <div class="dashboard-band">
        <div class="dashboard-band__header">
            <div>
                <h3 class="section-title" style="margin-bottom:6px">Modules</h3>
                <p class="dashboard-band__subtitle">Open a validation module only when you need it. Each workspace lets you pick an engagement and then applies your current role permissions automatically.</p>
            </div>
        </div>

        <div class="module-card-grid">
            @foreach (var integrityRule in IntegrityRuleCatalog.GetRuleNumbers().Where(ruleNumber => ruleNumber >= 1 && ruleNumber <= 10).Select(IntegrityRuleCatalog.Get))
            {
                <article class="module-card">
                    <div class="module-card__eyebrow">@integrityRule.RuleLabel</div>
                    <h4 class="module-card__title">@integrityRule.RuleTitle</h4>
                    <p class="module-card__text">@integrityRule.DetailedDescription</p>
                    <div class="module-card__actions">
                        <a href="@RuleRouteHelper.GetWorkspaceUrl(integrityRule.RuleNumber)" class="btn btn-success">Open @integrityRule.RuleLabel</a>
                    </div>
                </article>
            }

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 11</div>
                <h4 class="module-card__title">Qualification Selection from dbo_QUAL</h4>
                <p class="module-card__text">Test 100% of approved undergraduate and postgraduate qualification populations from <code>dbo_QUAL</code> using <code>_004</code>, <code>_005</code>, and the <code>M_____</code> exclusion pattern, then save the workspace for review and signoff.</p>
                <div class="module-card__actions">
                    <a href="/Rule11" class="btn btn-success">Open Rule 11</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 12</div>
                <h4 class="module-card__title">Course Selection from dbo_CREG</h4>
                <p class="module-card__text">Test 100% of the course population selected from <code>dbo_CREG._030</code>, compare it to <code>dbo_CRSE._030</code>, and keep the saved workspace available for review and signoff.</p>
                <div class="module-card__actions">
                    <a href="/Rule12" class="btn btn-success">Open Rule 12</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 13</div>
                <h4 class="module-card__title">CESM Qualification Population Validation</h4>
                <p class="module-card__text">Test 100% of the CESM population where <code>dbo_CESM._006 &lt;&gt; 'ZZZZZZ'</code>, verify the <code>dbo_CESM -&gt; dbo_QUAL -&gt; dbo_STUD</code> linkage on <code>_001</code>, and save the reviewed workspace for signoff.</p>
                <div class="module-card__actions">
                    <a href="/Rule13" class="btn btn-success">Open Rule 13</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 14</div>
                <h4 class="module-card__title">Course Registration Validation</h4>
                <p class="module-card__text">Test 100% of approved courses through the <code>dbo_CRSE -> dbo_CREG</code> path, classify course registration exceptions, and keep the saved workspace available for engagement review.</p>
                <div class="module-card__actions">
                    <a href="/Rule14" class="btn btn-success">Open Rule 14</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 15</div>
                <h4 class="module-card__title">Course Credentials Validation</h4>
                <p class="module-card__text">Test 100% of approved credential courses through the dbo_QUAL -> dbo_CRED -> dbo_CREG path, then review the saved control results and signoffs for the engagement.</p>
                <div class="module-card__actions">
                    <a href="/Rule15" class="btn btn-success">Open Rule 15</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 16</div>
                <h4 class="module-card__title">Student Population Validation</h4>
                <p class="module-card__text">Test 100% of the linked student population where <code>dbo_STUD._025 = 'N'</code> through the <code>dbo_STUD -> dbo_CREG -> dbo_CRSE</code> path, then review the saved control results.</p>
                <div class="module-card__actions">
                    <a href="/Rule16" class="btn btn-success">Open Rule 16</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 17</div>
                <h4 class="module-card__title">Graduate Students Fulfilled Qualification Validation</h4>
                <p class="module-card__text">Validate 100% of the <code>dbo_STUD</code> population where <code>_025 = 'F'</code>, save the filtered result set, and keep the reviewed workspace available across the engagement.</p>
                <div class="module-card__actions">
                    <a href="/Rule17" class="btn btn-success">Open Rule 17</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 18</div>
                <h4 class="module-card__title">NSFAS Student Validation</h4>
                <p class="module-card__text">Test 100% of the NSFAS student population through the <code>dbo_STUD -> bridge -> dbo_CRSE</code> linkage, then filter the saved results by control and PASS or FAIL.</p>
                <div class="module-card__actions">
                    <a href="/Rule18" class="btn btn-success">Open Rule 18</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 19</div>
                <h4 class="module-card__title">Masters and PhD Population Validation</h4>
                <p class="module-card__text">Test 100% of the linked Masters and PhD student population through the <code>dbo_STUD -> dbo_QUAL</code> path using fulfilled and qualification-type filters.</p>
                <div class="module-card__actions">
                    <a href="/Rule19" class="btn btn-success">Open Rule 19</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 20</div>
                <h4 class="module-card__title">Foundation Validation</h4>
                <p class="module-card__text">Run the foundation validation across all students, keep CRSE rows where _091 = 'Y', and review PASS or FAIL results from the saved workspace.</p>
                <div class="module-card__actions">
                    <a href="/Rule20" class="btn btn-success">Open Rule 20</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 21</div>
                <h4 class="module-card__title">First Time Entering Students Validation</h4>
                <p class="module-card__text">Validate 100% of <code>dbo_STUD</code> against the typed <code>_010</code> filter value, classify every row as PASS or FAIL, and keep the saved results visible across the engagement workspace.</p>
                <div class="module-card__actions">
                    <a href="/Rule21" class="btn btn-success">Open Rule 21</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 22</div>
                <h4 class="module-card__title">Staff Sampling (dbo_PROF)</h4>
                <p class="module-card__text">Apply the three notebook staff controls to dbo_PROF, save the full classified result set, and let users filter rows by control and PASS or FAIL.</p>
                <div class="module-card__actions">
                    <a href="/Rule22" class="btn btn-success">Open Rule 22</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 23</div>
                <h4 class="module-card__title">Reconcile Datasets</h4>
                <p class="module-card__text">Reconcile student number, qualification code, and ID number across dbo_STUD, MT-audit-prod-std, and H16STUD before review and export.</p>
                <div class="module-card__actions">
                    <a href="/Rule23" class="btn btn-success">Open Rule 23</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 24</div>
                <h4 class="module-card__title">Reconcile Qualification Datasets</h4>
                <p class="module-card__text">Reconcile qualification codes across dbo_QUAL, MT-audit-prod-QUAL, and H16QUAL, including missing-record checks and configurable approval-status exclusions.</p>
                <div class="module-card__actions">
                    <a href="/Rule24" class="btn btn-success">Open Rule 24</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 25</div>
                <h4 class="module-card__title">Reconcile Course Datasets</h4>
                <p class="module-card__text">Reconcile course codes across dbo_CRSE, MT-audit-prod-CRSE, and H16CRSE to isolate missing or inconsistent course rows before review and export.</p>
                <div class="module-card__actions">
                    <a href="/Rule25" class="btn btn-success">Open Rule 25</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 26</div>
                <h4 class="module-card__title">Bi-Directional 5-Control Validation</h4>
                <p class="module-card__text">Test dbo_PROF and Payroll_Sample in both directions at the same time across personnel existence, employment type, gender, race/group, and birth date controls.</p>
                <div class="module-card__actions">
                    <a href="/Rule26" class="btn btn-success">Open Rule 26</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 27</div>
                <h4 class="module-card__title">Error Validation</h4>
                <p class="module-card__text">Choose any validation table column, detect its values, and retrieve 100% of the records that match the selected value.</p>
                <div class="module-card__actions">
                    <a href="/Rule27" class="btn btn-success">Open Rule 27</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 28</div>
                <h4 class="module-card__title">Fatal Errors with Exclusions (CESM)</h4>
                <p class="module-card__text">Filter fatal CESM validation detail errors, remove approved exclusion codes, and fail the run only when non-excluded fatal rows remain.</p>
                <div class="module-card__actions">
                    <a href="/Rule28" class="btn btn-success">Open Rule 28</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 29</div>
                <h4 class="module-card__title">Single Column Filter</h4>
                <p class="module-card__text">Filter records where one selected column equals one selected value, then review the matching set with optional breakdown and exports.</p>
                <div class="module-card__actions">
                    <a href="/Rule29" class="btn btn-success">Open Rule 29</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 30</div>
                <h4 class="module-card__title">Fatal Errors with Exclusions (PROF)</h4>
                <p class="module-card__text">Filter fatal PROF validation detail errors, remove approved exclusion codes, and fail the run only when non-excluded fatal rows remain.</p>
                <div class="module-card__actions">
                    <a href="/Rule30" class="btn btn-success">Open Rule 30</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 31</div>
                <h4 class="module-card__title">Fatal Errors with Exclusions (QUAL)</h4>
                <p class="module-card__text">Filter fatal QUAL validation detail errors, remove approved exclusion codes, and fail the run only when non-excluded fatal rows remain.</p>
                <div class="module-card__actions">
                    <a href="/Rule31" class="btn btn-success">Open Rule 31</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 32</div>
                <h4 class="module-card__title">Fatal Errors with Exclusions</h4>
                <p class="module-card__text">Filter fatal STUD validation errors, remove the configured exclusion codes, and fail the run only when unapproved fatal errors remain.</p>
                <div class="module-card__actions">
                    <a href="/Rule32" class="btn btn-success">Open Rule 32</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 34</div>
                <h4 class="module-card__title">Census Date Validation</h4>
                <p class="module-card__text">Calculate the midpoint between first and last class dates, compare it to the stored census date, and evaluate weekends and South African public holidays.</p>
                <div class="module-card__actions">
                    <a href="/Rule34" class="btn btn-success">Open Rule 34</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 35</div>
                <h4 class="module-card__title">Duplicate Check on dbo_CRSE</h4>
                <p class="module-card__text">Count duplicate occurrences in the selected dbo_CRSE field, isolate duplicate groups, and save the full duplicate analysis for review and signoff.</p>
                <div class="module-card__actions">
                    <a href="/Rule35" class="btn btn-success">Open Rule 35</a>
                </div>
            </article>

            <article class="module-card">
                <div class="module-card__eyebrow">Rule 36</div>
                <h4 class="module-card__title">Deceased Students Validation</h4>
                <p class="module-card__text">Cross-check student records against the deceased students reference table and save exceptions for analyst review and signoff.</p>
                <div class="module-card__actions">
                    <a href="/Rule36" class="btn btn-success">Open Rule 36</a>
                </div>
            </article>
        </div>

        <div class="empty-card" style="margin-top:16px">
            <p>Choose a module first, then select the engagement inside the workspace. Read-only and signoff access still follow your assigned role on that engagement.</p>
        </div>
    </div>
    </div>
}

<div class="dashboard-panel" data-dashboard-panel="recent-runs">
<div class="dashboard-band">
    <div class="dashboard-band__header">
        <div>
            <h3 class="section-title" style="margin-bottom:6px">Recent Validation Runs</h3>
            <p class="dashboard-band__subtitle">Latest saved results available across your accessible engagements.</p>
        </div>
    </div>

    @if (Model.RecentRuns.Any())
    {
        <div class="card">
            <table class="data-table dashboard-table">
                <thead>
                    <tr>
                        <th>Run</th>
                        <th>Rule</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Exceptions</th>
                        <th>Rate</th>
                        <th>Run By</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in Model.RecentRuns)
                    {
                        <tr>
                            <td>@run.Id</td>
                            <td>Rule @run.RuleNumber</td>
                            <td><span class="badge @((run.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase) || run.Status == "Pass") ? "badge--pass" : "badge--fail")">@run.Status</span></td>
                            <td>@run.TotalValidated.ToString("N0")</td>
                            <td class="@(run.FailCount > 0 ? "text-danger" : "text-success")">@run.FailCount.ToString("N0")</td>
                            <td>@run.ExceptionRate.ToString("F2")%</td>
                            <td>@run.RunByUserName</td>
                            <td>@run.RunAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <div class="dashboard-actions">
                                    <a href="@RuleRouteHelper.GetRunUrl(run.RuleNumber, run.Id)"
                                       class="btn btn-sm btn-secondary">Open</a>
                                    <a href="/Rule@run.RuleNumber/DownloadSavedExcel?runId=@run.Id"
                                       class="btn btn-sm btn-success">Download</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-card">
            <p>No validation runs yet.</p>
        </div>
    }
</div>

</div>

<section class="dashboard-band dashboard-insights dashboard-panel" id="insights" data-dashboard-panel="insights">
    <div class="dashboard-band__header">
        <div>
            <h3 class="section-title" style="margin-bottom:6px">Insights</h3>
            <p class="dashboard-band__subtitle">Workflow health based on active engagements, archived engagements, and the latest validation runs.</p>
        </div>
    </div>

    <div class="dashboard-insight-grid">
        <div class="dashboard-insight-card">
            <div class="dashboard-insight-card__label">Active engagements</div>
            <div class="dashboard-insight-card__value">
                <strong>@Model.ApprovedClients</strong>
                <span>assigned and open</span>
            </div>
        </div>
        <div class="dashboard-insight-card">
            <div class="dashboard-insight-card__label">Archived engagements</div>
            <div class="dashboard-insight-card__value">
                <strong>@Model.ArchivedClients</strong>
                <span>read-only records</span>
            </div>
        </div>
        <div class="dashboard-insight-card">
            <div class="dashboard-insight-card__label">Completed reviews</div>
            <div class="dashboard-insight-card__value">
                <strong>@reviewedAndCompletedRuns</strong>
                <span>all signoffs captured</span>
            </div>
        </div>
        <div class="dashboard-insight-card">
            <div class="dashboard-insight-card__label">Needs review</div>
            <div class="dashboard-insight-card__value">
                <strong>@needsReviewRuns</strong>
                <span>waiting on signoff</span>
            </div>
        </div>
        <div class="dashboard-insight-card">
            <div class="dashboard-insight-card__label">Passed rules</div>
            <div class="dashboard-insight-card__value">
                <strong>@passedRuleRuns</strong>
                <span>@passedRuleRecords.ToString("N0") passing records | @passedRuleRecordRate.ToString("0.##")%</span>
            </div>
        </div>
        <div class="dashboard-insight-card">
            <div class="dashboard-insight-card__label">Failed rules</div>
            <div class="dashboard-insight-card__value">
                <strong>@failedRuleRuns</strong>
                <span>@failedRuleRecords.ToString("N0") failing records | @failedRuleRecordRate.ToString("0.##")%</span>
            </div>
        </div>
    </div>

    <div class="dashboard-insight-layout">
        <div class="dashboard-insight-rows">
            <div class="dashboard-insight-chart">
                <h4>Engagement status</h4>
                <canvas id="engagementStatusChart"></canvas>
            </div>
            <div class="dashboard-insight-chart">
                <h4>Review pipeline</h4>
                <canvas id="reviewPipelineChart"></canvas>
            </div>
            <div class="dashboard-insight-chart">
                <h4>Industry workload</h4>
                <canvas id="industryChart"></canvas>
            </div>
            <div class="dashboard-insight-chart dashboard-insight-chart--rule-outcome">
                <h4>Rule pass vs fail</h4>
                <p class="dashboard-band__subtitle" style="margin:0 0 10px">Latest current run per engagement and rule from the system database.</p>
                @if (Model.RuleOutcomeBreakdown.Any())
                {
                    <div class="dashboard-insight-chart__scroll">
                        <canvas id="ruleOutcomeChart"></canvas>
                    </div>
                }
                else
                {
                    <div class="empty-card" style="padding:20px">
                        <p>No current rule runs are available for your assigned engagements yet.</p>
                    </div>
                }
            </div>
            <div class="dashboard-insight-chart">
                <h4>Signoff coverage</h4>
                <canvas id="signoffChart"></canvas>
            </div>
        </div>

        <div class="dashboard-insight-feed">
            <h4>Latest activity</h4>
            @if (recentInsightRuns.Any())
            {
                <div class="dashboard-activity-list">
                    @foreach (var run in recentInsightRuns)
                    {
                        var complete = run.IsReviewedAndCompleted;
                        var reviewed = run.HasDataAnalystSignoff && !complete;
                        var pending = !run.HasDataAnalystSignoff;
                        <div class="dashboard-activity-item">
                            <span class="dashboard-activity-item__dot @(complete ? "dashboard-activity-item__dot--complete" : reviewed ? "dashboard-activity-item__dot--review" : "dashboard-activity-item__dot--pending")"></span>
                            <div>
                                <div class="dashboard-activity-item__title">
                                    @(!string.IsNullOrWhiteSpace(run.ClientName) ? run.ClientName : $"Run #{run.Id}")
                                </div>
                                <div class="dashboard-activity-item__meta">
                                    Rule @run.RuleNumber | @run.Status | @run.RunAt.ToString("dd MMM yyyy HH:mm")
                                </div>
                                <div class="dashboard-activity-item__meta">
                                    Run by @run.RunByUserName | @run.PassCount.ToString("N0") PASS | @run.FailCount.ToString("N0") FAIL
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="dashboard-activity-empty">No recent validation activity yet.</div>
            }

            <div style="margin-top:16px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px">
                <div class="dashboard-insight-card">
                    <div class="dashboard-insight-card__label">Analyst signoffs</div>
                    <div class="dashboard-insight-card__value"><strong>@analystSignedRuns</strong><span>runs signed by the analyst</span></div>
                </div>
                <div class="dashboard-insight-card">
                    <div class="dashboard-insight-card__label">Archive ready</div>
                    <div class="dashboard-insight-card__value"><strong>@archiveReadyEngagements</strong><span>engagements ready for archive</span></div>
                </div>
                <div class="dashboard-insight-card">
                    <div class="dashboard-insight-card__label">Manager signoffs</div>
                    <div class="dashboard-insight-card__value"><strong>@managerSignedRuns</strong><span>review confirmations</span></div>
                </div>
                <div class="dashboard-insight-card">
                    <div class="dashboard-insight-card__label">Director signoffs</div>
                    <div class="dashboard-insight-card__value"><strong>@directorSignedRuns</strong><span>final approvals</span></div>
                </div>
            </div>
        </div>
    </div>
</section>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
(function () {
    const panels = Array.from(document.querySelectorAll('[data-dashboard-panel]'));
    const tabs = Array.from(document.querySelectorAll('[data-dashboard-tab]'));
    const panelMap = new Map(panels.map(function (panel) {
        return [panel.getAttribute('data-dashboard-panel'), panel];
    }));

    function getVar(name) {
        return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    const charts = [];
    let insightsChartsReady = false;
    const green = '#34d399';
    const amber = '#fbbf24';
    const red = '#fb7185';
    const violet = '#8b5cf6';
    const teal = '#22d3ee';
    const blue = '#60a5fa';

    function isLightTheme() {
        return document.documentElement.classList.contains('light');
    }

    function getChartTextColor() {
        return isLightTheme()
            ? '#000000'
            : (getVar('--text') || '#f1f5f9');
    }

    function getChartLegendTextColor() {
        return isLightTheme()
            ? '#000000'
            : (getVar('--text-muted') || '#d5deea');
    }

    function getChartBorderColor() {
        return getVar('--border') || 'rgba(0,0,0,.08)';
    }

    function resetCharts() {
        while (charts.length) {
            const chart = charts.pop();
            chart.destroy();
        }

        insightsChartsReady = false;
    }

    function makeDoughnut(id, labels, values, colors) {
        const el = document.getElementById(id);
        if (!el) return;
        const legendText = getChartLegendTextColor();
        const border = getChartBorderColor();
        charts.push(new Chart(el, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: colors,
                    borderColor: border,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                aspectRatio: 1.35,
                cutout: '68%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: legendText,
                            boxWidth: 10,
                            usePointStyle: true,
                            pointStyle: 'circle'
                        }
                    },
                    tooltip: {
                        enabled: true
                    }
                }
            }
        }));
    }

    function makeBar(id, labels, values, color) {
        const el = document.getElementById(id);
        if (!el) return;
        const axisText = getChartTextColor();
        const border = getChartBorderColor();
        const longestLabelLength = (labels || []).reduce(function (max, label) {
            return Math.max(max, (label || '').length);
        }, 0);
        const reservedLabelWidth = Math.min(Math.max(longestLabelLength * 14, 220), 320);
        const chartHeight = labels.length <= 2
            ? Math.max(labels.length * 58, 110)
            : Math.min(Math.max(labels.length * 60, 150), 220);
        el.height = chartHeight;
        el.style.setProperty('height', `${chartHeight}px`, 'important');
        charts.push(new Chart(el, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Count',
                    data: values,
                    backgroundColor: color,
                    borderColor: color,
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            color: axisText,
                            precision: 0,
                            font: {
                                size: 13,
                                weight: '600'
                            }
                        },
                        grid: { color: border }
                    },
                    y: {
                        afterFit: function (scale) {
                            scale.width = Math.max(scale.width, reservedLabelWidth);
                        },
                        ticks: {
                            color: axisText,
                            autoSkip: false,
                            crossAlign: 'near',
                            padding: 16,
                            font: {
                                size: 15,
                                weight: '700'
                            }
                        },
                        grid: { color: border }
                    }
                },
                layout: {
                    padding: {
                        left: 36,
                        right: 8
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: { enabled: true }
                }
            }
        }));
    }

    function makeStackedBar(id, labels, passedValues, failedValues) {
        const el = document.getElementById(id);
        if (!el) return;
        const axisText = getChartTextColor();
        const legendText = getChartLegendTextColor();
        const border = getChartBorderColor();
        const chartHeight = Math.max(labels.length * 30, 420);
        el.height = chartHeight;
        el.style.setProperty('height', `${chartHeight}px`, 'important');
        charts.push(new Chart(el, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'PASS',
                    data: passedValues,
                    backgroundColor: green,
                    borderColor: green,
                    borderWidth: 1,
                    borderRadius: 8
                }, {
                    label: 'FAIL',
                    data: failedValues,
                    backgroundColor: red,
                    borderColor: red,
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        stacked: true,
                        beginAtZero: true,
                        ticks: { color: axisText, precision: 0 },
                        grid: { color: border }
                    },
                    y: {
                        stacked: true,
                        ticks: {
                            color: axisText,
                            autoSkip: false,
                            font: {
                                size: 13,
                                weight: '600'
                            }
                        },
                        grid: { color: border }
                    }
                },
                layout: {
                    padding: {
                        left: 8,
                        right: 8
                    }
                },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: legendText,
                            boxWidth: 10,
                            usePointStyle: true,
                            pointStyle: 'circle'
                        }
                    },
                    tooltip: { enabled: true }
                }
            }
        }));
    }

    function renderInsightsCharts() {
        if (insightsChartsReady)
            return;

        const engagementActive = @Model.ApprovedClients;
        const engagementArchived = @Model.ArchivedClients;
        const engagementPending = @Model.PendingApprovalClients;
        const reviewedCompleted = @reviewedAndCompletedRuns;
        const needsReview = @needsReviewRuns;
        const awaitingReview = @Model.AwaitingReviewRuns;
        const analystSigned = @analystSignedRuns;
        const analystUnsigned = @Model.UnsignedAnalystRuns;
        const managerSigned = @managerSignedRuns;
        const directorSigned = @directorSignedRuns;

        makeDoughnut('engagementStatusChart',
            ['Active', 'Archived', 'Pending'],
            [engagementActive, engagementArchived, engagementPending],
            [green, violet, amber]);

        makeDoughnut('reviewPipelineChart',
            ['Reviewed and completed', 'Awaiting review', 'Unsigned by analyst'],
            [reviewedCompleted, awaitingReview, analystUnsigned],
            [teal, amber, red]);

        const industryLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IndustryBreakdown.Select(i => i.Industry).ToArray()));
        const industryValues = [@string.Join(",", Model.IndustryBreakdown.Select(i => i.Count))];
        const ruleOutcomeBreakdown = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.RuleOutcomeBreakdown.Select(i => new {
                label = i.RuleLabel,
                passed = i.PassedCount,
                failed = i.FailedCount
            }).ToArray()));
        const visibleRuleOutcomeBreakdown = ruleOutcomeBreakdown.filter(function (item) {
            return (item.passed || 0) > 0 || (item.failed || 0) > 0;
        });
        const ruleOutcomeLabels = visibleRuleOutcomeBreakdown.map(function (item) { return item.label; });
        const rulePassedValues = visibleRuleOutcomeBreakdown.map(function (item) { return item.passed; });
        const ruleFailedValues = visibleRuleOutcomeBreakdown.map(function (item) { return item.failed; });

        makeBar('industryChart', industryLabels, industryValues, blue);
        if (ruleOutcomeLabels.length) {
            makeStackedBar('ruleOutcomeChart', ruleOutcomeLabels, rulePassedValues, ruleFailedValues);
        }

        makeDoughnut('signoffChart',
            ['Analyst', 'Manager', 'Director'],
            [analystSigned, managerSigned, directorSigned],
            [blue, amber, violet]);

        insightsChartsReady = true;
    }

    function setActivePanel(name) {
        const targetName = panelMap.has(name) ? name : 'engagements';

        panels.forEach(function (panel) {
            panel.classList.toggle('is-active', panel.getAttribute('data-dashboard-panel') === targetName);
        });

        tabs.forEach(function (tab) {
            tab.classList.toggle('is-active', tab.getAttribute('data-dashboard-tab') === targetName);
        });

        if (targetName === 'insights') {
            renderInsightsCharts();
            window.setTimeout(function () {
                charts.forEach(function (chart) { chart.resize(); });
            }, 0);
        }

        if (history && history.replaceState) {
            history.replaceState(null, '', '#' + targetName);
        }
    }

    tabs.forEach(function (tab) {
        tab.addEventListener('click', function (event) {
            event.preventDefault();
            setActivePanel(tab.getAttribute('data-dashboard-tab') || 'engagements');
        });
    });

    const initialHash = (window.location.hash || '').replace('#', '');
    setActivePanel(panelMap.has(initialHash) ? initialHash : 'engagements');

    const themeObserver = new MutationObserver(function () {
        resetCharts();

        if (document.querySelector('[data-dashboard-panel="insights"].is-active')) {
            renderInsightsCharts();
            window.setTimeout(function () {
                charts.forEach(function (chart) { chart.resize(); });
            }, 0);
        }
    });

    themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
    });

    window.addEventListener('beforeunload', function () {
        themeObserver.disconnect();
        resetCharts();
    });
})();
</script>
