@model HemisAudit.ViewModels.Rule35RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 35 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload = ViewBag.CanDownloadSavedRun is bool allowed && allowed;
    var canManageEngagement = ViewBag.CanManageEngagement is bool manageEngagement && manageEngagement;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool openWorkspace && openWorkspace;
    var isArchived = ViewBag.IsArchived is bool archived && archived;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    var headers = new[] { "ValidationNumber", "DuplicateValue", "OccurrenceCount", "DuplicateStatus" }
        .Concat(Model.Summary.ValidationRows.SelectMany(r => r.DisplayValues.Keys))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<style>
    .review-tabs { display:flex; gap:0; border-bottom:1px solid #e5e7eb; margin-bottom:24px; overflow:auto; }
    .review-tab { background:none; border:0; border-bottom:3px solid transparent; color:#334155; cursor:pointer; font:inherit; padding:14px 18px; white-space:nowrap; }
    .review-tab.is-active { border-bottom-color:#ef4444; color:#dc2626; font-weight:700; }
    .review-panel { display:none; }
    .review-panel.is-active { display:block; }
    .viz-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); }
    .viz-card { background:#fff; border:1px solid #e5e7eb; border-radius:18px; padding:20px; box-shadow:0 18px 40px rgba(15, 23, 42, .06); }
    .viz-bar { background:#e5e7eb; border-radius:999px; height:14px; overflow:hidden; margin-top:10px; }
    .viz-bar > span { display:block; height:100%; }
    .code-panel { background:#0f172a; border-radius:18px; color:#e2e8f0; overflow:auto; padding:18px; }
    .code-panel pre { margin:0; white-space:pre-wrap; word-break:break-word; }
</style>

<div class="page-header">
    <div>
        <h1>Rule 35 Saved Run</h1>
        <p>
            @Model.EngagementName
            <span style="padding:0 8px">|</span>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            Run #@Model.RunId
            <span style="padding:0 8px">|</span>
            @Model.Summary.Timestamp
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Back to Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The saved run is available for review and download only.
    </div>
}

@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">
        The data analyst signoff is still outstanding. Assigned users can still review and download this run.
    </div>
}

<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">
                @(Model.CurrentUserHasSignedOff ? $"Signed Off as {Model.CurrentUserEngagementRole}" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>

        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">Remove Signoff</button>
            </form>
        }
    }
    else if (!Model.IsCurrentRun && !isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">History results are read-only for signoff. Signoff is only available on the current run.</div>
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Reviewer</th>
                    <th>Comment</th>
                    <th>Signed At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td><strong>@signoff.ReviewerName</strong><br /><small style="color:#757575">@signoff.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:0 0 24px">
    <div class="review-tabs">
        <button type="button" class="review-tab is-active" data-review-tab="analysis">Analysis Results</button>
        <button type="button" class="review-tab" data-review-tab="details">Validation Rows</button>
        <button type="button" class="review-tab" data-review-tab="visuals">Visualizations</button>
        <button type="button" class="review-tab" data-review-tab="sql">SQL Code</button>
        <button type="button" class="review-tab" data-review-tab="downloads">Downloads</button>
    </div>

    <div class="review-panel is-active" data-review-panel="analysis" style="padding:24px">
        <div class="stats-grid" style="margin-bottom:24px">
            <div class="stat-card">
                <div class="stat-card__label">100% Source Records Tested</div>
                <div class="stat-card__value">@Model.Summary.TotalValidated.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--pass">
                <div class="stat-card__label">Unique Values</div>
                <div class="stat-card__value">@Model.Summary.UniqueValues.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">Duplicate Values</div>
                <div class="stat-card__value">@Model.Summary.DuplicateValues.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Duplicate Records</div>
                <div class="stat-card__value">@Model.Summary.DuplicateRecords.ToString("N0")</div>
            </div>
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Run Summary</h3>
            <div class="form-grid">
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div>
                    <div>@Model.Summary.Database</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule</div>
                    <div>Rule 35 - Duplicate Check on dbo_CRSE</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Source Table</div>
                    <div>@Model.Summary.TableName</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Duplicate Field</div>
                    <div>@Model.Summary.DuplicateColumn</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                    <div><span class="badge @(Model.Summary.Status == "PASS" ? "badge--pass" : "badge--fail")">@Model.Summary.Status</span></div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Duplicate Record Rate</div>
                    <div>@Model.Summary.ExceptionRate.ToString("F2")%</div>
                </div>
            </div>

            @if (Model.Summary.DuplicateSummary.Any())
            {
                <div style="margin-top:20px">
                    <h4 style="margin:0 0 10px 0">Duplicate Value Summary</h4>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Value</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Summary.DuplicateSummary.Take(10))
                            {
                                <tr>
                                    <td>@item.Value</td>
                                    <td>@item.Count.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="review-panel" data-review-panel="details" style="padding:24px">
        @if (Model.Summary.ValidationRows.Any())
        {
            <div class="card" style="padding:20px">
                <div class="alert alert--info" style="margin-bottom:16px">
                    @($"100% testing evaluated {Model.Summary.TotalValidated:N0} rows. The browser shows only the first {Model.Summary.ValidationRows.Take(10).Count():N0} row(s) to stay responsive.")
                </div>
                <h3 class="section-title" style="margin-top:0">Validation Rows</h3>
                <div style="overflow:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var header in headers)
                                {
                                    <th>@header</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Summary.ValidationRows.Take(10))
                            {
                                <tr>
                                    @foreach (var header in headers)
                                    {
                                        var value = header switch
                                        {
                                            "ValidationNumber" => row.ValidationNumber.ToString(),
                                            "DuplicateValue" => row.DuplicateValue,
                                            "OccurrenceCount" => row.OccurrenceCount.ToString(),
                                            "DuplicateStatus" => row.DuplicateStatus,
                                            _ => row.DisplayValues.TryGetValue(header, out var currentValue) ? currentValue ?? "" : ""
                                        };
                                        <td>@value</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert--info" style="margin:0">No validation rows were saved in this run.</div>
        }
    </div>

    <div class="review-panel" data-review-panel="visuals" style="padding:24px">
        <div class="viz-grid">
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Duplicate Records</div>
                <div style="font-size:36px;font-weight:800;color:#dc2626">@Model.Summary.DuplicateRecords.ToString("N0")</div>
                <div class="viz-bar"><span style="width:@(Model.Summary.TotalValidated == 0 ? 0 : (Model.Summary.DuplicateRecords * 100m / Model.Summary.TotalValidated).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#ef4444"></span></div>
                <div style="color:#64748b;margin-top:10px">@Model.Summary.ExceptionRate.ToString("F2")% of all tested records fall into duplicate groups.</div>
            </div>
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Unique Values</div>
                <div style="font-size:36px;font-weight:800;color:#16a34a">@Model.Summary.UniqueValues.ToString("N0")</div>
                <div class="viz-bar"><span style="width:@(Model.Summary.TotalValidated == 0 ? 0 : (Model.Summary.PassCount * 100m / Model.Summary.TotalValidated).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#22c55e"></span></div>
                <div style="color:#64748b;margin-top:10px">Rows attached to unique values remain in the pass set.</div>
            </div>
        </div>

        <div class="viz-card" style="margin-top:16px">
            <h3 class="section-title" style="margin-top:0">Duplicate Groups</h3>
            @if (Model.Summary.DuplicateSummary.Any())
            {
                @foreach (var item in Model.Summary.DuplicateSummary.Take(10))
                {
                    var width = Model.Summary.DuplicateRecords == 0 ? 0 : (item.Count * 100m / Model.Summary.DuplicateRecords);
                    <div style="margin-bottom:12px">
                        <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:6px">
                            <strong>@item.Value</strong>
                            <span>@item.Count.ToString("N0")</span>
                        </div>
                        <div class="viz-bar"><span style="width:@width.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%;background:#f97316"></span></div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert--success" style="margin:0">No duplicate groups were found in this saved run.</div>
            }
        </div>
    </div>

    <div class="review-panel" data-review-panel="sql" style="padding:24px">
        <div class="code-panel">
            <pre>@Model.GeneratedSql</pre>
        </div>
    </div>

    <div class="review-panel" data-review-panel="downloads" style="padding:24px">
        <div class="action-bar" style="justify-content:flex-start;margin:0">
            @if (canDownload)
            {
                <a asp-action="DownloadSavedExcel" asp-route-runId="@Model.RunId" class="btn btn-info">Excel</a>
                <a asp-action="DownloadSavedCsv" asp-route-runId="@Model.RunId" class="btn btn-info">CSV</a>
                <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-secondary">SQL</a>
            }
            else
            {
                <div class="alert alert--info" style="margin:0">Download access opens after the assigned data analyst signoff is present on the current run.</div>
            }
        </div>
    </div>
</div>

<script>
(() => {
    const tabs = Array.from(document.querySelectorAll('.review-tab'));
    const panels = Array.from(document.querySelectorAll('.review-panel'));
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(item => item.classList.remove('is-active'));
            panels.forEach(panel => panel.classList.remove('is-active'));
            tab.classList.add('is-active');
            document.querySelector(`[data-review-panel="${tab.dataset.reviewTab}"]`)?.classList.add('is-active');
        });
    });
})();
</script>
