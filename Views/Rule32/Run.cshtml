@model HemisAudit.ViewModels.Rule32RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 32 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = ViewBag.IsAdmin is bool admin && admin;
    var canDownload = ViewBag.CanDownloadSavedRun is bool allowed && allowed;
    var canManageEngagement = ViewBag.CanManageEngagement is bool manageEngagement && manageEngagement;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool openWorkspace && openWorkspace;
    var isArchived = ViewBag.IsArchived is bool archived && archived;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    var detailHeaders = new[] { "ValidationNumber", "Classification", "ErrorTypeValue", "ErrorCode", "NormalizedErrorCode" }
        .Concat(Model.Summary.ExcludedRows.SelectMany(r => r.DisplayValues.Keys))
        .Concat(Model.Summary.RemainingRows.SelectMany(r => r.DisplayValues.Keys))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<style>
    .review-tabs { display:flex; gap:0; border-bottom:1px solid #e5e7eb; margin-bottom:24px; overflow:auto; }
    .review-tab { background:none; border:0; border-bottom:3px solid transparent; color:#334155; cursor:pointer; font:inherit; padding:14px 18px; white-space:nowrap; }
    .review-tab.is-active { border-bottom-color:#ef4444; color:#dc2626; font-weight:700; }
    .review-panel { display:none; }
    .review-panel.is-active { display:block; }
    .viz-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); }
    .viz-card { background:#fff; border:1px solid #e5e7eb; border-radius:18px; padding:20px; box-shadow:0 18px 40px rgba(15, 23, 42, .06); }
    .viz-bar { background:#e5e7eb; border-radius:999px; height:14px; overflow:hidden; margin-top:10px; }
    .viz-bar > span { display:block; height:100%; }
    .code-panel { background:#0f172a; border-radius:18px; color:#e2e8f0; overflow:auto; padding:18px; }
    .code-panel pre { margin:0; white-space:pre-wrap; word-break:break-word; }
</style>

<div class="page-header">
    <div>
        <h1>Rule 32 Saved Run</h1>
        <p>
            @Model.EngagementName
            <span style="padding:0 8px">|</span>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            Run #@Model.RunId
            <span style="padding:0 8px">|</span>
            @Model.Summary.Timestamp
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Back to Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The saved run is available for review and download only.
    </div>
}

@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">
        The assigned data analyst must sign off before managers, directors, and trainees can download this run.
    </div>
}

<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>
    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary">
                @(Model.CurrentUserHasSignedOff ? "Update My Signoff" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>

        @if (Model.CurrentUserHasSignedOff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove your signoff for this validation run?')">Remove My Signoff</button>
            </form>
        }
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Reviewer</th>
                    <th>Comment</th>
                    <th>Signed At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td><strong>@signoff.ReviewerName</strong><br /><small style="color:#757575">@signoff.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:0 0 24px">
    <div class="review-tabs" role="tablist" aria-label="Rule 32 review tabs">
        <button type="button" class="review-tab is-active" data-review-tab="analysis">Analysis Results</button>
        <button type="button" class="review-tab" data-review-tab="details">Data Details</button>
        <button type="button" class="review-tab" data-review-tab="visuals">Visualizations</button>
        <button type="button" class="review-tab" data-review-tab="sql">SQL Code</button>
        <button type="button" class="review-tab" data-review-tab="downloads">Downloads</button>
    </div>

    <div class="review-panel is-active" data-review-panel="analysis" style="padding:24px">
        <div class="stats-grid" style="margin-bottom:24px">
            <div class="stat-card">
                <div class="stat-card__label">Fatal</div>
                <div class="stat-card__value">@Model.Summary.TotalFatal.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--pass">
                <div class="stat-card__label">Excluded</div>
                <div class="stat-card__value">@Model.Summary.ExcludedCount.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">Remaining</div>
                <div class="stat-card__value">@Model.Summary.RemainingCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Status</div>
                <div class="stat-card__value">@Model.Summary.Status</div>
            </div>
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Run Summary</h3>
            <div class="form-grid">
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div>
                    <div>@Model.Summary.Database</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule</div>
                    <div>Rule 32 - Fatal Errors with Exclusions (STUD)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Source Table</div>
                    <div>@Model.Summary.TableName</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Columns</div>
                    <div>@Model.Summary.ErrorTypeColumn | @Model.Summary.ErrorColumn</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Filter Value</div>
                    <div>@Model.Summary.ErrorTypeValue</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Exclusions</div>
                    <div>@string.Join(", ", Model.Summary.Exclusions)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Normalized Exclusions</div>
                    <div>@string.Join(", ", Model.Summary.NormalizedExclusions)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Exception Rate</div>
                    <div>@Model.Summary.ExceptionRate.ToString("F2")%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="review-panel" data-review-panel="details" style="padding:24px">
        <div class="card" style="margin-bottom:24px;padding:20px">
            <h3 class="section-title" style="margin-top:0">Excluded Fatal Errors</h3>
            @if (Model.Summary.ExcludedRows.Any())
            {
                <div style="overflow:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var header in detailHeaders)
                                {
                                    <th>@header</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Summary.ExcludedRows.Take(200))
                            {
                                <tr>
                                    @foreach (var header in detailHeaders)
                                    {
                                        var value = header switch
                                        {
                                            "ValidationNumber" => row.ValidationNumber.ToString(),
                                            "Classification" => row.Classification,
                                            "ErrorTypeValue" => row.ErrorTypeValue,
                                            "ErrorCode" => row.ErrorCode,
                                            "NormalizedErrorCode" => row.NormalizedErrorCode,
                                            _ => row.DisplayValues.TryGetValue(header, out var currentValue) ? currentValue ?? "" : ""
                                        };
                                        <td>@value</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert--info" style="margin:0">No excluded fatal errors were captured in this saved run.</div>
            }
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Remaining Fatal Errors</h3>
            @if (Model.Summary.RemainingRows.Any())
            {
                <div style="overflow:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var header in detailHeaders)
                                {
                                    <th>@header</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Summary.RemainingRows.Take(200))
                            {
                                <tr>
                                    @foreach (var header in detailHeaders)
                                    {
                                        var value = header switch
                                        {
                                            "ValidationNumber" => row.ValidationNumber.ToString(),
                                            "Classification" => row.Classification,
                                            "ErrorTypeValue" => row.ErrorTypeValue,
                                            "ErrorCode" => row.ErrorCode,
                                            "NormalizedErrorCode" => row.NormalizedErrorCode,
                                            _ => row.DisplayValues.TryGetValue(header, out var currentValue) ? currentValue ?? "" : ""
                                        };
                                        <td>@value</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert--success" style="margin:0">No remaining fatal errors. This saved run passed.</div>
            }
        </div>
    </div>

    <div class="review-panel" data-review-panel="visuals" style="padding:24px">
        <div class="viz-grid">
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Excluded Share</div>
                <div style="font-size:36px;font-weight:800;color:#166534">@Model.Summary.ExcludedCount.ToString("N0")</div>
                <div class="viz-bar"><span style="width:@(Model.Summary.TotalFatal == 0 ? 0 : (Model.Summary.ExcludedCount * 100m / Model.Summary.TotalFatal).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#22c55e"></span></div>
            </div>
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Remaining Share</div>
                <div style="font-size:36px;font-weight:800;color:#dc2626">@Model.Summary.RemainingCount.ToString("N0")</div>
                <div class="viz-bar"><span style="width:@(Model.Summary.TotalFatal == 0 ? 0 : (Model.Summary.RemainingCount * 100m / Model.Summary.TotalFatal).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#ef4444"></span></div>
            </div>
        </div>

        <div class="viz-grid" style="margin-top:20px">
            <div class="viz-card">
                <h4 style="margin-top:0">Excluded Breakdown</h4>
                @if (Model.Summary.ExcludedBreakdown.Any())
                {
                    @foreach (var item in Model.Summary.ExcludedBreakdown.Take(10))
                    {
                        <div style="margin-bottom:14px">
                            <div style="display:flex;justify-content:space-between;gap:12px">
                                <strong>@item.ErrorCode</strong>
                                <span>@item.Count.ToString("N0")</span>
                            </div>
                            <div class="viz-bar"><span style="width:@(Model.Summary.ExcludedCount == 0 ? 0 : (item.Count * 100m / Model.Summary.ExcludedCount).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#14b8a6"></span></div>
                        </div>
                    }
                }
                else
                {
                    <div style="color:#64748b">No excluded breakdown data available.</div>
                }
            </div>
            <div class="viz-card">
                <h4 style="margin-top:0">Remaining Breakdown</h4>
                @if (Model.Summary.RemainingBreakdown.Any())
                {
                    @foreach (var item in Model.Summary.RemainingBreakdown.Take(10))
                    {
                        <div style="margin-bottom:14px">
                            <div style="display:flex;justify-content:space-between;gap:12px">
                                <strong>@item.ErrorCode</strong>
                                <span>@item.Count.ToString("N0")</span>
                            </div>
                            <div class="viz-bar"><span style="width:@(Model.Summary.RemainingCount == 0 ? 0 : (item.Count * 100m / Model.Summary.RemainingCount).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#f97316"></span></div>
                        </div>
                    }
                }
                else
                {
                    <div style="color:#64748b">No remaining breakdown data available.</div>
                }
            </div>
        </div>
    </div>

    <div class="review-panel" data-review-panel="sql" style="padding:24px">
        <div class="card" style="padding:20px;margin-bottom:20px">
            <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap">
                <div>
                    <h3 class="section-title" style="margin:0">Saved SQL Preview</h3>
                    <div style="color:#64748b;margin-top:4px">Review the SQL generated from the saved run configuration.</div>
                </div>
                @if (canDownload)
                {
                    <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-primary">Download SQL</a>
                }
            </div>
        </div>
        <div class="code-panel"><pre><code>@Model.GeneratedSql</code></pre></div>
    </div>

    <div class="review-panel" data-review-panel="downloads" style="padding:24px">
        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Downloads</h3>
            @if (canDownload)
            {
                <div style="display:flex;gap:10px;flex-wrap:wrap">
                    <a asp-action="DownloadSavedExcel" asp-route-runId="@Model.RunId" class="btn btn-success">Excel</a>
                    <a asp-action="DownloadSavedCsv" asp-route-runId="@Model.RunId" class="btn btn-info">Full CSV</a>
                    <a asp-action="DownloadSavedExceptionsCsv" asp-route-runId="@Model.RunId" class="btn btn-info">Remaining CSV</a>
                    <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-primary">SQL</a>
                </div>
            }
            else
            {
                <div class="alert alert--warning" style="margin:0">
                    Download is available to the assigned data analyst immediately, and to other assigned users after the data analyst signoff.
                </div>
            }
        </div>
    </div>
</div>

<script>
(() => {
    const tabs = Array.from(document.querySelectorAll('[data-review-tab]'));
    const panels = Array.from(document.querySelectorAll('[data-review-panel]'));

    function setActiveTab(name) {
        tabs.forEach(tab => tab.classList.toggle('is-active', tab.getAttribute('data-review-tab') === name));
        panels.forEach(panel => panel.classList.toggle('is-active', panel.getAttribute('data-review-panel') === name));
    }

    tabs.forEach(tab => {
        tab.addEventListener('click', () => setActiveTab(tab.getAttribute('data-review-tab')));
    });
})();
</script>
