@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Rule 19 - Masters and PhD Population Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int currentClientId ? currentClientId : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

@if (isResultsOnlyRole)
{
    <style>
        #app > .accordion-stack > .accordion-item:nth-child(-n+3),
        #app > .action-bar {
            display: none !important;
        }
    </style>
}

<style>
    .rule19-preview-wrap {
        overflow-x: auto;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #fff;
    }

    .rule19-preview-table {
        width: max-content;
        min-width: 100%;
        table-layout: auto;
    }

    .rule19-preview-table thead th,
    .rule19-preview-table td {
        white-space: nowrap;
        overflow-wrap: normal;
        word-break: normal;
        font-family: Consolas, "Courier New", monospace;
        font-size: 13px;
    }

    .rule19-preview-table td.is-pass {
        color: #0f766e;
        font-weight: 700;
    }

    .rule19-preview-table td.is-fail {
        color: #b91c1c;
        font-weight: 700;
    }

    .rule19-stat-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    .rule19-summary-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .rule19-muted {
        color: #64748b;
        font-size: 13px;
    }

    .rule19-chip {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: #f3e8ff;
        color: #6b21a8;
        font-size: 12px;
        font-weight: 700;
    }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="clientId">Engagement</label>
        <select id="clientId">
            <option value="">Select engagement (results saved here)</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
        <small>Saved runs reload the last analyst configuration for this engagement.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R19</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 19: Masters and PhD Population Validation</h1>
            <p class="rule-header__sub">100% testing only across the <code>dbo_STUD -> dbo_QUAL</code> linkage using <code>STUD._001 = QUAL._001</code>.</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    <div class="accordion-stack">
        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('connection')">
                <span class="acc-icon">DB</span>
                <span>Database Connection</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-connection">
                <div class="form-grid">
                    <div class="field-group">
                        <label for="server">Server Name</label>
                        <input id="server" type="text" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label for="driver">Driver</label>
                        <select id="driver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="database">Database</label>
                        <select id="database"></select>
                    </div>
                </div>
                <div class="action-bar" style="justify-content:flex-start;margin:12px 0 0">
                    <button type="button" class="btn btn-primary" id="connectBtn">Connect</button>
                    <button type="button" class="btn btn-info" id="verifyBtn">Verify Tables</button>
                </div>
                <div id="connectionOutput" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('config')">
                <span class="acc-icon">CF</span>
                <span>Rule Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-config" style="display:none">
                <div class="info-box info-box--red">
                    <strong>Rule 19 Logic:</strong><br />
                    Link <strong>dbo_STUD._001</strong> to <strong>dbo_QUAL._001</strong>, keep rows where
                    <strong>dbo_STUD._025</strong> matches the selected fulfilled value, and keep only qualification
                    types in the configured Masters/Doctoral list from <strong>dbo_QUAL._005</strong>.
                    <br />
                    Rule 19 uses <strong>100% population testing only</strong>. No random sample is used in this module.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label for="studTable">STUD Table</label>
                        <select id="studTable"></select>
                    </div>
                    <div class="field-group">
                        <label for="qualTable">QUAL Table</label>
                        <select id="qualTable"></select>
                    </div>
                    <div class="field-group">
                        <label for="qualCodeColumn">Qualification Code Column</label>
                        <select id="qualCodeColumn"></select>
                    </div>
                    <div class="field-group">
                        <label for="fulfilledColumn">Fulfilled Column</label>
                        <select id="fulfilledColumn"></select>
                    </div>
                    <div class="field-group">
                        <label for="qualTypeColumn">Qualification Type Column</label>
                        <select id="qualTypeColumn"></select>
                    </div>
                    <div class="field-group" style="grid-column:1 / -1">
                        <label for="mdTypesText">Masters / Doctoral Type Codes</label>
                        <textarea id="mdTypesText" rows="3">07, 27, 28, 49, 72, 73, 08, 30, 50, 74, 75</textarea>
                    </div>
                </div>
                <div class="rule19-muted" style="margin-top:8px">
                    Rule 19 follows the notebook logic and returns the full qualifying population in the saved results and exports.
                </div>
                <div id="configOutput" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('filter')">
                <span class="acc-icon">FV</span>
                <span>Filter Value</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-filter" style="display:none">
                <div class="field-group">
                    <label for="fulfilledValue">Fulfilled Filter Value</label>
                    <div class="action-bar" style="justify-content:flex-start;margin:0">
                        <select id="fulfilledValue" style="max-width:440px"></select>
                        <button type="button" class="btn btn-info" id="loadValuesBtn">Refresh</button>
                    </div>
                </div>
                <div class="rule19-muted" style="margin-top:8px">
                    The dropdown loads the distinct fulfilled values exactly as the notebook query returns them, ordered by record count.
                </div>
                <div id="filterOutput" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('downloads')">
                <span class="acc-icon">DL</span>
                <span>Export Options</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-downloads" style="display:none">
                <div class="checkbox-row">
                    <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL</label>
                </div>
            </div>
        </div>
    </div>

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 19 connection, configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">
            Select an engagement to load the saved Rule 19 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div>
                <div id="workspaceRunLabel">No saved run yet</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                <div id="workspaceStatusLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div>
                <div id="workspaceEditedLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div>
                <div id="workspaceRoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div>
            </div>
            <div class="field-group" style="grid-column:1 / -1">
                <label for="workspaceSignoffComment">Signoff Comment</label>
                <textarea id="workspaceSignoffComment" rows="3" placeholder="Add review or completion notes"></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            <button type="button" class="btn btn-secondary" id="beginEditBtn">Begin Edit</button>
            <button type="button" class="btn btn-success" id="saveWorkspaceBtn">Save Workspace</button>
            <button type="button" class="btn btn-primary" id="signoffBtn">Save Signoff</button>
            <button type="button" class="btn btn-warning" id="removeSignoffBtn">Remove My Signoff</button>
        </div>
    </div>

    <div class="action-bar">
        <button type="button" class="btn btn-info" id="verifyBtnBar">Verify Tables</button>
        <button type="button" class="btn btn-success" id="runBtn">Run Rule 19</button>
        <button type="button" class="btn btn-primary" id="sqlBtn">Generate SQL</button>
        <button type="button" class="btn btn-warning" id="downloadAllBtn" disabled>Download All</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
            <button class="tab-btn" type="button" data-tab="downloads">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis" id="analysisPane"></div>
        <div class="tab-pane" data-tab-panel="results" id="resultsPane"></div>
        <div class="tab-pane" data-tab-panel="sql">
            <textarea id="sqlText" rows="18" readonly></textarea>
        </div>
        <div class="tab-pane" data-tab-panel="downloads">
            <div class="alert alert--info" style="margin-bottom:16px">
                Excel and CSV downloads include the saved Rule 19 result set. The browser preview stays limited for performance, while downloads keep the full qualifying population.
            </div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info" id="downloadExcelBtn">Excel</button>
                <button type="button" class="btn btn-info" id="downloadCsvBtn">CSV</button>
                <button type="button" class="btn btn-secondary" id="downloadSqlBtn">SQL</button>
            </div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="spinnerMsg">Processing...</p>
        </div>
    </div>
</div>

<form id="antiForgeryForm" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<script>
(() => {
    const currentSystemRole = '@currentSystemRole';
    const apiBasePath = '/Rule19';
    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';
    const defaultMdTypes = '07, 27, 28, 49, 72, 73, 08, 30, 50, 74, 75';
    const state = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        currentRunId: null,
        summary: null,
        resultFilter: 'ALL',
        currentStatus: '',
        currentUserEngagementRole: '',
        currentUserHasSignedOff: false,
        hasDataAnalystSignoff: false,
        resultsVisible: false,
        isHydrating: false,
        isDirty: false,
        workspaceRequestVersion: 0,
        uiMutationVersion: 0
    };

    const els = {
        clientId: document.getElementById('clientId'),
        server: document.getElementById('server'),
        driver: document.getElementById('driver'),
        database: document.getElementById('database'),
        studTable: document.getElementById('studTable'),
        qualTable: document.getElementById('qualTable'),
        qualCodeColumn: document.getElementById('qualCodeColumn'),
        fulfilledColumn: document.getElementById('fulfilledColumn'),
        fulfilledValue: document.getElementById('fulfilledValue'),
        qualTypeColumn: document.getElementById('qualTypeColumn'),
        mdTypesText: document.getElementById('mdTypesText'),
        chkExcel: document.getElementById('chkExcel'),
        chkCsv: document.getElementById('chkCsv'),
        chkSql: document.getElementById('chkSql'),
        connectionOutput: document.getElementById('connectionOutput'),
        configOutput: document.getElementById('configOutput'),
        filterOutput: document.getElementById('filterOutput'),
        analysisPane: document.getElementById('analysisPane'),
        resultsPane: document.getElementById('resultsPane'),
        sqlText: document.getElementById('sqlText'),
        statusBadge: document.getElementById('statusBadge'),
        workspaceInfo: document.getElementById('workspaceInfo'),
        workspaceRunState: document.getElementById('workspaceRunState'),
        workspaceRunLabel: document.getElementById('workspaceRunLabel'),
        workspaceStatusLabel: document.getElementById('workspaceStatusLabel'),
        workspaceEditedLabel: document.getElementById('workspaceEditedLabel'),
        workspaceRoleLabel: document.getElementById('workspaceRoleLabel'),
        workspaceSignoffComment: document.getElementById('workspaceSignoffComment'),
        beginEditBtn: document.getElementById('beginEditBtn'),
        saveWorkspaceBtn: document.getElementById('saveWorkspaceBtn'),
        signoffBtn: document.getElementById('signoffBtn'),
        removeSignoffBtn: document.getElementById('removeSignoffBtn'),
        downloadAllBtn: document.getElementById('downloadAllBtn')
    };

    function normalizeRole(value) {
        return String(value || '').trim().toLowerCase();
    }

    function toggleAccordion(name) {
        const body = document.getElementById(`body-${name}`);
        const open = body && body.style.display !== 'none';
        if (body) body.style.display = open ? 'none' : 'block';
    }
    window.toggleAccordion = toggleAccordion;

    function showSpinner(message) {
        document.getElementById('spinnerMsg').textContent = message || 'Processing...';
        document.getElementById('spinner').style.display = 'flex';
    }

    function hideSpinner() {
        document.getElementById('spinner').style.display = 'none';
    }

    function htmlEscape(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatNumber(value) {
        return Number(value || 0).toLocaleString();
    }

    function setAlert(target, type, message) {
        target.innerHTML = message ? `<div class="alert alert--${type}">${message}</div>` : '';
    }

    function setWorkspaceInfo(type, message) {
        els.workspaceInfo.className = `alert alert--${type}`;
        els.workspaceInfo.textContent = message;
        window.showWorkspaceActionToast?.(message, type);
    }

    function setStatusBadge(text, type) {
        if (!text) {
            els.statusBadge.style.display = 'none';
            els.statusBadge.textContent = '';
            return;
        }

        els.statusBadge.style.display = 'inline-block';
        els.statusBadge.className = `rule-header__badge ${type === 'pass' ? 'badge--pass' : type === 'fail' ? 'badge--fail' : 'badge--neutral'}`;
        els.statusBadge.textContent = text;
    }

    function populateSelect(select, options, selectedValue) {
        if (!select) return;
        select.innerHTML = '';
        (options || []).forEach(option => {
            const opt = document.createElement('option');
            if (Array.isArray(option)) {
                opt.textContent = option[0];
                opt.value = option[1];
            } else if (typeof option === 'object') {
                opt.value = option.value ?? option.Value ?? '';
                opt.textContent = option.label ?? option.Label ?? option.value ?? option.Value ?? '';
            } else {
                opt.value = option;
                opt.textContent = option;
            }
            if (selectedValue != null && String(opt.value) === String(selectedValue)) {
                opt.selected = true;
            }
            select.appendChild(opt);
        });
    }

    function ensureOption(select, value, text) {
        if (!select || !value) return;
        if (!Array.from(select.options).some(option => option.value === value)) {
            const option = document.createElement('option');
            option.value = value;
            option.textContent = text || value;
            select.appendChild(option);
        }
        select.value = value;
    }

    async function postJson(url, data) {
        return await window.fetchJsonWithProgress(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(data || {})
        });
    }

    async function downloadBlob(url, payload, defaultName) {
        await window.downloadFileWithProgress({
            url,
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(payload),
            defaultFileName: defaultName,
            label: 'Downloading result'
        });
    }

    function getRequest() {
        return {
            clientId: parseInt(els.clientId.value || '0', 10) || 0,
            runId: state.currentRunId,
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value,
            studTable: els.studTable.value,
            qualTable: els.qualTable.value,
            qualCodeColumn: els.qualCodeColumn.value,
            fulfilledColumn: els.fulfilledColumn.value,
            fulfilledValue: els.fulfilledValue.value,
            qualTypeColumn: els.qualTypeColumn.value,
            mdTypesText: els.mdTypesText.value.trim() || defaultMdTypes,
            showAllRecords: true
        };
    }

    async function markWorkspaceDirty() {
        if (state.isHydrating) return;
        state.isDirty = true;
        state.uiMutationVersion++;
        updateWorkspaceButtons();
    }

    function updateWorkspaceButtons() {
        const role = state.currentUserEngagementRole || currentSystemRole || '';
        const normalizedRole = normalizeRole(role);
        const normalizedSystemRole = normalizeRole(currentSystemRole);
        const canEdit = normalizedSystemRole === 'dataanalyst' || normalizedRole === 'dataanalyst';
        const canSign = !!state.currentRunId &&
            (normalizedRole === 'dataanalyst' || (state.resultsVisible && (normalizedRole === 'manager' || normalizedRole === 'director')));
        const signoffLocked = !!state.currentUserHasSignedOff;

        window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit || signoffLocked);
        window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit || signoffLocked);
        window.ruleWorkspaceUi.applyStates([
            { target: 'connectBtn', disabled: !canEdit || signoffLocked },
            { target: 'verifyBtn', disabled: !canEdit || signoffLocked },
            { target: 'verifyBtnBar', disabled: !canEdit || signoffLocked },
            { target: 'loadValuesBtn', disabled: !canEdit || signoffLocked },
            { target: 'runBtn', disabled: !canEdit || signoffLocked },
            { target: 'sqlBtn', disabled: !canEdit || signoffLocked },
            { target: els.beginEditBtn, disabled: signoffLocked || !canEdit || !state.currentRunId },
            { target: els.saveWorkspaceBtn, disabled: signoffLocked || !canEdit || !state.currentRunId || !state.summary },
            {
                target: els.signoffBtn,
                disabled: signoffLocked || !canSign,
                text: state.currentUserHasSignedOff ? `Signed Off as ${role || currentSystemRole}` : 'Save Signoff'
            },
            { target: els.removeSignoffBtn, show: state.currentUserHasSignedOff, display: '', disabled: !state.currentUserHasSignedOff },
            { target: els.workspaceSignoffComment, disabled: signoffLocked || !canSign }
        ]);
        window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions', '.action-bar'], signoffLocked, {
            allow: ['#downloadAllBtn', '#downloadExcelBtn', '#downloadCsvBtn', '#downloadSqlBtn', '#removeSignoffBtn']
        });
    }

    function renderAnalysis(summary) {
        if (!summary) {
            els.analysisPane.innerHTML = '<div class="empty-card"><p>No Rule 19 results loaded.</p></div>';
            return;
        }

        const breakdownRows = (summary.breakdown || [])
            .map(item => `<tr><td>${htmlEscape(item.value)}</td><td>${formatNumber(item.count)}</td></tr>`)
            .join('');
        const procedureSteps = (summary.procedureSteps || [])
            .map(step => `<div class="rule19-chip">${htmlEscape(step)}</div>`)
            .join('');
        const previewNote = summary.isPreviewOnly
            ? `<div class="alert alert--warning" style="margin-top:16px">Browser preview limited to ${formatNumber(summary.previewLimit)} rows. Downloads keep the full Rule 19 population.</div>`
            : '';
        const passRate = summary.totalValidated > 0
            ? ((summary.passCount / summary.totalValidated) * 100).toFixed(2)
            : '0.00';

        els.analysisPane.innerHTML = `
            <div class="rule19-stat-grid" style="margin-bottom:24px">
                <div class="stat-card">
                    <div class="stat-card__label">STUD Records</div>
                    <div class="stat-card__value">${formatNumber(summary.studRecordCount)}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__label">QUAL Records</div>
                    <div class="stat-card__value">${formatNumber(summary.qualRecordCount)}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__label">Eligible Population</div>
                    <div class="stat-card__value">${formatNumber(summary.totalValidated)}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__label">PASS Rate</div>
                    <div class="stat-card__value">${passRate}%</div>
                </div>
            </div>
            <div class="card" style="padding:20px">
                <h3 class="section-title" style="margin-top:0">Run Summary</h3>
                <div class="rule19-summary-grid">
                    <div><div class="rule19-muted">Database</div><div>${htmlEscape(summary.database)}</div></div>
                    <div><div class="rule19-muted">Linkage</div><div>${htmlEscape(summary.tableLinkageText)}</div></div>
                    <div><div class="rule19-muted">Fulfilled Rule</div><div>${htmlEscape(summary.fulfilledColumn)} = '${htmlEscape(summary.fulfilledValue)}'</div></div>
                    <div><div class="rule19-muted">Qualification Type Rule</div><div>${htmlEscape(summary.qualTypeColumn)} IN (${htmlEscape(summary.mdTypesText)})</div></div>
                    <div><div class="rule19-muted">Rows In Browser</div><div>${formatNumber(summary.displayedCount)}</div></div>
                    <div><div class="rule19-muted">Status</div><div>${htmlEscape(summary.status)}</div></div>
                </div>
                ${previewNote}
            </div>
            <div class="card" style="padding:20px;margin-top:20px">
                <h3 class="section-title" style="margin-top:0">Procedure</h3>
                <div style="display:flex;gap:10px;flex-wrap:wrap">${procedureSteps || '<span class="rule19-muted">No procedure steps available.</span>'}</div>
            </div>
            <div class="card" style="padding:20px;margin-top:20px">
                <h3 class="section-title" style="margin-top:0">Qualification Type Breakdown</h3>
                ${breakdownRows
                    ? `<table class="data-table"><thead><tr><th>${htmlEscape(summary.qualTypeColumn)}</th><th>Count</th></tr></thead><tbody>${breakdownRows}</tbody></table>`
                    : '<div class="rule19-muted">No linked population was returned for the current settings.</div>'}
            </div>`;
    }

    function renderResults(summary) {
        if (!summary || !(summary.matchingRows || []).length) {
            els.resultsPane.innerHTML = '<div class="empty-card"><p>No Rule 19 rows loaded.</p></div>';
            return;
        }

        const allRows = summary.matchingRows || [];
        const filteredRows = allRows.filter(row => {
            if (state.resultFilter === 'ALL') {
                return true;
            }

            const displayValues = row.displayValues || {};
            const validationEntry = Object.entries(displayValues)
                .find(([key]) => /validation_?result/i.test(key));
            const rowResult = String(
                validationEntry?.[1]
                ?? row.validationResult
                ?? row.ValidationResult
                ?? ''
            ).toUpperCase();
            return rowResult === state.resultFilter;
        });
        const headers = Array.from(new Set(allRows.flatMap(row => Object.keys(row.displayValues || {}))));
        const headHtml = headers.map(header => `<th>${htmlEscape(header)}</th>`).join('');
        const bodyHtml = filteredRows.map(row => {
            const cells = headers.map(header => {
                const value = row.displayValues?.[header] ?? '';
                const normalizedValue = String(value || '').toUpperCase();
                const cls = /validation_?result/i.test(header)
                    ? (normalizedValue === 'PASS' ? 'is-pass' : normalizedValue === 'FAIL' ? 'is-fail' : '')
                    : '';
                return `<td class="${cls}">${htmlEscape(value)}</td>`;
            }).join('');
            return `<tr>${cells}</tr>`;
        }).join('');

        const noteHtml = summary.isPreviewOnly
            ? `<div class="alert alert--info" style="margin-bottom:16px">Showing the first ${formatNumber(summary.displayedCount)} row(s) in the browser preview. Downloads keep the full Rule 19 result set.</div>`
            : '';
        const filterNoteHtml = `<div class="alert alert--info" style="margin-bottom:16px">Showing ${formatNumber(filteredRows.length)} of ${formatNumber(allRows.length)} loaded preview row(s) for <strong>${htmlEscape(state.resultFilter)}</strong>.</div>`;

        els.resultsPane.innerHTML = `
            <div class="card" style="padding:20px;margin-bottom:20px">
                <div class="action-bar" style="justify-content:flex-start;margin:0">
                    <label for="rule19ResultFilter" style="font-weight:600">Result Filter</label>
                    <select id="rule19ResultFilter" style="max-width:220px">
                        <option value="ALL" ${state.resultFilter === 'ALL' ? 'selected' : ''}>All Results</option>
                        <option value="PASS" ${state.resultFilter === 'PASS' ? 'selected' : ''}>PASS</option>
                        <option value="FAIL" ${state.resultFilter === 'FAIL' ? 'selected' : ''}>FAIL</option>
                    </select>
                </div>
            </div>
            ${noteHtml}
            ${filterNoteHtml}
            ${bodyHtml
                ? `<div class="rule19-preview-wrap">
                    <table class="data-table rule19-preview-table">
                        <thead><tr>${headHtml}</tr></thead>
                        <tbody>${bodyHtml}</tbody>
                    </table>
                </div>`
                : '<div class="empty-card"><p>No Rule 19 rows match the selected result filter.</p></div>'}`;

        document.getElementById('rule19ResultFilter')?.addEventListener('change', event => {
            state.resultFilter = String(event.target.value || 'ALL').toUpperCase();
            renderResults(summary);
        });
    }

    function applySummary(summary) {
        state.summary = summary;
        if (summary) {
            state.currentRunId = summary.savedRunId || state.currentRunId;
            state.currentStatus = summary.status || state.currentStatus;
            state.resultsVisible = true;
        }

        const statusText = summary?.status || '';
        const badgeType = /complete|pass/i.test(statusText)
            ? 'pass'
            : /fail|error/i.test(statusText)
                ? 'fail'
                : 'neutral';
        setStatusBadge(statusText, badgeType);
        els.downloadAllBtn.disabled = !summary;
        renderAnalysis(summary);
        renderResults(summary);
        updateWorkspaceButtons();
    }

    function updateWorkspaceCard(workspace) {
        state.currentRunId = workspace?.runId || null;
        state.currentUserEngagementRole = workspace?.currentUserEngagementRole || '';
        state.currentStatus = workspace?.currentStatus || '';
        state.currentUserHasSignedOff = !!workspace?.currentUserHasSignedOff;
        state.hasDataAnalystSignoff = !!workspace?.hasDataAnalystSignoff;
        state.isDirty = false;

        els.workspaceSignoffComment.value = workspace?.currentUserSignoffComment || '';
        els.workspaceRunLabel.textContent = workspace?.runId ? `Run #${workspace.runId}` : 'No saved run yet';
        els.workspaceStatusLabel.textContent = workspace?.currentStatus || '-';
        els.workspaceEditedLabel.textContent = workspace?.lastEditedAt ? new Date(workspace.lastEditedAt).toLocaleString() : '-';
        els.workspaceRoleLabel.textContent = workspace?.currentUserEngagementRole || currentSystemRole || '-';
        els.workspaceRunState.textContent = workspace?.runId ? `Run #${workspace.runId}` : 'No saved run loaded';
        els.workspaceRunState.className = `badge ${workspace?.runId ? 'badge--pass' : 'badge--neutral'} badge--sm`;

        updateWorkspaceButtons();
    }

    function hydrateWorkspace(workspace, resultsVisible) {
        state.isHydrating = true;
        state.currentRunId = workspace.runId || null;
        state.summary = workspace.summary || null;
        state.currentUserEngagementRole = workspace.currentUserEngagementRole || '';
        state.currentStatus = workspace.currentStatus || '';
        state.currentUserHasSignedOff = !!workspace.currentUserHasSignedOff;
        state.hasDataAnalystSignoff = !!workspace.hasDataAnalystSignoff;
        state.resultsVisible = !!resultsVisible;
        state.isDirty = false;

        els.server.value = workspace.server || '';
        els.driver.value = workspace.driver || 'ODBC Driver 17 for SQL Server';
        ensureOption(els.database, workspace.database || '');
        ensureOption(els.studTable, workspace.studTable || 'dbo_STUD');
        ensureOption(els.qualTable, workspace.qualTable || 'dbo_QUAL');
        ensureOption(els.qualCodeColumn, workspace.qualCodeColumn || '_001');
        ensureOption(els.fulfilledColumn, workspace.fulfilledColumn || '_025');
        ensureOption(els.fulfilledValue, workspace.fulfilledValue || 'F', workspace.fulfilledValue || 'F');
        ensureOption(els.qualTypeColumn, workspace.qualTypeColumn || '_005');
        els.mdTypesText.value = workspace.mdTypesText || defaultMdTypes;
        els.workspaceSignoffComment.value = workspace.currentUserSignoffComment || '';

        updateWorkspaceCard(workspace);

        if (workspace.summary && resultsVisible) {
            applySummary(workspace.summary);
            setWorkspaceInfo('success', 'Saved Rule 19 workspace loaded.');
        } else if (workspace.summary && !resultsVisible) {
            applySummary(null);
            setWorkspaceInfo('warning', 'A saved Rule 19 workspace exists, but its results are not available for your role yet.');
        } else {
            applySummary(null);
            setWorkspaceInfo('info', 'Rule 19 workspace loaded. Run validation to generate results.');
        }

        state.isHydrating = false;
    }

    async function fetchWorkspace() {
        if (!state.clientId) {
            applySummary(null);
            updateWorkspaceCard(null);
            setWorkspaceInfo('info', 'Select an engagement to load the saved Rule 19 workspace.');
            return;
        }

        const requestVersion = ++state.workspaceRequestVersion;
        const mutationVersionAtStart = state.uiMutationVersion;
        const data = await window.fetchJsonWithProgress(`${apiBasePath}/GetWorkspaceState?clientId=${state.clientId}`, { method: 'GET' });
        if (requestVersion !== state.workspaceRequestVersion || mutationVersionAtStart !== state.uiMutationVersion) {
            return;
        }

        if (!data.success || !data.hasWorkspace || !data.workspace) {
            applySummary(null);
            updateWorkspaceCard(null);
            setWorkspaceInfo('info', 'No saved Rule 19 workspace exists for this engagement yet.');
            return;
        }

        hydrateWorkspace(data.workspace, data.resultsVisible);
    }

    async function connectDatabase() {
        const server = els.server.value.trim();
        if (!server) {
            setAlert(els.connectionOutput, 'warning', 'Enter the SQL Server name first.');
            return;
        }

        showSpinner('Loading databases...');
        try {
            const data = await postJson(`${apiBasePath}/GetDatabases`, {
                server,
                driver: els.driver.value
            });
            if (!data.success) {
                throw new Error(data.error || 'Failed to load databases.');
            }

            populateSelect(els.database, data.databases || []);
            setAlert(els.connectionOutput, 'success', `Loaded ${(data.databases || []).length} database(s).`);
            if ((data.databases || []).length) {
                await loadTables();
            }
        } finally {
            hideSpinner();
        }
    }

    async function loadTables() {
        if (!els.database.value) return;

        const data = await postJson(`${apiBasePath}/GetTables`, {
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value
        });
        if (!data.success) {
            throw new Error(data.error || 'Failed to load tables.');
        }

        populateSelect(els.studTable, data.tables || [], data.autoStudTable || 'dbo_STUD');
        populateSelect(els.qualTable, data.tables || [], data.autoQualTable || 'dbo_QUAL');
        await loadStudColumns();
        await loadQualColumns();
        setAlert(els.configOutput, 'success', `Loaded ${(data.tables || []).length} table(s).`);
    }

    async function loadStudColumns() {
        if (!els.studTable.value) return;

        const data = await postJson(`${apiBasePath}/GetColumns`, {
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value,
            tableName: els.studTable.value
        });
        if (!data.success) {
            throw new Error(data.error || 'Failed to load STUD columns.');
        }

        populateSelect(els.qualCodeColumn, data.columns || [], data.autoQualCodeColumn || '_001');
        populateSelect(els.fulfilledColumn, data.columns || [], data.autoFulfilledColumn || '_025');
        await loadFilterValues(false);
    }

    async function loadQualColumns() {
        if (!els.qualTable.value) return;

        const data = await postJson(`${apiBasePath}/GetColumns`, {
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value,
            tableName: els.qualTable.value
        });
        if (!data.success) {
            throw new Error(data.error || 'Failed to load QUAL columns.');
        }

        populateSelect(els.qualTypeColumn, data.columns || [], data.autoQualTypeColumn || '_005');
    }

    async function loadFilterValues(showUserFeedback = true) {
        if (!els.studTable.value || !els.fulfilledColumn.value) return;

        if (showUserFeedback) {
            showSpinner('Loading filter values...');
        }

        try {
            const data = await postJson(`${apiBasePath}/LoadFilterValues`, {
                server: els.server.value.trim(),
                database: els.database.value,
                driver: els.driver.value,
                studTable: els.studTable.value,
                fulfilledColumn: els.fulfilledColumn.value
            });
            if (!data.success) {
                throw new Error(data.error || 'Failed to load filter values.');
            }

            const options = (data.options || []).map(option => [option.label, option.value]);
            populateSelect(els.fulfilledValue, options, data.defaultValue);
            setAlert(els.filterOutput, 'success', `Loaded ${(data.options || []).length} fulfilled value option(s) from ${htmlEscape(els.fulfilledColumn.value)}.`);
        } finally {
            if (showUserFeedback) {
                hideSpinner();
            }
        }
    }

    async function verifyTables() {
        showSpinner('Verifying Rule 19 tables...');
        try {
            const data = await postJson(`${apiBasePath}/VerifyTables`, getRequest());
            if (!data.success) {
                throw new Error(data.error || 'Verification failed.');
            }

            setAlert(
                els.connectionOutput,
                'success',
                `STUD records: <strong>${formatNumber(data.studRecordCount)}</strong> | QUAL records: <strong>${formatNumber(data.qualRecordCount)}</strong> | Eligible population: <strong>${formatNumber(data.eligiblePopulationCount)}</strong>`
            );
        } finally {
            hideSpinner();
        }
    }

    async function runValidation() {
        const request = getRequest();
        if (!request.clientId) {
            setWorkspaceInfo('warning', 'Select the approved engagement assigned to you before running this rule.');
            return;
        }

        showSpinner('Running Rule 19...');
        try {
            state.uiMutationVersion++;
            const data = await postJson(`${apiBasePath}/RunValidation`, request);
            if (!data.success) {
                throw new Error(data.error || 'Rule 19 failed.');
            }

            state.currentUserHasSignedOff = false;
            state.hasDataAnalystSignoff = false;
            state.resultsVisible = true;
            state.currentUserEngagementRole = state.currentUserEngagementRole || currentSystemRole || 'DataAnalyst';
            applySummary(data);
            setWorkspaceInfo('success', `Rule 19 completed. Eligible population: ${formatNumber(data.totalValidated)}. PASS: ${formatNumber(data.passCount)} | FAIL: ${formatNumber(data.failCount)}.`);
        } finally {
            hideSpinner();
        }
    }

    async function generateSql() {
        showSpinner('Generating SQL...');
        try {
            const data = await postJson(`${apiBasePath}/GenerateSql`, getRequest());
            if (!data.success) {
                throw new Error(data.error || 'SQL generation failed.');
            }

            els.sqlText.value = data.sql || '';
            document.querySelector('.tab-btn[data-tab="sql"]')?.click();
        } finally {
            hideSpinner();
        }
    }

    async function beginEdit() {
        showSpinner('Preparing workspace edit...');
        try {
            state.uiMutationVersion++;
            const data = await postJson(`${apiBasePath}/BeginWorkspaceEdit`, getRequest());
            if (!data.success) {
                throw new Error(data.error || 'Could not begin editing.');
            }

            if (data.workspace) {
                updateWorkspaceCard(data.workspace);
            }
            setWorkspaceInfo('warning', data.message || 'Editing has begun.');
        } finally {
            hideSpinner();
        }
    }

    async function saveWorkspace() {
        showSpinner('Saving workspace...');
        try {
            state.uiMutationVersion++;
            const data = await postJson(`${apiBasePath}/SaveWorkspace`, getRequest());
            if (!data.success) {
                throw new Error(data.error || 'Could not save the workspace.');
            }

            if (data.workspace) {
                updateWorkspaceCard(data.workspace);
            }
            setWorkspaceInfo(data.signoffsCleared ? 'warning' : 'success', data.message || 'Workspace saved.');
        } finally {
            hideSpinner();
        }
    }

    async function signoffWorkspace() {
        showSpinner('Saving signoff...');
        try {
            state.uiMutationVersion++;
            const data = await postJson(`${apiBasePath}/SignOffWorkspace`, {
                clientId: parseInt(els.clientId.value || '0', 10) || 0,
                runId: state.currentRunId,
                comment: els.workspaceSignoffComment.value || ''
            });
            if (!data.success) {
                throw new Error(data.error || 'Signoff failed.');
            }

            state.currentUserHasSignedOff = true;
            if (data.workspace) {
                updateWorkspaceCard(data.workspace);
            }
            updateWorkspaceButtons();
            setWorkspaceInfo('success', data.message || 'Signoff saved.');
        } finally {
            hideSpinner();
        }
    }

    async function removeWorkspaceSignoff() {
        showSpinner('Removing signoff...');
        try {
            state.uiMutationVersion++;
            const data = await postJson(`${apiBasePath}/RemoveWorkspaceSignoff`, {
                clientId: parseInt(els.clientId.value || '0', 10) || 0,
                runId: state.currentRunId,
                comment: ''
            });
            if (!data.success) {
                throw new Error(data.error || 'Could not remove signoff.');
            }

            state.currentUserHasSignedOff = false;
            if (data.workspace) {
                updateWorkspaceCard(data.workspace);
            }
            updateWorkspaceButtons();
            setWorkspaceInfo('warning', data.message || 'Signoff removed.');
        } finally {
            hideSpinner();
        }
    }

    document.querySelectorAll('.tab-btn').forEach(button => {
        button.addEventListener('click', () => {
            const tab = button.getAttribute('data-tab');
            document.querySelectorAll('.tab-btn').forEach(item => item.classList.remove('active'));
            document.querySelectorAll('[data-tab-panel]').forEach(panel => panel.classList.remove('active'));
            button.classList.add('active');
            document.querySelector(`[data-tab-panel="${tab}"]`)?.classList.add('active');
        });
    });

    els.clientId.addEventListener('change', async () => {
        state.clientId = parseInt(els.clientId.value || '0', 10) || 0;
        state.uiMutationVersion++;
        await fetchWorkspace();
    });
    els.database.addEventListener('change', async () => {
        await markWorkspaceDirty();
        await loadTables();
    });
    els.studTable.addEventListener('change', async () => {
        await markWorkspaceDirty();
        await loadStudColumns();
    });
    els.qualTable.addEventListener('change', async () => {
        await markWorkspaceDirty();
        await loadQualColumns();
    });
    els.qualCodeColumn.addEventListener('change', markWorkspaceDirty);
    els.fulfilledColumn.addEventListener('change', async () => {
        await markWorkspaceDirty();
        await loadFilterValues(false);
    });
    els.fulfilledValue.addEventListener('change', markWorkspaceDirty);
    els.qualTypeColumn.addEventListener('change', markWorkspaceDirty);
    els.mdTypesText.addEventListener('change', markWorkspaceDirty);
    document.getElementById('connectBtn').addEventListener('click', () => connectDatabase().catch(err => {
        hideSpinner();
        setAlert(els.connectionOutput, 'error', htmlEscape(err.message));
    }));
    document.getElementById('verifyBtn').addEventListener('click', () => verifyTables().catch(err => {
        hideSpinner();
        setAlert(els.connectionOutput, 'error', htmlEscape(err.message));
    }));
    document.getElementById('verifyBtnBar').addEventListener('click', () => verifyTables().catch(err => {
        hideSpinner();
        setAlert(els.connectionOutput, 'error', htmlEscape(err.message));
    }));
    document.getElementById('loadValuesBtn').addEventListener('click', () => loadFilterValues(true).catch(err => {
        hideSpinner();
        setAlert(els.filterOutput, 'error', htmlEscape(err.message));
    }));
    document.getElementById('runBtn').addEventListener('click', () => runValidation().catch(err => {
        hideSpinner();
        setWorkspaceInfo('error', err.message || 'Rule 19 failed.');
    }));
    document.getElementById('sqlBtn').addEventListener('click', () => generateSql().catch(err => {
        hideSpinner();
        els.sqlText.value = err.message || 'SQL generation failed.';
    }));
    document.getElementById('beginEditBtn').addEventListener('click', () => beginEdit().catch(err => {
        hideSpinner();
        setWorkspaceInfo('error', err.message || 'Could not begin editing.');
    }));
    document.getElementById('saveWorkspaceBtn').addEventListener('click', () => saveWorkspace().catch(err => {
        hideSpinner();
        setWorkspaceInfo('error', err.message || 'Could not save the workspace.');
    }));
    document.getElementById('signoffBtn').addEventListener('click', () => signoffWorkspace().catch(err => {
        hideSpinner();
        setWorkspaceInfo('error', err.message || 'Signoff failed.');
    }));
    document.getElementById('removeSignoffBtn').addEventListener('click', () => removeWorkspaceSignoff().catch(err => {
        hideSpinner();
        setWorkspaceInfo('error', err.message || 'Could not remove signoff.');
    }));
    document.getElementById('downloadExcelBtn').addEventListener('click', () => state.summary && downloadBlob(`${apiBasePath}/DownloadExcel`, state.summary, 'Rule19_Masters_PhD_Population.xlsx').catch(err => setWorkspaceInfo('error', err.message || 'Download failed.')));
    document.getElementById('downloadCsvBtn').addEventListener('click', () => state.summary && downloadBlob(`${apiBasePath}/DownloadCsv`, state.summary, 'Rule19_Masters_PhD_Population.csv').catch(err => setWorkspaceInfo('error', err.message || 'Download failed.')));
    document.getElementById('downloadSqlBtn').addEventListener('click', () => downloadBlob(`${apiBasePath}/DownloadSql`, getRequest(), 'Rule19_Masters_PhD_Population.sql').catch(err => setWorkspaceInfo('error', err.message || 'Download failed.')));
    document.getElementById('downloadAllBtn').addEventListener('click', async () => {
        try {
            if (!state.summary) {
                throw new Error('Run Rule 19 first.');
            }
            if (els.chkExcel.checked) {
                await downloadBlob(`${apiBasePath}/DownloadExcel`, state.summary, 'Rule19_Masters_PhD_Population.xlsx');
            }
            if (els.chkCsv.checked) {
                await downloadBlob(`${apiBasePath}/DownloadCsv`, state.summary, 'Rule19_Masters_PhD_Population.csv');
            }
            if (els.chkSql.checked) {
                await downloadBlob(`${apiBasePath}/DownloadSql`, getRequest(), 'Rule19_Masters_PhD_Population.sql');
            }
        } catch (err) {
            setWorkspaceInfo('error', err.message || 'Download failed.');
        }
    });

    applySummary(null);
    updateWorkspaceButtons();
    if (state.clientId) {
        fetchWorkspace().catch(err => setWorkspaceInfo('error', err.message || 'Failed to load workspace.'));
    }
})();
</script>
