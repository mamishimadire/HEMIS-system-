@using System.Text.Json
@model HemisAudit.ViewModels.Rule13RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 13 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload = ViewBag.CanDownloadSavedRun is bool allowed && allowed;
    var canManageEngagement = ViewBag.CanManageEngagement is bool manageEngagement && manageEngagement;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool openWorkspace && openWorkspace;
    var isArchived = ViewBag.IsArchived is bool archived && archived;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    const int maxBrowserReviewRows = 10;
    var browserReviewRows = Model.Summary.ReviewRows.Take(maxBrowserReviewRows).ToList();
    var browserRowsTrimmed = Model.Summary.ReviewRows.Count > browserReviewRows.Count;
    var reviewRowsJson = JsonSerializer.Serialize(browserReviewRows.Select(row => new
    {
        validationNumber = row.ValidationNumber,
        partCode = row.PartCode,
        partTitle = row.PartTitle,
        partDescription = row.PartDescription,
        studentNumber007 = row.StudentNumber007,
        qualificationCode001 = row.QualificationCode001,
        foundationFlag106 = row.FoundationFlag106,
        qualificationDescription003 = row.QualificationDescription003,
        qualificationType005 = row.QualificationType005,
        bridgeQualificationCode001 = row.BridgeQualificationCode001,
        courseCode030 = row.CourseCode030,
        crseCourseCode030 = row.CrseCourseCode030,
        foundationCourse091 = row.FoundationCourse091,
        studentType = row.StudentType,
        notebookStatus = row.NotebookStatus,
        validationResult = row.ValidationResult,
        validationExplanation = row.ValidationExplanation
    }));
    var partSummariesJson = JsonSerializer.Serialize(Model.Summary.PartSummaries.Select(part => new
    {
        partCode = part.PartCode,
        partDescription = part.PartDescription,
        totalCount = part.TotalCount,
        passCount = part.PassCount,
        failCount = part.FailCount,
        status = part.Status
    }));
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<div class="page-header">
    <div>
        <h1>Rule 13 Saved Run</h1>
        <p>
            @Model.EngagementName
            <span style="padding:0 8px">|</span>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            Run #@Model.RunId
            <span style="padding:0 8px">|</span>
            @Model.Summary.Timestamp
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Back to Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The saved run is available for review and download only.
    </div>
}

@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">
        The data analyst signoff is still outstanding. Assigned users can still review and download this run.
    </div>
}

<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">
                @(Model.CurrentUserHasSignedOff ? $"Signed Off as {Model.CurrentUserEngagementRole}" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>

        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">Remove Signoff</button>
            </form>
        }
    }
    else if (!Model.IsCurrentRun && !isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">History results are read-only for signoff. Signoff is only available on the current run.</div>
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Reviewer</th>
                    <th>Comment</th>
                    <th>Signed At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td><strong>@signoff.ReviewerName</strong><br /><small style="color:#757575">@signoff.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:24px;margin-bottom:24px">
    <div class="stats-grid" style="margin-bottom:24px">
        <div class="stat-card">
            <div class="stat-card__label">Qualifying CESM Population</div>
            <div class="stat-card__value">@Model.Summary.FoundationStudentCount.ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__label">Validated Rows</div>
            <div class="stat-card__value">@Model.Summary.TotalValidated.ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__label">PASS Rows</div>
            <div class="stat-card__value">@Model.Summary.PassCount.ToString("N0")</div>
        </div>
        <div class="stat-card stat-card--fail">
            <div class="stat-card__label">FAIL Rows</div>
            <div class="stat-card__value">@Model.Summary.FailCount.ToString("N0")</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Summary.Warning))
    {
        <div class="alert alert--info" style="margin-bottom:16px">@Model.Summary.Warning</div>
    }

    <div class="form-grid" style="margin-bottom:20px">
        <div>
            <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div>
            <div>@Model.Summary.Database</div>
        </div>
        <div>
            <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Tables</div>
            <div>CESM: @Model.Summary.StudTable | QUAL: @Model.Summary.QualTable | STUD: @Model.Summary.CregTable</div>
        </div>
        <div>
            <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
            <div><span class="badge @(Model.Summary.Status == "PASS" ? "badge--pass" : "badge--fail")">@Model.Summary.Status</span></div>
        </div>
        <div>
            <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule Scope</div>
            <div>@Model.Summary.GoverningPartCodesText</div>
        </div>
        <div style="grid-column:1 / -1">
            <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Linkage Used</div>
            <div>@Model.Summary.TableLinkageText</div>
        </div>
        <div style="grid-column:1 / -1">
            <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Overall PASS Rule</div>
            <div>@Model.Summary.OverallStatusRuleText</div>
        </div>
        @if (Model.Summary.ProcedureSteps.Count > 0)
        {
            <div style="grid-column:1 / -1">
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700;margin-bottom:8px">Procedure Performed</div>
                <ol style="margin:0;padding-left:20px">
                    @foreach (var step in Model.Summary.ProcedureSteps)
                    {
                        <li>@step</li>
                    }
                </ol>
            </div>
        }
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Scope</th>
                <th>Title</th>
                <th>Rows</th>
                <th>PASS</th>
                <th>FAIL</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var part in Model.Summary.PartSummaries)
            {
                <tr>
                    <td><strong>@part.PartCode</strong></td>
                    <td>@part.PartTitle</td>
                    <td>@part.TotalCount.ToString("N0")</td>
                    <td>@part.PassCount.ToString("N0")</td>
                    <td>@part.FailCount.ToString("N0")</td>
                    <td><span class="badge @(part.Status == "PASS" ? "badge--pass" : "badge--fail")">@part.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card" style="padding:24px;margin-bottom:24px">
    <div class="action-bar" style="justify-content:flex-start;margin:0 0 16px 0">
        <label for="resultStatusFilter" style="font-weight:600">Result</label>
        <select id="resultStatusFilter" style="max-width:220px">
            <option value="ALL">All Results</option>
            <option value="PASS">PASS</option>
            <option value="FAIL">FAIL</option>
        </select>
    </div>
    <div class="alert alert--info" style="margin-bottom:16px">
        Filter the saved Rule 13 result rows by PASS or FAIL.
    </div>
    @if (browserRowsTrimmed)
    {
        <div class="alert alert--warning" style="margin-bottom:16px">
            The browser preview is limited to @maxBrowserReviewRows rows to keep this saved run responsive. Use Excel or CSV for the full result set.
        </div>
    }
    <div class="alert alert--info" style="margin-bottom:16px">
        Tables: CESM `@Model.Summary.StudTable`, QUAL `@Model.Summary.QualTable`, STUD `@Model.Summary.CregTable`.<br />
        Linkage: `@Model.Summary.TableLinkageText`.<br />
        Population: `CESM._006 <> 'ZZZZZZ'` across the full qualifying CESM population.<br />
        A row passes only when the CESM qualification links to at least one STUD record through QUAL._001 = STUD._001.
    </div>
    <div id="reviewRowsContainer"></div>
</div>

<div class="card" style="padding:24px;margin-bottom:24px">
    <h3 class="section-title" style="margin-top:0">SQL</h3>
    <textarea rows="16" readonly>@Model.GeneratedSql</textarea>
</div>

@if (canDownload)
{
    <div class="card" style="padding:24px">
        <h3 class="section-title" style="margin-top:0">Downloads</h3>
        <div class="action-bar" style="justify-content:flex-start;margin:0">
            <a asp-action="DownloadSavedExcel" asp-route-runId="@Model.RunId" class="btn btn-success">Excel</a>
            <a asp-action="DownloadSavedCsv" asp-route-runId="@Model.RunId" class="btn btn-info">CSV</a>
            <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-secondary">SQL</a>
        </div>
    </div>
}

<script>
(() => {
    const rows = @Html.Raw(reviewRowsJson);
    const partSummaries = @Html.Raw(partSummariesJson);
    const cesmTableName = '@Model.Summary.StudTable'.toUpperCase();
    const qualTableName = '@Model.Summary.QualTable'.toUpperCase();
    const studTableName = '@Model.Summary.CregTable'.toUpperCase();
    const statusFilter = document.getElementById('resultStatusFilter');
    const reviewRowsContainer = document.getElementById('reviewRowsContainer');

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatNumber(value) {
        return Number(value || 0).toLocaleString();
    }

    function renderRows() {
        if (!reviewRowsContainer) return;

        const selectedStatus = String(statusFilter?.value || 'ALL').toUpperCase();
        const filtered = rows.filter(row => {
            return selectedStatus === 'ALL' || String(row.validationResult || '').toUpperCase() === selectedStatus;
        });

        const sections = partSummaries
            .map(part => String(part.partCode || '').toUpperCase())
            .map(partCode => {
                const partRows = filtered.filter(row => String(row.partCode || '').toUpperCase() === partCode);
                if (!partRows.length) {
                    return '';
                }

                const partSummary = partSummaries.find(part => String(part.partCode || '').toUpperCase() === partCode);

                return `
                    <div class="card rule20-comparison-card" style="padding:20px;margin-bottom:16px">
                        <div class="rule20-comparison-card__header">
                            <div>
                                <div class="rule20-comparison-card__title">${escapeHtml(partSummary?.partTitle || partCode)}</div>
                                ${partSummary?.partDescription ? `<div class="rule20-comparison-card__subtitle">${escapeHtml(partSummary.partDescription)}</div>` : ''}
                            </div>
                            <div class="rule20-comparison-card__meta">
                                <span class="badge ${String(partSummary?.status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}">${escapeHtml(partSummary?.status || '')}</span>
                                <span>${formatNumber(partRows.length)} row(s)</span>
                            </div>
                        </div>
                        <div class="rule20-grid-wrap">
                            <table class="data-table rule20-comparison-table rule20-grid-table">
                                <thead>
                                    <tr>
                                        <th colspan="2"></th>
                                        <th class="rule20-spacer" rowspan="3"></th>
                                        <th colspan="2">LINK TABLE</th>
                                        <th class="rule20-spacer" rowspan="3"></th>
                                        <th colspan="2"></th>
                                        <th rowspan="3">Results</th>
                                    </tr>
                                    <tr>
                                        <th colspan="2">${escapeHtml(cesmTableName)}</th>
                                        <th colspan="2">${escapeHtml(qualTableName)}</th>
                                        <th colspan="2">${escapeHtml(studTableName)}</th>
                                    </tr>
                                    <tr>
                                        <th>_001</th>
                                        <th>_006</th>
                                        <th>_001</th>
                                        <th>_003</th>
                                        <th>_001</th>
                                        <th>Link Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${partRows.map(row => `
                                        <tr>
                                            <td class="rule20-align-center">${escapeHtml(row.qualificationCode001)}</td>
                                            <td class="rule20-align-center">${escapeHtml(row.courseCode030)}</td>
                                            <td class="rule20-spacer"></td>
                                            <td class="rule20-align-center">${escapeHtml(row.bridgeQualificationCode001)}</td>
                                            <td>${escapeHtml(row.qualificationDescription003)}</td>
                                            <td class="rule20-spacer"></td>
                                            <td class="rule20-align-center">${escapeHtml(row.foundationCourse091)}</td>
                                            <td class="rule20-align-center">${escapeHtml(row.notebookStatus)}</td>
                                            <td class="rule20-align-center">
                                                <div class="rule20-comparison-result">
                                                    <span class="badge ${String(row.validationResult).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}" title="${escapeHtml(row.validationExplanation || '')}">${escapeHtml(row.validationResult)}</span>
                                                </div>
                                            </td>
                                        </tr>`).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>`;
            })
            .filter(Boolean);

        reviewRowsContainer.innerHTML = sections.length
            ? sections.join('')
            : '<div class="empty-card" style="padding:20px"><p>No rows match the selected filters.</p></div>';
    }

    statusFilter?.addEventListener('change', renderRows);
    renderRows();
})();
</script>

