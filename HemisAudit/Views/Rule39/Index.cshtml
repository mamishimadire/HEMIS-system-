// ── SQL ────────────────────────────────────────────────────────────────────────
async function generateSql() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can generate SQL.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only.', 'error'); return; }
    if (!validateConfig()) return;
    showSpinner('Generating SQL...');
    try {
        const result = await post('/Rule39/GenerateSql', buildRequest());
        if (!result.success) return;
        const el = document.getElementById('sqlContent');
        el.classList.remove('empty-state');
        el.innerHTML = `
            ${renderSectionHeader('Rule 39 SQL Code', 'Generated SQL matches the notebook validation formula', `Database: ${escapeHtml(state.database || '')}`)}
            <div class="sql-toolbar">
                <button class="btn btn-sm btn-primary" onclick="copyToClipboard('sqlCode')">Copy</button>
                <button class="btn btn-sm btn-info" onclick="downloadSql()">Download SQL</button>
            </div>
            <div class="sql-panel"><pre id="sqlCode" class="sql-block">${escapeHtml(result.sql)}</pre></div>`;
        switchTab('sql');
    } finally { hideSpinner(); }
}

// ── Download ──────────────────────────────────────────────────────────────────
async function downloadExcel() {
    await downloadCurrentOrSaved('/Rule39/DownloadExcel', state.validationResult, 'DownloadSavedExcel', `Rule39_FirstTime_NAL_${fileStamp()}.xlsx`);
}
async function downloadCsv() {
    await downloadCurrentOrSaved('/Rule39/DownloadCsv', state.validationResult, 'DownloadSavedCsv', `Rule39_Results_${fileStamp()}.csv`);
}
async function downloadFlaggedCsv() {
    await downloadCurrentOrSaved('/Rule39/DownloadExceptionsCsv', state.validationResult, 'DownloadSavedExceptionsCsv', `Rule39_FLAGGED_${fileStamp()}.csv`);
}
async function downloadSql() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can download the SQL script.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only.', 'error'); return; }
    if (state.currentRunId && downloadSavedGet('DownloadSavedSql')) return;
    if (!validateConfig()) return;
    await downloadPost('/Rule39/DownloadSql', buildRequest(), `Rule39_${fileStamp()}.sql`);
}
async function downloadAll() {
    if (!state.validationResult && !state.currentRunId) { alert('Run validation first.'); return; }
    const tasks = [];
    if (document.getElementById('chkExcel')?.checked) tasks.push(() => downloadExcel());
    if (document.getElementById('chkCsv')?.checked) tasks.push(() => downloadCsv());
    if (document.getElementById('chkExceptionsCsv')?.checked) tasks.push(() => downloadFlaggedCsv());
    if (currentSystemRole === 'DataAnalyst' && document.getElementById('chkSql')?.checked) tasks.push(() => downloadSql());
    if (!tasks.length) { alert('Select at least one download format.'); return; }
    for (const task of tasks) await task();
}

// ── Workspace Save / Signoff ──────────────────────────────────────────────────
async function saveWorkspace() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can save this workspace.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only.', 'error'); return; }
    if (!state.currentRunId) { setWorkspaceInfo('Run validation first so the workspace can be saved.', 'error'); return; }
    showSpinner('Saving workspace...');
    try {
        const result = await post('/Rule39/SaveWorkspace', buildRequest());
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save workspace.')}`, 'error'); return; }
        state.editWarningAccepted = true;
        state.isDirty = false;
        if (result.workspace) {
            state.currentRunId = result.workspace.runId || state.currentRunId;
            state.currentUserEngagementRole = result.workspace.currentUserEngagementRole || state.currentUserEngagementRole;
            state.currentUserHasSignedOff = !!result.workspace.currentUserHasSignedOff;
            state.hasDataAnalystSignoff = !!result.workspace.hasDataAnalystSignoff;
            state.isWorkspaceSaved = !!result.workspace.isWorkspaceSaved;
            document.getElementById('signoffComment').value = result.workspace.currentUserSignoffComment || document.getElementById('signoffComment').value;
            if (result.workspace.summary) applyValidationResult(result.workspace.summary, { switchToValidation: false, fromWorkspace: true });
        }
        setWorkspaceInfo(result.message || 'Workspace saved.', result.signoffsCleared ? 'warning' : 'success');
        renderWorkspaceState();
    } finally { hideSpinner(); }
}

async function signOffWorkspace() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const canSign = !isArchivedWorkspace() && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    if (!canSign) { setWorkspaceInfo('This workspace can only be signed off by the assigned analyst, manager, or director after the analyst review is available.', 'error'); return; }
    if (!state.isWorkspaceSaved) { setWorkspaceInfo('Save the workspace first before signing off.', 'warning'); return; }
    if (state.isDirty) { setWorkspaceInfo('Save the workspace first. Editing removes signoffs and requires a fresh review.', 'warning'); return; }
    showSpinner('Saving signoff...');
    try {
        const result = await post('/Rule39/SignOffWorkspace', { clientId: state.clientId, runId: state.currentRunId, comment: document.getElementById('signoffComment').value.trim() });
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save signoff.')}`, 'error'); return; }
        const wResultsVisible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible') ? !!result.resultsVisible : !!result.workspace?.resultsVisible;
        if (result.workspace) { result.workspace.resultsVisible = wResultsVisible; await hydrateWorkspace(result.workspace); }
        state.isDirty = false;
        setWorkspaceInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
        renderWorkspaceState();
        switchTab('dl');
    } finally { hideSpinner(); }
}

async function removeWorkspaceSignoff() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const canSign = !isArchivedWorkspace() && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    if (!canSign || !state.currentUserHasSignedOff) { setWorkspaceInfo('There is no signoff for your assigned engagement role to remove.', 'error'); return; }
    showSpinner('Removing signoff...');
    try {
        const result = await post('/Rule39/RemoveWorkspaceSignoff', { clientId: state.clientId, runId: state.currentRunId, comment: '' });
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to remove signoff.')}`, 'error'); return; }
        const wResultsVisible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible') ? !!result.resultsVisible : !!result.workspace?.resultsVisible;
        if (result.workspace) { result.workspace.resultsVisible = wResultsVisible; await hydrateWorkspace(result.workspace); }
        setWorkspaceInfo('Signoff removed.', 'warning');
        renderWorkspaceState();
    } finally { hideSpinner(); }
}

// ── Workspace UI State ─────────────────────────────────────────────────────────
function renderWorkspaceState() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const archived = isArchivedWorkspace();
    const canEditWorkspace = currentSystemRole === 'DataAnalyst' && !archived;
    const canSignWorkspace = !archived && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    const canActivateSignoff = !!canSignWorkspace && !!state.isWorkspaceSaved;
    const canRemoveWorkspaceSignoff = !archived && canSignWorkspace && state.currentUserHasSignedOff;
    const showDisabledArchivedSignoff = archived && !!state.currentRunId;
    const runValidationBtn = document.getElementById('runValidationBtn');
    const generateSqlBtn = document.getElementById('generateSqlBtn');
    const saveWorkspaceBtn = document.getElementById('saveWorkspaceBtn');
    const signOffBtn = document.getElementById('signOffBtn');
    const removeWorkspaceSignoffBtn = document.getElementById('removeWorkspaceSignoffBtn');
    const signoffComment = document.getElementById('signoffComment');
    const signoffLabel = document.getElementById('workspaceSignoffLabel');
    const signedOffLock = !!state.currentUserHasSignedOff;
    const signoffButtonText = state.currentUserHasSignedOff ? `Signed Off as ${role || 'Reviewer'}` : `Sign Off as ${role || 'Reviewer'}`;

    window.ruleWorkspaceUi.setReadonlyShell('app', !canEditWorkspace || signedOffLock);
    window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEditWorkspace || signedOffLock);
    window.ruleWorkspaceUi.applyStates([
        { target: runValidationBtn, show: canEditWorkspace, disabled: !canEditWorkspace || signedOffLock },
        { target: generateSqlBtn, show: canEditWorkspace, disabled: !canEditWorkspace || signedOffLock },
        { target: saveWorkspaceBtn, show: canEditWorkspace, disabled: !canEditWorkspace || !state.currentRunId || signedOffLock },
        { target: signoffComment, disabled: archived || !canActivateSignoff || signedOffLock }
    ]);
    window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions', '.action-bar'], signedOffLock, { allow: ['#downloadAllBtn', '#removeWorkspaceSignoffBtn'] });

    if (showDisabledArchivedSignoff) {
        window.ruleWorkspaceUi.applyStates([
            { target: signOffBtn, show: true, disabled: true, text: signoffButtonText, title: 'Archived engagements are read-only.' },
            { target: removeWorkspaceSignoffBtn, show: !!state.currentUserHasSignedOff, disabled: true, title: 'Archived engagements are read-only.' }
        ]);
    } else {
        window.ruleWorkspaceUi.applyStates([
            { target: signOffBtn, show: canSignWorkspace, disabled: !canActivateSignoff || state.isDirty || signedOffLock, text: signoffButtonText, title: '' },
            { target: removeWorkspaceSignoffBtn, show: canRemoveWorkspaceSignoff, disabled: !canRemoveWorkspaceSignoff, title: '' }
        ]);
    }

    if (signoffLabel) signoffLabel.textContent = role === 'DataAnalyst' ? 'Analyst Signoff Comment' : 'Review Signoff Comment';
    applyWorkspaceAccessMode(canEditWorkspace);

    if (!state.clientId) { setWorkspaceRunState('No engagement selected', 'neutral'); setWorkspaceInfo('Select an engagement to load the last saved Rule 39 workspace.', 'info'); return; }
    if (!state.currentRunId) {
        setWorkspaceRunState('No saved run loaded', 'neutral');
        setWorkspaceInfo(canEditWorkspace ? 'No saved Rule 39 workspace exists yet. Connect, configure, run validation, then save and sign off.' : 'No saved Rule 39 workspace exists for this engagement yet.', 'info');
        return;
    }
    if (archived) { setWorkspaceRunState(`Run #${state.currentRunId} archived`, 'warning'); setWorkspaceInfo('This engagement is archived. Configuration, validation, saving, and signoff are disabled.', 'warning'); return; }
    if (state.isDirty) {
        setWorkspaceRunState(`Run #${state.currentRunId} loaded`, 'warning');
        setWorkspaceInfo(canEditWorkspace ? `Saved run <strong>#${state.currentRunId}</strong> is loaded, but has unsaved changes.` : `Saved run <strong>#${state.currentRunId}</strong> is loaded, but your role cannot edit this workspace.`, 'warning');
        return;
    }
    if (state.currentUserHasSignedOff) { setWorkspaceRunState(`Run #${state.currentRunId} signed off`, 'success'); setWorkspaceInfo(`Saved run <strong>#${state.currentRunId}</strong> is loaded. Your analyst signoff is already on this run.`, 'success'); return; }
    if (state.hasDataAnalystSignoff) { setWorkspaceRunState(`Run #${state.currentRunId} analyst-signed`, 'success'); setWorkspaceInfo(`Saved run <strong>#${state.currentRunId}</strong> is loaded from SQL. Other assigned users can review this analyst-signed run.`, 'success'); return; }
    setWorkspaceRunState(`Run #${state.currentRunId} saved`, 'info');
    setWorkspaceInfo(canEditWorkspace ? `Saved run <strong>#${state.currentRunId}</strong> is loaded. Analyst signoff is still outstanding.` : `Saved run <strong>#${state.currentRunId}</strong> is loaded and awaiting analyst signoff.`, 'info');
}

function applyWorkspaceAccessMode(canEditWorkspace) {
    ['body-connection', 'body-tables', 'body-columns'].forEach(id => {
        const body = document.getElementById(id);
        if (!body) return;
        body.style.opacity = canEditWorkspace ? '' : '0.45';
        body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
        body.querySelectorAll('input, select, textarea, button').forEach(el => { el.disabled = !canEditWorkspace; });
    });
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function validateConfig() {
    const missing = [];
    if (!state.clientId) missing.push('engagement');
    if (!state.server) missing.push('server');
    if (!state.database) missing.push('database');
    if (!state.studTable) missing.push('STUD table');
    if (!state.qualTable) missing.push('QUAL table');
    if (!state.nalTable) missing.push('NAL table');
    if (!state.studQualRefCol) missing.push('STUD qual ref column');
    if (!state.studFirstTimeCol) missing.push('STUD first-time column');
    if (!state.studFirstTimeValue) missing.push('first-time value');
    if (!state.qualCodeCol) missing.push('QUAL code column');
    if (!state.qualNameCol) missing.push('QUAL name column');
    if (!state.nalRefCol) missing.push('NAL ref column');
    if (!state.nalNameCol) missing.push('NAL name column');
    if (!state.nalCategoryCol) missing.push('NAL category column');
    if (!state.nalCategoryValue) missing.push('NAL category value');
    if (missing.length) {
        if (!state.clientId) setWorkspaceInfo('Select the approved engagement assigned to you before running this rule.', 'warning');
        setStatus('validationContent', `Please select ${missing.join(', ')} first.`, 'warning');
        switchTab('validation');
        return false;
    }
    return true;
}

function buildRequest() {
    return {
        clientId: state.clientId,
        runId: state.currentRunId,
        server: state.server,
        database: state.database,
        driver: state.driver,
        studTable: state.studTable,
        qualTable: state.qualTable,
        nalTable: state.nalTable,
        studQualRefColumn: state.studQualRefCol,
        stud007Column: state.stud007Col,
        stud008Column: state.stud008Col,
        studFirstTimeColumn: state.studFirstTimeCol,
        stud012Column: state.stud012Col,
        stud026Column: state.stud026Col,
        studFirstTimeValue: state.studFirstTimeValue,
        qualCodeColumn: state.qualCodeCol,
        qualNameColumn: state.qualNameCol,
        nalRefColumn: state.nalRefCol,
        nalNameColumn: state.nalNameCol,
        nalAlignedColumn: state.nalAlignedCol,
        nalCategoryColumn: state.nalCategoryCol,
        nalCategoryValue: state.nalCategoryValue,
        nalHeqsfRefColumn: state.nalHeqsfRefCol,
        nalSaqaIdColumn: state.nalSaqaIdCol,
        nalNqfColumn: state.nalNqfCol,
        nalCreditsColumn: state.nalCreditsCol,
        nalOutcomeColumn: state.nalOutcomeCol
    };
}

function copyToClipboard(elId) {
    const text = document.getElementById(elId).textContent;
    navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard!'));
}

document.addEventListener('DOMContentLoaded', async () => {
    document.getElementById('serverInput').addEventListener('input', async () => {
        state.server = document.getElementById('serverInput').value.trim(); await markWorkspaceDirty();
    });
    document.getElementById('driverSelect').addEventListener('change', async () => {
        state.driver = document.getElementById('driverSelect').value; await markWorkspaceDirty();
    });
    document.getElementById('databaseSelect').addEventListener('change', async e => {
        state.database = e.target.value; await markWorkspaceDirty(); await loadTables();
    });
    document.getElementById('studTableSelect').addEventListener('change', async e => {
        state.studTable = e.target.value; await markWorkspaceDirty(); await loadColumns('stud');
    });
    document.getElementById('qualTableSelect').addEventListener('change', async e => {
        state.qualTable = e.target.value; await markWorkspaceDirty(); await loadColumns('qual');
    });
    document.getElementById('nalTableSelect').addEventListener('change', async e => {
        state.nalTable = e.target.value; await markWorkspaceDirty(); await loadColumns('nal');
    });
    ['stud007Col','stud008Col','stud012Col','stud026Col'].forEach(id => {
        document.getElementById(id).addEventListener('change', e => { state[id] = e.target.value; });
    });
    document.getElementById('qualCodeCol').addEventListener('change', e => { state.qualCodeCol = e.target.value; });
    document.getElementById('qualNameCol').addEventListener('change', e => { state.qualNameCol = e.target.value; });
    document.getElementById('nalNameCol').addEventListener('change', e => { state.nalNameCol = e.target.value; });
    document.getElementById('nalAlignedCol').addEventListener('change', e => { state.nalAlignedCol = e.target.value; });
    ['nalHeqsfRefCol','nalSaqaIdCol','nalNqfCol','nalCreditsCol','nalOutcomeCol'].forEach(id => {
        document.getElementById(id).addEventListener('change', e => { state[id] = e.target.value; });
    });

    renderWorkspaceState();
    if (state.clientId > 0) await loadWorkspaceState();
});
</script>
