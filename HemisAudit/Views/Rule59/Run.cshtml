@model HemisAudit.ViewModels.Rule59RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 59 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload      = ViewBag.CanDownloadSavedRun is bool d && d;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool o && o;
    var isArchived       = ViewBag.IsArchived is bool a && a;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

@if (TempData["Success"] != null) { <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div> }
@if (TempData["Error"]   != null) { <div class="alert alert--error"   style="margin-bottom:16px">@TempData["Error"]</div> }

@if (moduleNavigation != null) { @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation) }

<div class="page-header">
    <div>
        <h1>Rule 59 — Saved Run #@Model.RunId</h1>
        <p>@Model.EngagementName &nbsp;|&nbsp; @Model.MaconomyNumber &nbsp;|&nbsp; @Model.Summary.Timestamp</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        @if (canOpenWorkspace)  { <a href="/Rule59?clientId=@Model.ClientId" class="btn btn-secondary">Open Workspace</a> }
        @if (canDownload)
        {
            <a href="/Rule59/DownloadSavedExcel?runId=@Model.RunId" class="btn btn-info">Download Excel</a>
            <a href="/Rule59/DownloadSavedCsv?runId=@Model.RunId"   class="btn btn-info">Download CSV</a>
            <a href="/Rule59/DownloadSavedSql?runId=@Model.RunId"   class="btn btn-secondary">Download SQL</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">This engagement is archived. The saved run is available for review and download only.</div>
}
@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">The data analyst signoff is still outstanding. Assigned users can still review and download this run.</div>
}

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Run Summary</h3>
    <div class="form-grid">
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>@Model.Summary.Database</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Rule</div><div>Rule 59 — SFTE VALPAC Data in STAFF PRODUCTION</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">VALPAC Table</div><div>@Model.Summary.ValpacTable</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">PRODUCTION Table</div><div>@Model.Summary.ProdTable</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Column Mapping</div><div style="font-size:12px">@Model.Summary.TableLinkageText</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div><span class="badge @(Model.Summary.Status == "PASS" ? "badge--pass" : "badge--fail")">@Model.Summary.Status</span></div></div>
    </div>
    <div class="stats-grid" style="margin-top:16px">
        <div class="stat-card"><div class="stat-card__label">VALPAC Records</div><div class="stat-card__value">@Model.Summary.ValpacRecordCount.ToString("N0")</div></div>
        <div class="stat-card"><div class="stat-card__label">PRODUCTION Records</div><div class="stat-card__value">@Model.Summary.ProdRecordCount.ToString("N0")</div></div>
        <div class="stat-card"><div class="stat-card__label">Total Tested</div><div class="stat-card__value">@Model.Summary.TotalValidated.ToString("N0")</div></div>
        <div class="stat-card stat-card--pass"><div class="stat-card__label">Found in PRODUCTION</div><div class="stat-card__value">@Model.Summary.PassCount.ToString("N0")</div></div>
        <div class="stat-card stat-card--fail"><div class="stat-card__label">Missing from PRODUCTION</div><div class="stat-card__value">@Model.Summary.FailCount.ToString("N0")</div></div>
    </div>
</div>

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary">
                @(Model.CurrentUserHasSignedOff ? "Update My Signoff" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>
        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">Remove Signoff</button>
            </form>
        }
    }
    else if (isArchived) { <div class="alert alert--info" style="margin-bottom:16px">Signoff controls are disabled for archived engagements.</div> }
    else if (!Model.IsCurrentRun) { <div class="alert alert--info" style="margin-bottom:16px">History results are read-only. Signoff is only available on the current run.</div> }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead><tr><th>Role</th><th>Reviewer</th><th>Comment</th><th>Signed At</th></tr></thead>
            <tbody>
                @foreach (var s in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@s.SignoffRole</span></td>
                        <td><strong>@s.ReviewerName</strong><br /><small style="color:#757575">@s.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(s.Comment) ? "-" : s.Comment)</td>
                        <td>@s.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else { <div style="color:#757575">No signoffs recorded yet.</div> }
</div>

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Result Rows <small style="font-weight:normal;font-size:13px">(browser preview)</small></h3>
    @if (Model.Summary.IsPreviewOnly)
    {
        <div class="alert alert--warning" style="margin-bottom:12px">Showing a preview of @Model.Summary.PreviewLimit rows (FAIL-prioritised). Download Excel or CSV for the full result set.</div>
    }
    <div style="overflow-x:auto">
        <table class="data-table" style="min-width:500px;font-size:12px;font-family:Consolas,monospace">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@Model.Summary.ValpacCol037 (VALPAC)</th>
                    <th>@Model.Summary.ProdColPersonelNumber (PRODUCTION)</th>
                    <th>Result</th>
                    <th>Explanation</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Summary.ReviewRows)
                {
                    var dv = row.DisplayValues;
                    string DV(string k) => dv.TryGetValue(k, out var v) ? (v ?? "") : "";
                    <tr style="background:@(row.ValidationResult == "FAIL" ? "#FFF3F3" : "#F3FFF3")">
                        <td>@row.ValidationNumber</td>
                        <td style="font-weight:700">@DV("VALPAC__037")</td>
                        <td>@DV("PROD_PERSONEL_NUMBER")</td>
                        <td><span class="badge @(row.ValidationResult == "FAIL" ? "badge--fail" : "badge--pass")">@row.ValidationResult</span></td>
                        <td style="font-size:11px;color:#555">@row.ValidationExplanation</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.GeneratedSql))
{
    <div class="card" style="padding:20px;margin-top:20px">
        <h3 class="section-title" style="margin-top:0">SQL Script</h3>
        <pre style="overflow-x:auto;font-size:12px;background:#0f172a;color:#e2e8f0;padding:16px;border-radius:8px;white-space:pre-wrap">@Model.GeneratedSql</pre>
    </div>
}
