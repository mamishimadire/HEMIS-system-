    window.runAppOperationWithProgress = async function (options, action) {
        options = options || {};

        if (operationState.active) {
            window.showAppToast('An operation is already in progress. Wait for it to finish before starting another one.', 'warning');
            return false;
        }

        operationState.active = true;
        operationState.sequence += 1;

        var label = options.label || 'Processing request';
        var secondaryText = options.fileName || 'Working...';
        var pendingText = options.pendingText || 'Processing...';
        var card = options.suppressCard ? null : createDownloadCard('op-' + operationState.sequence, label, secondaryText);
        var percent = 3;
        if (card) {
            updateDownloadCard(card, percent, pendingText, secondaryText);
        }
        if (typeof options.onStart === 'function') {
            options.onStart(percent, pendingText, secondaryText);
        }

        var startedAt = Date.now();
        var timer = window.setInterval(function () {
            var elapsed = Date.now() - startedAt;
            var target = 12;
            var metaText = pendingText;
            if (elapsed < 1200) {
                target = 12 + (elapsed / 1200) * 28;
            } else if (elapsed < 4000) {
                target = 40 + ((elapsed - 1200) / 2800) * 34;
            } else if (elapsed < 10000) {
                target = 74 + ((elapsed - 4000) / 6000) * 18;
            } else if (elapsed < 25000) {
                target = 92 + ((elapsed - 10000) / 15000) * 6;
                metaText = 'Processing large dataset. Finalizing server response...';
            } else {
                target = 98;
                metaText = 'Still processing on the server. Keeping this request active...';
            }

            percent = Math.max(percent, Math.min(98, Math.round(target)));
            if (card) {
                updateDownloadCard(card, percent, metaText, secondaryText);
            }
            if (typeof options.onProgress === 'function') {
                options.onProgress(percent, metaText, secondaryText);
            }
        }, 180);

        try {
            var result = await action();
            window.clearInterval(timer);
            if (card) {
                updateDownloadCard(card, 100, options.successText || 'Completed.', secondaryText, 'is-complete');
            }
            if (typeof options.onProgress === 'function') {
                options.onProgress(100, options.successText || 'Completed.', secondaryText);
            }
            if (typeof options.onComplete === 'function') {
                options.onComplete(result, secondaryText);
            }
            if (options.successToastText) {
                window.showAppToast(options.successToastText, options.successToastType || 'success');
            }
            if (card) {
                removeDownloadCard(card, 900);
            }
            return result;
        } catch (error) {
            window.clearInterval(timer);
            var message = error && error.message ? error.message : 'Request failed.';
            if (card) {
                updateDownloadCard(card, 100, message, secondaryText, 'is-error');
            }
            if (typeof options.onError === 'function') {
                options.onError(message, secondaryText);
            }
            if (options.errorToastText !== false) {
                window.showAppToast(options.errorToastText || message, 'error');
            }
            if (card) {
                removeDownloadCard(card, 2500);
            }
            throw error;
        } finally {
            operationState.active = false;
        }
    };

    function isAsyncValidationRequest(url, method) {
        var normalizedUrl = String(url || '').toLowerCase();
        var normalizedMethod = String(method || 'GET').toUpperCase();
        return normalizedMethod === 'POST' && normalizedUrl.indexOf('/runvalidation') >= 0;
    }

    function withAsyncValidationHeader(requestOptions) {
        var nextOptions = Object.assign({}, requestOptions || {});
        var headers = new Headers(nextOptions.headers || {});
        headers.set('X-Validation-Async', '1');
        nextOptions.headers = headers;
        return nextOptions;
    }

    function delay(ms) {
        return new Promise(function (resolve) {
            window.setTimeout(resolve, ms);
        });
    }

    async function pollValidationOperation(statusUrl) {
        for (;;) {
            await delay(1500);

            var response = await fetch(statusUrl, { method: 'GET' });
            var contentType = (response.headers.get('content-type') || '').toLowerCase();
            if (contentType.indexOf('application/json') < 0) {
                throw new Error('Validation status response was invalid.');
            }

            var payload = await response.json();
            if (!response.ok) {
                throw new Error(payload.error || payload.message || 'Failed to read validation status.');
            }

            if (payload && payload.pending) {
                continue;
            }

            if (payload && Object.prototype.hasOwnProperty.call(payload, 'result')) {
                return payload.result;
            }

            return payload;
        }
    }

    window.fetchJsonWithProgress = async function (url, requestOptions, explicitProgressOptions) {
        requestOptions = requestOptions || {};
        var method = requestOptions.method || 'GET';
        var progressOptions = explicitProgressOptions === false
            ? null
            : (explicitProgressOptions || window.getTrackedOperationOptions(url, method));

        var performFetch = async function () {
            var effectiveRequestOptions = isAsyncValidationRequest(url, method)
                ? withAsyncValidationHeader(requestOptions)
                : requestOptions;

            var response = await fetch(url, effectiveRequestOptions);
            var contentType = (response.headers.get('content-type') || '').toLowerCase();

            if (!response.ok) {
                var errorMessage = 'Request failed.';
                if (contentType.indexOf('application/json') >= 0) {
                    try {
                        var errorData = await response.json();
                        errorMessage = errorData.error || errorData.message || errorMessage;
                    } catch (_) {}
                } else {
                    try {
                        var errorText = (await response.text() || '').trim();
                        if (errorText) errorMessage = errorText;
                    } catch (_) {}
                }

                throw new Error(errorMessage);
            }

            if (contentType.indexOf('application/json') >= 0) {
                if (response.status === 202) {
                    var acceptedResult = await response.json();
                    var statusUrl = acceptedResult && acceptedResult.statusUrl
                        ? acceptedResult.statusUrl
                        : (acceptedResult && acceptedResult.operationId
                            ? '/ValidationOperations/' + encodeURIComponent(acceptedResult.operationId)
                            : '');

                    if (!statusUrl) {
                        throw new Error('Validation status URL was not provided.');
                    }

                    var polledResult = await pollValidationOperation(statusUrl);
                    window.ruleWorkspaceUi?.syncWorkspaceSaveLock?.(url, method, requestOptions, polledResult);
                    return polledResult;
                }

                var jsonResult = await response.json();
                window.ruleWorkspaceUi?.syncWorkspaceSaveLock?.(url, method, requestOptions, jsonResult);
                return jsonResult;
            }

            return await response.text();
        };

        if (!progressOptions) {
            return await performFetch();
        }

        return await window.runAppOperationWithProgress(progressOptions, performFetch);
    };

