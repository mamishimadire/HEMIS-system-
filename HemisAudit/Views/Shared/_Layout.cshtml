    function beginImplicitDownloadTracking(url) {
        if (downloadState.active) {
            var activeMessage = 'A download is already in progress. Wait for it to finish before starting another one.';
            window.showAppToast(activeMessage, 'warning');
            throw new Error(activeMessage);
        }

        downloadState.active = true;
        downloadState.sequence += 1;

        var requestedName = 'Preparing file...';
        var card = createDownloadCard(downloadState.sequence, inferDownloadLabel(url), requestedName);
        var displayPercent = 3;
        var prepareStartedAt = Date.now();
        var prepareTimer = null;
        var transferTimer = null;
        var completed = false;

        updateDownloadCard(card, displayPercent, 'Preparing file on server...', requestedName);

        prepareTimer = window.setInterval(function () {
            var elapsed = Date.now() - prepareStartedAt;
            var target = 8;
            if (elapsed < 1500) {
                target = 8 + (elapsed / 1500) * 10;
            } else if (elapsed < 5000) {
                target = 18 + ((elapsed - 1500) / 3500) * 8;
            } else if (elapsed < 15000) {
                target = 26 + ((elapsed - 5000) / 10000) * 10;
            } else {
                target = 36;
            }

            displayPercent = Math.max(displayPercent, Math.min(36, Math.round(target)));
            updateDownloadCard(card, displayPercent, 'Preparing file on server...', requestedName);
        }, 180);

        function stopPrepareTimer() {
            if (prepareTimer) {
                window.clearInterval(prepareTimer);
                prepareTimer = null;
            }
        }

        function stopTransferTimer() {
            if (transferTimer) {
                window.clearInterval(transferTimer);
                transferTimer = null;
            }
        }

        function release() {
            if (completed) {
                return;
            }

            completed = true;
            stopPrepareTimer();
            stopTransferTimer();
            downloadState.active = false;
        }

        return {
            card: card,
            requestedName: requestedName,
            getDisplayPercent: function () { return displayPercent; },
            setDisplayPercent: function (value) { displayPercent = Math.max(displayPercent, Math.round(Number(value) || 0)); },
            setPrepareReady: function (fileName, totalBytes) {
                stopPrepareTimer();
                updateDownloadCard(
                    card,
                    displayPercent,
                    totalBytes > 0
                        ? 'Starting download... 0% of ' + formatBytes(totalBytes)
                        : 'Starting download...',
                    fileName
                );
            },
            startTransferFallback: function (fileName, getReceivedBytes) {
                stopTransferTimer();
                transferTimer = window.setInterval(function () {
                    displayPercent = Math.max(displayPercent, Math.min(95, displayPercent + 1));
                    updateDownloadCard(card, displayPercent, formatBytes(getReceivedBytes()) + ' downloaded', fileName);
                }, 220);
            },
            stopTransferFallback: stopTransferTimer,
            updateTransfer: function (fileName, percent, meta) {
                displayPercent = Math.max(displayPercent, percent);
                updateDownloadCard(card, displayPercent, meta, fileName);
            },
            complete: function (fileName) {
                release();
                updateDownloadCard(card, 100, 'Download complete.', fileName, 'is-complete');
                window.showAppToast('Download complete: ' + fileName, 'success');
                removeDownloadCard(card, 1400);
            },
            fail: function (message, fileName) {
                release();
                var errorMessage = message || 'Download failed.';
                updateDownloadCard(card, 100, errorMessage, fileName || requestedName, 'is-error');
                window.showAppToast(errorMessage, 'error');
                removeDownloadCard(card, 2500);
            },
            releaseOnly: release
        };
    }

