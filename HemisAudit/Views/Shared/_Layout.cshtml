    function getRequestUrl(input) {
        if (typeof input === 'string') {
            return input;
        }

        if (input && typeof input.url === 'string') {
            return input.url;
        }

        return '';
    }

    function getRequestMethod(input, init) {
        if (init && init.method) {
            return String(init.method).toUpperCase();
        }

        if (input && input.method) {
            return String(input.method).toUpperCase();
        }

        return 'GET';
    }

    function getRequestHeaderValue(input, init, name) {
        var headerName = String(name || '').toLowerCase();
        var sources = [];

        if (init && init.headers) {
            sources.push(init.headers);
        }

        if (input && input.headers) {
            sources.push(input.headers);
        }

        for (var i = 0; i < sources.length; i++) {
            try {
                var headers = new Headers(sources[i]);
                var value = headers.get(headerName);
                if (value) {
                    return value;
                }
            } catch (_) { }
        }

        return '';
    }

    function inferDownloadLabel(url) {
