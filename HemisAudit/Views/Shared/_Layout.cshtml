        var metaNode = card.querySelector('.app-download-card__meta');
        var fileNode = card.querySelector('.app-download-card__file');
        var fillNode = card.querySelector('.app-download-card__bar-fill');

        if (percentNode) percentNode.textContent = normalizedPercent + '%';
        if (metaNode) metaNode.textContent = metaText || '';
        if (fileNode && fileName) fileNode.textContent = fileName;
        if (fillNode) fillNode.style.width = normalizedPercent + '%';
