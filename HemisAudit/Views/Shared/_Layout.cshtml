            }

            var fileName = extractFileName(response.headers.get('content-disposition'), requestedName);
            var totalBytes = parseInt(response.headers.get('content-length') || '0', 10);
            if (!isFinite(totalBytes) || totalBytes < 0) totalBytes = 0;

            if (prepareTimer) {
                window.clearInterval(prepareTimer);
                prepareTimer = null;
            }

            updateDownloadCard(
                card,
                displayPercent,
                totalBytes > 0
                    ? 'Starting download... 0% of ' + formatBytes(totalBytes)
                    : 'Starting download...',
                fileName
            );

            var blob;
            if (response.body && typeof response.body.getReader === 'function') {
                var reader = response.body.getReader();
                var chunks = [];
                var receivedBytes = 0;
                var transferPercent = displayPercent;

                if (totalBytes <= 0) {
                    transferTimer = window.setInterval(function () {
                        transferPercent = Math.max(transferPercent, Math.min(95, transferPercent + 1));
                        updateDownloadCard(card, transferPercent, formatBytes(receivedBytes) + ' downloaded', fileName);
                    }, 220);
                }

                while (true) {
                    var readResult = await reader.read();
                    if (readResult.done) break;

                    var chunk = readResult.value || new Uint8Array();
                    chunks.push(chunk);
                    receivedBytes += chunk.length;

                    var percent = totalBytes > 0
                        ? Math.min(99, 36 + Math.round((receivedBytes / totalBytes) * 64))
                        : transferPercent;
                    var meta = totalBytes > 0
                        ? Math.max(0, Math.round((receivedBytes / totalBytes) * 100)) + '% of ' + formatBytes(totalBytes) + ' (' + formatBytes(receivedBytes) + ' downloaded)'
                        : formatBytes(receivedBytes) + ' downloaded';

                    transferPercent = Math.max(transferPercent, percent);
                    updateDownloadCard(card, transferPercent, meta, fileName);
                }

                if (transferTimer) {
                    window.clearInterval(transferTimer);
                }

                blob = new Blob(chunks, { type: response.headers.get('content-type') || 'application/octet-stream' });
            } else {
                blob = await response.blob();
            }

            saveBlob(blob, fileName);
            updateDownloadCard(card, 100, 'Download complete.', fileName, 'is-complete');
            window.showAppToast('Download complete: ' + fileName, 'success');
            removeDownloadCard(card, 1400);
            return true;
        } catch (error) {
            if (prepareTimer) {
                window.clearInterval(prepareTimer);
            }
            if (transferTimer) {
                window.clearInterval(transferTimer);
            }
            var message = error && error.message ? error.message : 'Download failed.';
            updateDownloadCard(card, 100, message, requestedName, 'is-error');
            window.showAppToast(message, 'error');
            removeDownloadCard(card, 2500);
            throw error;
        } finally {
            downloadState.active = false;
        }
    };

    (function installImplicitDownloadTracking() {
        if (window.__hemisImplicitDownloadTrackingInstalled) {
            return;
        }

        window.__hemisImplicitDownloadTrackingInstalled = true;
        var originalFetch = window.fetch.bind(window);

        function shouldTrackImplicitDownload(input, init) {
            var url = getRequestUrl(input);
            var method = getRequestMethod(input, init);
            if (method !== 'GET' && method !== 'POST') {
                return false;
            }

            if (String(getRequestHeaderValue(input, init, 'X-App-Managed-Download')).toLowerCase() === '1') {
                return false;
            }

            try {
                var absoluteUrl = new URL(url, window.location.href);
                return absoluteUrl.origin === window.location.origin &&
                    absoluteUrl.pathname.toLowerCase().indexOf('/download') >= 0;
            } catch (_) {
                return false;
            }
        }

        function wrapDownloadResponse(response, tracker) {
            if (!response.body || typeof response.body.getReader !== 'function') {
                tracker.complete(extractFileName(response.headers.get('content-disposition'), tracker.requestedName));
                return response;
            }

            var fileName = extractFileName(response.headers.get('content-disposition'), tracker.requestedName);
            var totalBytes = parseInt(response.headers.get('content-length') || '0', 10);
            if (!isFinite(totalBytes) || totalBytes < 0) {
                totalBytes = 0;
            }

            tracker.setPrepareReady(fileName, totalBytes);

            var reader = response.body.getReader();
            var receivedBytes = 0;
            if (totalBytes <= 0) {
                tracker.startTransferFallback(fileName, function () { return receivedBytes; });
            }

            var settled = false;

            function settleComplete() {
                if (settled) {
                    return;
                }

                settled = true;
                tracker.stopTransferFallback();
                tracker.complete(fileName);
            }

            function settleError(message) {
                if (settled) {
                    return;
                }

                settled = true;
                tracker.stopTransferFallback();
                tracker.fail(message, fileName);
            }

            var stream = new ReadableStream({
                pull: async function (controller) {
                    try {
                        var readResult = await reader.read();
                        if (readResult.done) {
                            settleComplete();
                            controller.close();
                            return;
                        }

                        var chunk = readResult.value || new Uint8Array();
                        receivedBytes += chunk.length;

                        var percent = totalBytes > 0
                            ? Math.min(99, 36 + Math.round((receivedBytes / totalBytes) * 64))
                            : tracker.getDisplayPercent();
                        var meta = totalBytes > 0
                            ? Math.max(0, Math.round((receivedBytes / totalBytes) * 100)) + '% of ' + formatBytes(totalBytes) + ' (' + formatBytes(receivedBytes) + ' downloaded)'
                            : formatBytes(receivedBytes) + ' downloaded';

                        tracker.updateTransfer(fileName, percent, meta);
                        controller.enqueue(chunk);
                    } catch (error) {
                        settleError(error && error.message ? error.message : 'Download failed.');
                        controller.error(error);
                    }
                },
                cancel: function (reason) {
                    tracker.stopTransferFallback();
                    tracker.releaseOnly();
                    try {
                        return reader.cancel(reason);
                    } catch (_) {
                        return undefined;
                    }
                }
            });

            return new Response(stream, {
                headers: new Headers(response.headers),
                status: response.status,
                statusText: response.statusText
            });
        }

        window.fetch = async function (input, init) {
            if (!shouldTrackImplicitDownload(input, init)) {
                return originalFetch(input, init);
            }

            var tracker = beginImplicitDownloadTracking(getRequestUrl(input));

            try {
                var response = await originalFetch(input, init);
                if (!response.ok) {
                    tracker.fail('Download failed.');
                    return response;
                }

                return wrapDownloadResponse(response, tracker);
            } catch (error) {
                tracker.fail(error && error.message ? error.message : 'Download failed.');
                throw error;
            }
        };
    })();

    document.addEventListener('click', function (event) {
        var link = event.target && event.target.closest
            ? event.target.closest('a[data-track-download], a[href*="/DownloadSaved"]')
            : null;
        if (!link || event.defaultPrevented) return;
        if (link.target && link.target !== '_self') return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        if (!link.href) return;

        event.preventDefault();

        window.downloadFileWithProgress({
            url: link.href,
            method: 'GET',
            label: link.getAttribute('data-download-label') || (link.textContent || '').trim() || 'Downloading saved results',
            defaultFileName: link.getAttribute('data-download-name') || 'download.bin'
        }).catch(function () { });
    });

})();
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
