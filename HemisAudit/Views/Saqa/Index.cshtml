<script>
(function () {
    /* ── iframe load ── */
    const frame = document.getElementById('saqaFrame');
    const blockedMsg = document.getElementById('saqaBlockedMsg');
    const sdot = document.getElementById('saqaSdot');
    const statusTxt = document.getElementById('saqaStatusTxt');

    frame.addEventListener('load', function () {
        try {
            var doc = frame.contentDocument || frame.contentWindow.document;
            if (!doc || doc.body === null || doc.body.innerHTML.trim() === '') {
                showBlocked();
            } else {
                sdot.className = 'dir-sdot';
                statusTxt.textContent = 'SAQA search ready';
            }
        } catch (e) {
            sdot.className = 'dir-sdot';
            statusTxt.textContent = 'SAQA search ready';
        }
    });

    frame.addEventListener('error', showBlocked);

    function showBlocked() {
        frame.style.display = 'none';
        blockedMsg.style.display = 'flex';
        sdot.className = 'dir-sdot red';
        statusTxt.textContent = 'Embedding blocked by SAQA — use Open in New Tab';
    }

    document.getElementById('saqaBtnReload').addEventListener('click', function () {
        frame.style.display = '';
        blockedMsg.style.display = 'none';
        sdot.className = 'dir-sdot';
        statusTxt.textContent = 'Reloading…';
        frame.src = frame.src;
    });

    /* ── Guide panel ── */
    const overlay = document.getElementById('saqaOverlay');
    const panel   = document.getElementById('saqaGuidePanel');
    const tabs    = document.querySelectorAll('.sgp-tab');
    const steps   = document.querySelectorAll('.sgp-step');
    const btnPrev = document.getElementById('sgpPrev');
    const btnNext = document.getElementById('sgpNext');
    const counter = document.getElementById('sgpCounter');
    let currentStep = 1;
    const totalSteps = 4;

    function openGuide() {
        overlay.classList.add('open');
        panel.classList.add('open');
    }

    function closeGuide() {
        overlay.classList.remove('open');
        panel.classList.remove('open');
    }

    function goToStep(n) {
        currentStep = Math.max(1, Math.min(totalSteps, n));
        tabs.forEach(function(t) { t.classList.toggle('active', +t.dataset.step === currentStep); });
        steps.forEach(function(s, i) { s.classList.toggle('active', i + 1 === currentStep); });
        counter.textContent = 'Step ' + currentStep + ' of ' + totalSteps;
        btnPrev.disabled = currentStep === 1;
        btnNext.disabled = currentStep === totalSteps;
        document.querySelector('.sgp-body').scrollTop = 0;
    }

    document.getElementById('saqaGuideBtn').addEventListener('click', openGuide);
    document.getElementById('saqaGuideClose').addEventListener('click', closeGuide);
    overlay.addEventListener('click', closeGuide);

    tabs.forEach(function(t) {
        t.addEventListener('click', function() { goToStep(+t.dataset.step); });
    });

    btnPrev.addEventListener('click', function() { goToStep(currentStep - 1); });
    btnNext.addEventListener('click', function() { goToStep(currentStep + 1); });

    goToStep(1);
}());
</script>
