@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 40 – PROF VALPAC vs 2025H16PROF";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients           = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId  = ViewBag.ClientId is int cid ? cid : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole = string.Equals(currentSystemRole, "Manager",  StringComparison.OrdinalIgnoreCase)
                         || string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(currentSystemRole, "Trainee",  StringComparison.OrdinalIgnoreCase);
    var moduleNavigation  = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="r40ClientId">Engagement</label>
        <select id="r40ClientId" onchange="r40OnClientChange(this.value)">
            <option value="">Select engagement</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R40</div>
        <div>
            <h1 class="rule-header__title">Rule 40 — PROF VALPAC vs 2025H16PROF Staff Agreement</h1>
            <p class="rule-header__sub">
                Compares VALPAC PROF records against the ASCII file using <code>_037</code> (Staff Number) as the key.
                Checks <code>_011 _012 _013 _014 _038 _039 _040 _041 _042 _046 _047 _048</code> across both files.
                Result: <strong>AGREE</strong>, <strong>DISAGREE</strong>, or <strong>MISSING</strong>.
            </p>
        </div>
    </div>

    <!-- Saved workspace banner -->
    <div id="r40WorkspaceBanner" style="display:none" class="card" style="margin-bottom:16px;padding:14px 18px"></div>

    @if (!isResultsOnlyRole)
    {
        <!-- ── Step 1: Connect ───────────────────────────────────────────── -->
        <div class="card workspace-config-card" id="r40ConnectCard">
            <h3 class="section-title">Step 1 — Connect to Database</h3>
            <div class="field-row">
                <div class="field-group" style="flex:2;min-width:220px">
                    <label for="r40Server">SQL Server</label>
                    <input type="text" id="r40Server" placeholder="e.g. HEMIS-SQL\SQLEXPRESS" autocomplete="off" />
                </div>
                <div style="display:flex;align-items:flex-end">
                    <button class="btn btn-primary" onclick="r40Connect()">Connect</button>
                </div>
                <div class="field-group" style="flex:2;min-width:200px">
                    <label for="r40Database">Database</label>
                    <select id="r40Database" onchange="r40LoadTables()">
                        <option value="">— connect first —</option>
                    </select>
                </div>
            </div>
            <div id="r40ConnectStatus" class="status-msg" style="margin-top:8px"></div>
        </div>

        <!-- ── Step 2: Select Tables ─────────────────────────────────────── -->
        <div class="card workspace-config-card" id="r40TablesCard" style="display:none">
            <h3 class="section-title">Step 2 — Select VALPAC &amp; ASCII Tables</h3>
            <div class="field-row">
                <div class="field-group" style="flex:1;min-width:200px">
                    <label for="r40ValpacTable">VALPAC Table (Staff VALPAC)</label>
                    <select id="r40ValpacTable"><option value="">— select —</option></select>
                </div>
                <div class="field-group" style="flex:1;min-width:200px">
                    <label for="r40AsciiTable">ASCII Table (Staff ASCII File)</label>
                    <select id="r40AsciiTable"><option value="">— select —</option></select>
                </div>
                <div style="display:flex;align-items:flex-end">
                    <button class="btn btn-secondary" onclick="r40VerifyTables()">Verify Tables</button>
                </div>
            </div>
            <div id="r40VerifyStatus" style="margin-top:10px"></div>
        </div>

        <!-- ── Run Validation ────────────────────────────────────────────── -->
        <div class="card workspace-config-card" id="r40RunCard" style="display:none">
            <h3 class="section-title">Step 3 — Run Validation</h3>
            <p style="color:var(--text-muted);font-size:.88rem;margin-bottom:12px">
                Compares every staff record between the VALPAC and ASCII tables on <code>_037</code>.
                Columns checked: Date of Birth, Gender, Race, Nationality, Empl. Commencement, Personnel Category, Rank, Permanent/Temporary, Full/Part-time, Qualification Type, Joint Appointment, On Payroll Code.
            </p>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <button class="btn btn-primary" id="r40RunBtn" onclick="r40RunValidation()">Run Validation</button>
                <button class="btn btn-secondary" onclick="r40GenerateSql()">Generate SQL</button>
                <button class="btn btn-secondary" onclick="r40DownloadSql()">Download SQL</button>
            </div>
            <div id="r40RunStatus" class="status-msg" style="margin-top:10px"></div>
        </div>
    }

    <!-- ── Results ───────────────────────────────────────────────────────── -->
    <div id="r40ResultsPanel" style="display:none">

        <!-- Summary stats -->
        <div class="card" style="margin-bottom:16px;padding:16px 20px">
            <h3 class="section-title" style="margin:0 0 12px">Validation Summary</h3>
            <div class="workspace-summary-grid">
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">VALPAC Table</span>
                    <span class="workspace-summary-item__value" id="r40SumValpac">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">ASCII Table</span>
                    <span class="workspace-summary-item__value" id="r40SumAscii">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">Total Staff</span>
                    <span class="workspace-summary-item__value" id="r40SumTotal">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">AGREE</span>
                    <span class="workspace-summary-item__value text-success" id="r40SumAgree">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">DISAGREE</span>
                    <span class="workspace-summary-item__value text-danger" id="r40SumDisagree">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">Missing in ASCII</span>
                    <span class="workspace-summary-item__value text-danger" id="r40SumMissingAscii">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">Missing in VALPAC</span>
                    <span class="workspace-summary-item__value text-danger" id="r40SumMissingValpac">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">Exception Rate</span>
                    <span class="workspace-summary-item__value" id="r40SumRate">—</span>
                </div>
                <div class="workspace-summary-item">
                    <span class="workspace-summary-item__label">Status</span>
                    <span class="workspace-summary-item__value" id="r40SumStatus">—</span>
                </div>
            </div>
        </div>

        <!-- Exception rows preview -->
        <div class="card" style="margin-bottom:16px;padding:16px 20px">
            <h3 class="section-title" style="margin:0 0 6px">Exceptions (DISAGREE &amp; MISSING)</h3>
            <p style="color:var(--text-muted);font-size:.83rem;margin:0 0 10px">Preview 10 row(s) only — download Excel/CSV for full population.</p>
            <div style="overflow-x:auto">
                <table class="data-table" id="r40ExcTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Staff Number (_037)</th>
                            <th>Result</th>
                            <th>Disagreeing Fields</th>
                        </tr>
                    </thead>
                    <tbody id="r40ExcTbody">
                        <tr><td colspan="4" style="text-align:center;color:var(--text-muted)">No exceptions.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- AGREE sample preview -->
        <div class="card" style="margin-bottom:16px;padding:16px 20px">
            <h3 class="section-title" style="margin:0 0 6px">AGREE Sample</h3>
            <p style="color:var(--text-muted);font-size:.83rem;margin:0 0 10px">Preview 10 row(s) only.</p>
            <div style="overflow-x:auto">
                <table class="data-table" id="r40AgreeTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Staff Number (_037)</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody id="r40AgreeTbody">
                        <tr><td colspan="3" style="text-align:center;color:var(--text-muted)">No agree rows.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Downloads -->
        <div class="card" style="margin-bottom:16px;padding:16px 20px">
            <h3 class="section-title" style="margin:0 0 10px">Downloads (Full Population)</h3>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <button class="btn btn-success" onclick="r40Download('excel')">Download Excel</button>
                <button class="btn btn-secondary" onclick="r40Download('csv')">Download CSV</button>
            </div>
        </div>

        <!-- Save workspace -->
        @if (!isResultsOnlyRole)
        {
            <div class="card" id="r40SaveCard" style="margin-bottom:16px;padding:16px 20px;display:none">
                <h3 class="section-title" style="margin:0 0 10px">Save Workspace</h3>
                <p style="color:var(--text-muted);font-size:.88rem;margin:0 0 12px">
                    Save this run to make it available for signoff by the review team.
                </p>
                <button class="btn btn-primary" onclick="r40SaveWorkspace()">Save Workspace</button>
                <div id="r40SaveStatus" class="status-msg" style="margin-top:8px"></div>
            </div>
        }

        <!-- Signoff -->
        <div class="card" id="r40SignoffCard" style="margin-bottom:16px;padding:16px 20px;display:none">
            <h3 class="section-title" style="margin:0 0 10px">Signoff</h3>
            <div id="r40SignoffBody"></div>
        </div>

    </div>

    <!-- SQL modal -->
    <div id="r40SqlModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
        <div style="background:var(--surface);border-radius:10px;padding:20px;max-width:90vw;width:700px;max-height:80vh;display:flex;flex-direction:column">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                <strong>Generated SQL — Rule 40</strong>
                <button class="btn btn-secondary btn-sm" onclick="document.getElementById('r40SqlModal').style.display='none'">Close</button>
            </div>
            <textarea id="r40SqlText" readonly style="flex:1;font-family:monospace;font-size:.78rem;resize:none;border:1px solid var(--border);border-radius:6px;padding:10px;background:var(--bg);color:var(--text);min-height:320px"></textarea>
        </div>
    </div>
</div>

<script>
(function () {
    'use strict';

    // ── State ───────────────────────────────────────────────────────────────
    var state = {
        clientId:    @selectedClientId,
        server:      '',
        database:    '',
        driver:      'ODBC Driver 17 for SQL Server',
        valpacTable: '',
        asciiTable:  '',
        runId:       null,
        verified:    false
    };

    // ── Boot ─────────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        if (state.clientId > 0) loadWorkspace(state.clientId);
    });

    window.r40OnClientChange = function (val) {
        state.clientId = parseInt(val, 10) || 0;
        clearResults();
        if (state.clientId > 0) loadWorkspace(state.clientId);
    };

    // ── Workspace load ───────────────────────────────────────────────────────
    function loadWorkspace(clientId) {
        fetch('/Rule40/GetWorkspaceState?clientId=' + clientId)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) return;
                if (!data.hasWorkspace) return;
                var ws = data.workspace;
                if (!ws) return;
                state.runId       = ws.runId;
                state.server      = ws.server      || '';
                state.database    = ws.database    || '';
                state.valpacTable = ws.valpacTable || '';
                state.asciiTable  = ws.asciiTable  || '';

                showBanner(ws);

                if (data.resultsVisible && ws.summary) {
                    renderSummary(ws.summary);
                    renderTables(ws.summary);
                    show('r40ResultsPanel');
                    showSaveCard(ws);
                    renderSignoff(ws);
                }
            });
    }

    function showBanner(ws) {
        var el = document.getElementById('r40WorkspaceBanner');
        if (!el) return;
        var saved = ws.isWorkspaceSaved ? ' | <span style="color:#2e7d32">Workspace saved</span>' : ' | <span style="color:#b45309">Workspace not yet saved</span>';
        var edited = ws.lastEditedByUserName ? ' | Last edited by ' + esc(ws.lastEditedByUserName) : '';
        el.innerHTML = '<strong>Saved workspace:</strong> VALPAC: <code>' + esc(ws.valpacTable) + '</code> vs ASCII: <code>' + esc(ws.asciiTable) + '</code>'
            + ' | Status: <strong>' + esc(ws.currentStatus) + '</strong>'
            + saved + edited;
        el.style.display = 'block';
    }

    function showSaveCard(ws) {
        var saveCard = document.getElementById('r40SaveCard');
        if (saveCard && !@(isResultsOnlyRole ? "true" : "false")) {
            saveCard.style.display = 'block';
        }
    }

    function clearResults() {
        hide('r40ResultsPanel');
        hide('r40WorkspaceBanner');
        state.runId = null;
    }

    // ── Connect ──────────────────────────────────────────────────────────────
    window.r40Connect = function () {
        state.server = el('r40Server').value.trim();
        if (!state.server) { setStatus('r40ConnectStatus', 'Enter a server name.', 'error'); return; }
        setStatus('r40ConnectStatus', 'Connecting…', 'info');
        post('/Rule40/GetDatabases', { server: state.server, driver: state.driver })
            .then(function (d) {
                if (!d.success) { setStatus('r40ConnectStatus', d.error || 'Connection failed.', 'error'); return; }
                var sel = el('r40Database');
                sel.innerHTML = '<option value="">— select database —</option>';
                (d.databases || []).forEach(function (db) {
                    sel.appendChild(opt(db, db));
                });
                setStatus('r40ConnectStatus', 'Connected. Select a database.', 'success');
            })
            .catch(function () { setStatus('r40ConnectStatus', 'Connection error.', 'error'); });
    };

    window.r40LoadTables = function () {
        state.database = el('r40Database').value;
        if (!state.database) return;
        post('/Rule40/GetTables', { server: state.server, database: state.database, driver: state.driver })
            .then(function (d) {
                if (!d.success) { setStatus('r40ConnectStatus', d.error || 'Could not load tables.', 'error'); return; }
                populateTableSelect('r40ValpacTable', d.tables, d.autoValpacTable);
                populateTableSelect('r40AsciiTable',  d.tables, d.autoAsciiTable);
                show('r40TablesCard');
                show('r40RunCard');
                setStatus('r40ConnectStatus', '', '');
            });
    };

    function populateTableSelect(selId, tables, autoVal) {
        var sel = el(selId);
        sel.innerHTML = '<option value="">— select —</option>';
        (tables || []).forEach(function (t) {
            var o = opt(t, t);
            if (autoVal && t.toLowerCase() === autoVal.toLowerCase()) o.selected = true;
            sel.appendChild(o);
        });
    }

    // ── Verify tables ─────────────────────────────────────────────────────────
    window.r40VerifyTables = function () {
        state.valpacTable = el('r40ValpacTable').value;
        state.asciiTable  = el('r40AsciiTable').value;
        if (!state.valpacTable || !state.asciiTable) {
            setStatus('r40VerifyStatus', 'Select both tables first.', 'error'); return;
        }
        setStatus('r40VerifyStatus', 'Verifying…', 'info');
        post('/Rule40/VerifyTables', {
            server: state.server, database: state.database, driver: state.driver,
            valpacTable: state.valpacTable, asciiTable: state.asciiTable
        }).then(function (d) {
            if (!d.success) { setStatus('r40VerifyStatus', d.error || 'Verify failed.', 'error'); return; }
            state.verified = true;
            setStatus('r40VerifyStatus',
                'VALPAC: <strong>' + fmt(d.valpacCount) + ' rows</strong> &nbsp;|&nbsp; ASCII: <strong>' + fmt(d.asciiCount) + ' rows</strong>', 'success');
        });
    };

    // ── Run validation ────────────────────────────────────────────────────────
    window.r40RunValidation = function () {
        if (!state.clientId) { setStatus('r40RunStatus', 'Select an engagement first.', 'error'); return; }
        state.valpacTable = el('r40ValpacTable')?.value || state.valpacTable;
        state.asciiTable  = el('r40AsciiTable')?.value  || state.asciiTable;
        if (!state.valpacTable || !state.asciiTable) { setStatus('r40RunStatus', 'Select both tables first.', 'error'); return; }

        var btn = el('r40RunBtn');
        if (btn) btn.disabled = true;
        setStatus('r40RunStatus', 'Running validation — comparing all staff records…', 'info');

        post('/Rule40/RunValidation', {
            clientId: state.clientId,
            server: state.server, database: state.database, driver: state.driver,
            valpacTable: state.valpacTable, asciiTable: state.asciiTable
        }).then(function (d) {
            if (btn) btn.disabled = false;
            if (!d.success) { setStatus('r40RunStatus', d.error || 'Validation failed.', 'error'); return; }
            state.runId = d.savedRunId;
            setStatus('r40RunStatus', '', '');
            renderSummary(d);
            renderTables(d);
            show('r40ResultsPanel');
            var saveCard = document.getElementById('r40SaveCard');
            if (saveCard) saveCard.style.display = 'block';
        }).catch(function () {
            if (btn) btn.disabled = false;
            setStatus('r40RunStatus', 'Unexpected error during validation.', 'error');
        });
    };

    // ── Render summary ────────────────────────────────────────────────────────
    function renderSummary(d) {
        setText('r40SumValpac',       d.valpacTable || '—');
        setText('r40SumAscii',        d.asciiTable  || '—');
        setText('r40SumTotal',        fmt(d.totalCount));
        setText('r40SumAgree',        fmt(d.agreeCount));
        setText('r40SumDisagree',     fmt(d.disagreeCount));
        setText('r40SumMissingAscii', fmt(d.missingInAsciiCount));
        setText('r40SumMissingValpac',fmt(d.missingInValpacCount));
        setText('r40SumRate',         (d.exceptionRate || 0).toFixed(2) + '%');
        var statusEl = el('r40SumStatus');
        if (statusEl) {
            statusEl.textContent = d.status || '—';
            statusEl.className   = 'workspace-summary-item__value ' + (d.status === 'PASS' ? 'text-success' : 'text-danger');
        }
    }

    // ── Render tables ─────────────────────────────────────────────────────────
    function renderTables(d) {
        var excTbody   = el('r40ExcTbody');
        var agreeTbody = el('r40AgreeTbody');
        if (!excTbody || !agreeTbody) return;

        var excRows = d.reviewRows || [];
        if (excRows.length === 0) {
            excTbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-muted)">No exceptions.</td></tr>';
        } else {
            excTbody.innerHTML = excRows.map(function (row) {
                var badge = row.overallResult === 'AGREE'
                    ? '<span class="badge badge--pass">AGREE</span>'
                    : row.overallResult && row.overallResult.startsWith('MISSING')
                        ? '<span class="badge badge--warning">' + esc(row.overallResult) + '</span>'
                        : '<span class="badge badge--fail">DISAGREE</span>';
                return '<tr><td>' + row.rowNumber + '</td><td><code>' + esc(row.staffNumber) + '</code></td><td>' + badge + '</td><td style="font-size:.8rem;color:var(--text-muted)">' + esc(row.disagreeDetail) + '</td></tr>';
            }).join('');
        }

        var agreeRows = d.agreeSample || [];
        if (agreeRows.length === 0) {
            agreeTbody.innerHTML = '<tr><td colspan="3" style="text-align:center;color:var(--text-muted)">No agree rows.</td></tr>';
        } else {
            agreeTbody.innerHTML = agreeRows.map(function (row) {
                return '<tr><td>' + row.rowNumber + '</td><td><code>' + esc(row.staffNumber) + '</code></td><td><span class="badge badge--pass">AGREE</span></td></tr>';
            }).join('');
        }
    }

    // ── Signoff ───────────────────────────────────────────────────────────────
    function renderSignoff(ws) {
        var card = el('r40SignoffCard');
        if (!card) return;
        if (!ws.isWorkspaceSaved) { hide('r40SignoffCard'); return; }
        show('r40SignoffCard');

        var html = '';

        if (ws.currentUserHasSignedOff) {
            html += '<div class="alert alert--success" style="margin-bottom:10px">You have signed off this workspace.'
                + (ws.currentUserSignoffComment ? ' Comment: <em>' + esc(ws.currentUserSignoffComment) + '</em>' : '') + '</div>';
            html += '<button class="btn btn-warning btn-sm" onclick="r40RemoveSignoff()">Remove My Signoff</button>';
        } else {
            html += '<div class="field-group" style="margin-bottom:8px"><label>Signoff Comment (optional)</label>'
                + '<input type="text" id="r40SignoffComment" placeholder="Optional comment" style="max-width:400px" /></div>';
            html += '<button class="btn btn-primary" onclick="r40AddSignoff()">Sign Off</button>';
        }

        html += '<div id="r40SignoffStatus" class="status-msg" style="margin-top:8px"></div>';
        el('r40SignoffBody').innerHTML = html;
    }

    window.r40AddSignoff = function () {
        if (!state.runId) { setStatus('r40SignoffStatus', 'No saved run to sign off.', 'error'); return; }
        var comment = (el('r40SignoffComment')?.value || '').trim();
        post('/Rule40/AddSignoff', { clientId: state.clientId, runId: state.runId, comment: comment })
            .then(function (d) {
                if (!d.success) { setStatus('r40SignoffStatus', d.error || 'Signoff failed.', 'error'); return; }
                loadWorkspace(state.clientId);
            });
    };

    window.r40RemoveSignoff = function () {
        if (!state.runId) return;
        post('/Rule40/RemoveSignoff', { clientId: state.clientId, runId: state.runId, comment: '' })
            .then(function (d) {
                if (!d.success) { setStatus('r40SignoffStatus', d.error || 'Remove failed.', 'error'); return; }
                loadWorkspace(state.clientId);
            });
    };

    // ── Save workspace ────────────────────────────────────────────────────────
    window.r40SaveWorkspace = function () {
        if (!state.clientId || !state.runId) {
            setStatus('r40SaveStatus', 'Run validation first.', 'error'); return;
        }
        setStatus('r40SaveStatus', 'Saving…', 'info');
        post('/Rule40/SaveWorkspace', {
            clientId: state.clientId, runId: state.runId,
            server: state.server, database: state.database, driver: state.driver,
            valpacTable: state.valpacTable, asciiTable: state.asciiTable
        }).then(function (d) {
            if (!d.success) { setStatus('r40SaveStatus', d.message || d.error || 'Save failed.', 'error'); return; }
            setStatus('r40SaveStatus', 'Workspace saved.', 'success');
            if (d.workspace) {
                showBanner(d.workspace);
                renderSignoff(d.workspace);
                show('r40SignoffCard');
            }
        });
    };

    // ── Downloads ─────────────────────────────────────────────────────────────
    window.r40Download = function (type) {
        if (!state.runId) { alert('Run and save validation first.'); return; }
        var url      = type === 'excel' ? '/Rule40/DownloadExcel' : '/Rule40/DownloadCsv';
        var filename = type === 'excel' ? 'Rule40_PROF_Agreement.xlsx' : 'Rule40_PROF_Agreement.csv';
        fetchDownload(url, { clientId: state.clientId, runId: state.runId, comment: '' }, filename);
    };

    function fetchDownload(url, body, filename) {
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
            body: JSON.stringify(body)
        }).then(function (r) { return r.blob(); })
          .then(function (blob) {
            var a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = filename;
            a.click();
            URL.revokeObjectURL(a.href);
        });
    }

    // ── SQL ───────────────────────────────────────────────────────────────────
    window.r40GenerateSql = function () {
        post('/Rule40/GenerateSql', buildRequest())
            .then(function (d) {
                if (!d.success) { alert(d.error || 'Could not generate SQL.'); return; }
                el('r40SqlText').value = d.sql || '';
                el('r40SqlModal').style.display = 'flex';
            });
    };

    window.r40DownloadSql = function () {
        fetchDownload('/Rule40/DownloadSql', buildRequest(), 'Rule40_PROF_Agreement.sql');
    };

    // ── Utilities ─────────────────────────────────────────────────────────────
    function buildRequest() {
        return {
            clientId: state.clientId, runId: state.runId,
            server: state.server, database: state.database, driver: state.driver,
            valpacTable: state.valpacTable, asciiTable: state.asciiTable
        };
    }

    function post(url, body) {
        return fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
            body: JSON.stringify(body)
        }).then(function (r) { return r.json(); });
    }

    function getAntiForgeryToken() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    function el(id) { return document.getElementById(id); }
    function show(id) { var e = el(id); if (e) e.style.display = ''; }
    function hide(id) { var e = el(id); if (e) e.style.display = 'none'; }
    function setText(id, val) { var e = el(id); if (e) e.textContent = val; }
    function esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function fmt(n) { return (n || 0).toLocaleString(); }
    function opt(val, label) { var o = document.createElement('option'); o.value = val; o.textContent = label; return o; }

    function setStatus(id, msg, type) {
        var e = el(id);
        if (!e) return;
        e.innerHTML = msg;
        e.className = 'status-msg' + (type === 'error' ? ' status-msg--error' : type === 'success' ? ' status-msg--success' : type === 'info' ? ' status-msg--info' : '');
    }
}());
</script>

@Html.AntiForgeryToken()
