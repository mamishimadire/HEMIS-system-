@using HemisAudit.ViewModels
@model Rule41RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 60 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload = ViewBag.CanDownloadSavedRun is bool d && d;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool o && o;
    var isArchived = ViewBag.IsArchived is bool a && a;
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
    var summary = Model.Summary ?? new Rule41ValidationSummary();
    var pairs = summary.Reconc?.Pairs ?? new List<Rule41ColumnPair>();
    var exceptionRows = summary.Reconc?.ExceptionRows ?? new List<Rule41ReconcRow>();
    var agreeRows = summary.Reconc?.Rows ?? new List<Rule41ReconcRow>();
}

<style>
    .r60-summary-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(210px, 1fr)); }
    .r60-summary-card { background:#fff; border:1px solid #e5e7eb; border-radius:16px; padding:18px; box-shadow:0 14px 32px rgba(15, 23, 42, .05); }
    .r60-table-wrap { overflow-x:auto; }
    .r60-table { border-collapse:collapse; width:100%; min-width:920px; font-size:12px; font-family:Consolas, monospace; }
    .r60-table th,.r60-table td { border:1px solid #ddd; padding:6px 8px; text-align:center; vertical-align:middle; }
    .r60-table thead th { background:#0f172a; color:#fff; position:sticky; top:0; }
    .r60-table tbody tr.agree { background:#f3fff3; }
    .r60-table tbody tr.disagree { background:#fff3f3; }
    .r60-table tbody tr.missing { background:#fff8e7; }
</style>

@if (TempData["Success"] != null) { <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div> }

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<div class="page-header">
    <div>
        <h1>Rule 60 — Saved Run #@Model.RunId</h1>
        <p>@Model.EngagementName &nbsp;|&nbsp; @Model.MaconomyNumber &nbsp;|&nbsp; @((summary.Timestamp) ?? "")</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        @if (canOpenWorkspace) { <a href="/Rule60?clientId=@Model.ClientId" class="btn btn-secondary">Open Workspace</a> }
        @if (canDownload)
        {
            <a href="/Rule60/DownloadSavedExcel?runId=@Model.RunId" class="btn btn-info">Download Excel</a>
            <a href="/Rule60/DownloadSavedCsv?runId=@Model.RunId" class="btn btn-info">Download CSV</a>
            <a href="/Rule60/DownloadSavedExceptionsCsv?runId=@Model.RunId" class="btn btn-info">Exceptions CSV</a>
            <a href="/Rule60/DownloadSavedSql?runId=@Model.RunId" class="btn btn-secondary">Download SQL</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">This engagement is archived. The saved run is available for review and download only.</div>
}
@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">The data analyst signoff is still outstanding. Assigned users can still review and download this run.</div>
}
@if (!Model.IsCurrentRun)
{
    <div class="alert alert--info" style="margin-bottom:24px">History results are read-only. Signoff is only available on the current run.</div>
}

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Run Summary</h3>
    <div class="r60-summary-grid">
        <div class="r60-summary-card"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>@summary.Database</div></div>
        <div class="r60-summary-card"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule</div><div>Rule 60 — CRSE vs H16CRSE Agreement</div></div>
        <div class="r60-summary-card"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">CRSE Table</div><div>@summary.StudTable</div></div>
        <div class="r60-summary-card"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">H16CRSE Table</div><div>@summary.AuditTable</div></div>
        <div class="r60-summary-card"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Join Keys</div><div>@summary.StudKey &harr; @summary.AuditKey</div></div>
        <div class="r60-summary-card"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div><span class="badge @(summary.Status == "PASS" ? "badge--pass" : "badge--fail")">@summary.Status</span></div></div>
    </div>
    <div class="stats-grid" style="margin-top:16px">
        <div class="stat-card"><div class="stat-card__label">Total Tested</div><div class="stat-card__value">@summary.TotalCount.ToString("N0")</div></div>
        <div class="stat-card stat-card--pass"><div class="stat-card__label">Agree</div><div class="stat-card__value">@summary.AgreeCount.ToString("N0")</div></div>
        <div class="stat-card stat-card--fail"><div class="stat-card__label">Disagree</div><div class="stat-card__value">@summary.DisagreeCount.ToString("N0")</div></div>
        <div class="stat-card stat-card--fail"><div class="stat-card__label">Missing</div><div class="stat-card__value">@summary.MissingCount.ToString("N0")</div></div>
        <div class="stat-card"><div class="stat-card__label">Exception Rate</div><div class="stat-card__value">@summary.ExceptionRate.ToString("F2")%</div></div>
    </div>
</div>

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived && Model.IsCurrentRun)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary">
                @(Model.CurrentUserHasSignedOff ? "Update My Signoff" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>
        @if (Model.CurrentUserHasSignedOff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">Remove Signoff</button>
            </form>
        }
    }
    else if (isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">Signoff controls are disabled for archived engagements.</div>
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead><tr><th>Role</th><th>Reviewer</th><th>Comment</th><th>Signed At</th></tr></thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td><strong>@signoff.ReviewerName</strong><br /><small style="color:#757575">@signoff.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Result Rows</h3>
    <div class="alert alert--info" style="margin-bottom:12px">This view shows the saved reconciliation summary. Use the download buttons for the export files.</div>

    <div style="margin-bottom:18px">
        <h4 style="margin:0 0 10px">Exceptions</h4>
        @if (exceptionRows.Any())
        {
            <div class="r60-table-wrap">
                <table class="r60-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ref</th>
                            @foreach (var pair in pairs)
                            {
                                <th>CRSE @pair.Label</th>
                                <th>H16CRSE @pair.Label</th>
                                <th>Match</th>
                            }
                            <th>Result</th>
                            <th>Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in exceptionRows)
                        {
                            <tr class="@row.OverallResult.ToLowerInvariant()">
                                <td>@row.RowNumber</td>
                                <td><strong>@row.StudentRef</strong></td>
                                @foreach (var pair in pairs)
                                {
                                    row.Fields.TryGetValue(pair.Label, out var field);
                                    <td>@(field?.StudValue ?? "—")</td>
                                    <td>@(field?.AuditValue ?? "—")</td>
                                    <td><span class="badge @(string.Equals(field?.Match, "AGREE", StringComparison.OrdinalIgnoreCase) ? "badge--pass" : string.Equals(field?.Match, "DISAGREE", StringComparison.OrdinalIgnoreCase) ? "badge--fail" : "badge--neutral")">@(field?.Match ?? "—")</span></td>
                                }
                                <td><span class="badge @(row.OverallResult == "AGREE" ? "badge--pass" : row.OverallResult == "DISAGREE" ? "badge--fail" : "badge--neutral")">@row.OverallResult</span></td>
                                <td style="text-align:left">@row.DisagreeDetail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><p>No exceptions recorded for this run.</p></div>
        }
    </div>

    <div>
        <h4 style="margin:0 0 10px">Agree Sample</h4>
        @if (agreeRows.Any())
        {
            <div class="r60-table-wrap">
                <table class="r60-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ref</th>
                            @foreach (var pair in pairs)
                            {
                                <th>CRSE @pair.Label</th>
                                <th>H16CRSE @pair.Label</th>
                                <th>Match</th>
                            }
                            <th>Result</th>
                            <th>Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in agreeRows)
                        {
                            <tr class="@row.OverallResult.ToLowerInvariant()">
                                <td>@row.RowNumber</td>
                                <td><strong>@row.StudentRef</strong></td>
                                @foreach (var pair in pairs)
                                {
                                    row.Fields.TryGetValue(pair.Label, out var field);
                                    <td>@(field?.StudValue ?? "—")</td>
                                    <td>@(field?.AuditValue ?? "—")</td>
                                    <td><span class="badge @(string.Equals(field?.Match, "AGREE", StringComparison.OrdinalIgnoreCase) ? "badge--pass" : string.Equals(field?.Match, "DISAGREE", StringComparison.OrdinalIgnoreCase) ? "badge--fail" : "badge--neutral")">@(field?.Match ?? "—")</span></td>
                                }
                                <td><span class="badge @(row.OverallResult == "AGREE" ? "badge--pass" : row.OverallResult == "DISAGREE" ? "badge--fail" : "badge--neutral")">@row.OverallResult</span></td>
                                <td style="text-align:left">@row.DisagreeDetail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><p>No agreement sample rows available for this run.</p></div>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.GeneratedSql))
{
    <div class="card" style="padding:20px;margin-top:20px">
        <h3 class="section-title" style="margin-top:0">SQL Script</h3>
        <pre style="overflow-x:auto;font-size:12px;background:#0f172a;color:#e2e8f0;padding:16px;border-radius:8px;white-space:pre-wrap">@Model.GeneratedSql</pre>
    </div>
}

