@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 72 - Pharmacy Module";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new List<Client>();
    var selectedClientId = (int)(ViewBag.ClientId ?? 0);
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

@if (isResultsOnlyRole)
{
    <style>
        #phApp > .accordion-stack,
        #phApp > .action-bar { display: none !important; }
    </style>
}

<div id="phApp" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label>Engagement</label>
        <select id="phClientId" onchange="phHandleClientChange(this.value)">
            <option value="0">Select engagement (results saved here)</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id == selectedClientId ? "selected" : null)">@c.Name - @c.FiscalYear</option>
            }
        </select>
        <small>Pharmacy validates QUALIFICATION values from the Pharmacy table against Clinical Production and confirms Surname matching.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">PH</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 72: Pharmacy Qualification &amp; Surname Validation</h1>
            <p class="rule-header__sub">Cross-table validation | QUALIFICATION lookup | Surname confirmation | 100% population test</p>
        </div>
        <div class="rule-header__badge" id="phStatusBadge" style="display:none"></div>
    </div>

    <div class="accordion-stack">

        <div class="accordion-item" id="ph-acc-connection">
            <button class="accordion-toggle" onclick="phToggle('connection')">
                <span class="acc-icon">DB</span>
                <span>Database Connection</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="ph-body-connection">
                <div class="form-grid">
                    <div class="field-group">
                        <label>Server Name</label>
                        <input type="text" id="phServer" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label>Driver</label>
                        <select id="phDriver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group" id="phDbFieldGroup" style="display:none">
                        <label>Database</label>
                        <select id="phDatabase">
                            <option value="">Select database</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary" onclick="phConnect()">Connect</button>
                <div class="status-output" id="phConnectionStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="ph-acc-tables">
            <button class="accordion-toggle" onclick="phToggle('tables')">
                <span class="acc-icon">TB</span>
                <span>Table Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="ph-body-tables" style="display:none">
                <div class="info-box info-box--blue">
                    <strong>Pharmacy Module Logic:</strong> Check that each QUALIFICATION from the Pharmacy table exists in
                    Clinical Production. When found, confirm the Surname matches.
                    PASS = QUALIFICATION found in production; FAIL = missing.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>Pharmacy Table <span class="auto-tag" id="phPharmAutoTag" style="display:none">auto-detected</span></label>
                        <select id="phPharmTable">
                            <option value="">Select table</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Clinical Production Table <span class="auto-tag" id="phProdAutoTag" style="display:none">auto-detected</span></label>
                        <select id="phProdTable">
                            <option value="">Select table</option>
                        </select>
                    </div>
                </div>
                <div class="status-output" id="phTableStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="ph-acc-columns">
            <button class="accordion-toggle" onclick="phToggle('columns')">
                <span class="acc-icon">CL</span>
                <span>Column Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="ph-body-columns" style="display:none">
                <div class="info-box info-box--dark">
                    <strong>Column Selection:</strong> Choose the <code>QUALIFICATION</code> column (used for matching across both tables)
                    and the <code>Surname</code> column (confirmed when QUALIFICATION is found in production).
                    Both columns are read from the Pharmacy table; Surname is also checked against Production.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>QUALIFICATION Column <span class="auto-tag" id="phQualAutoTag" style="display:none">auto-detected</span></label>
                        <select id="phQualCol" onchange="phColChanged()">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Surname Column <span class="auto-tag" id="phSurnameAutoTag" style="display:none">auto-detected</span></label>
                        <select id="phSurnameCol" onchange="phColChanged()">
                            <option value="">Select column</option>
                        </select>
                    </div>
                </div>
                <div style="margin-top:10px">
                    <button class="btn btn-secondary" onclick="phAutoDetect()">Auto-Detect Columns</button>
                </div>
                <div id="phColumnPreview" class="validation-preview" style="display:none;margin-top:12px"></div>
            </div>
        </div>

    </div>

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 72 connection, configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="phWorkspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="phWorkspaceInfo" class="alert alert--info">
            Select an engagement to load the last saved Rule 72 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div class="field-group">
                <label id="phSignoffLabel">Signoff Comment</label>
                <textarea id="phSignoffComment" placeholder="Add the final review note that confirms this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            <button class="btn btn-success" id="phSaveWorkspaceBtn" onclick="phSaveWorkspace()">Save Workspace</button>
            <button class="btn btn-primary" id="phSignOffBtn" onclick="phSignOff()" style="display:none">Sign Off</button>
            <button class="btn btn-warning" id="phRemoveSignoffBtn" onclick="phRemoveSignoff()" style="display:none">Remove Signoff</button>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-info" onclick="phVerify()">Verify Tables</button>
        <button class="btn btn-success" id="phRunBtn" onclick="phRun()">Run Validation</button>
        <button class="btn btn-primary" id="phSqlBtn" onclick="phGenerateSql()">Generate SQL</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" onclick="phTab('validation')">Validation Results</button>
            <button class="tab-btn" type="button" onclick="phTab('exceptions')">Exceptions</button>
            <button class="tab-btn" type="button" onclick="phTab('charts')">Charts</button>
            <button class="tab-btn" type="button" onclick="phTab('sql')">SQL Code</button>
        </div>
        <div class="tab-pane active" id="ph-tab-validation">
            <div id="phValidationContent" class="empty-state"><p>Run validation to see results here.</p></div>
        </div>
        <div class="tab-pane" id="ph-tab-exceptions">
            <div id="phExceptionsContent" class="empty-state"><p>No exceptions data yet. Run validation first.</p></div>
        </div>
        <div class="tab-pane" id="ph-tab-charts">
            <div id="phChartsContent" class="empty-state"><p>Charts will appear after running validation.</p></div>
        </div>
        <div class="tab-pane" id="ph-tab-sql">
            <div id="phSqlContent" class="empty-state"><p>Click "Generate SQL" or run validation to generate the SQL script.</p></div>
        </div>
    </div>

    <!-- Progress popup -->
    <div id="phProgressOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;display:none;align-items:center;justify-content:center">
        <div style="background:#fff;border-radius:12px;padding:32px 40px;min-width:320px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.18)">
            <div style="font-size:1.1rem;font-weight:600;margin-bottom:14px" id="phProgressTitle">Processing…</div>
            <div style="background:#e5e7eb;border-radius:99px;height:10px;overflow:hidden;margin-bottom:10px">
                <div id="phProgressBar" style="height:100%;background:#6d28d9;border-radius:99px;width:0%;transition:width .3s ease"></div>
            </div>
            <div style="font-size:.92rem;color:#555" id="phProgressMsg">Please wait…</div>
            <div style="font-size:1.4rem;font-weight:700;color:#6d28d9;margin-top:8px" id="phProgressPct">0%</div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const phRole = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(currentSystemRole));
const phPreviewLimit = 10;
const ph = {
    server: '', database: '', driver: 'ODBC Driver 17 for SQL Server',
    pharmTable: '', prodTable: '',
    qualCol: '', surnameCol: '',
    clientId: parseInt(document.getElementById('phClientId')?.value || '0') || 0,
    runId: null, result: null,
    view: { filter: 'ALL', page: 1, pageSize: phPreviewLimit },
    engRole: '', status: '', signedOff: false, workspaceSaved: false,
    daSignoff: false, resultsVisible: false, dirty: false, hydrating: false,
    editAccepted: false, chartInstances: {},
    pharmCols: [], prodCols: []
};

// ── Progress overlay ───────────────────────────────────────────────────────

let phProgressTimer = null;

function phShowProgress(title, steps) {
    const overlay = document.getElementById('phProgressOverlay');
    overlay.style.display = 'flex';
    document.getElementById('phProgressTitle').textContent = title;
    document.getElementById('phProgressMsg').textContent = steps[0] || 'Starting…';
    document.getElementById('phProgressBar').style.width = '0%';
    document.getElementById('phProgressPct').textContent = '0%';

    let step = 0;
    const total = steps.length;
    phProgressTimer = setInterval(() => {
        step = Math.min(step + 1, total - 1);
        const pct = Math.round((step / (total - 1)) * 90);
        document.getElementById('phProgressBar').style.width = pct + '%';
        document.getElementById('phProgressPct').textContent = pct + '%';
        document.getElementById('phProgressMsg').textContent = steps[step];
    }, 600);
}

function phFinishProgress(msg) {
    clearInterval(phProgressTimer);
    document.getElementById('phProgressBar').style.width = '100%';
    document.getElementById('phProgressPct').textContent = '100%';
    document.getElementById('phProgressMsg').textContent = msg || 'Done';
    setTimeout(() => { document.getElementById('phProgressOverlay').style.display = 'none'; }, 700);
}

function phHideProgress() {
    clearInterval(phProgressTimer);
    document.getElementById('phProgressOverlay').style.display = 'none';
}

// ── Utilities ──────────────────────────────────────────────────────────────

function phToggle(name) {
    const body = document.getElementById(`ph-body-${name}`);
    const chevron = document.querySelector(`#ph-acc-${name} .acc-chevron`);
    if (!body) return;
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    if (chevron) chevron.textContent = open ? 'v' : '^';
}

function phTab(name) {
    document.querySelectorAll('#phApp .tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('#phApp .tab-pane').forEach(p => p.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById(`ph-tab-${name}`)?.classList.add('active');
    if (name === 'charts' && ph.result) phRenderCharts(ph.result);
}

function phSetAlert(elId, type, msg) {
    const el = document.getElementById(elId);
    if (el) el.innerHTML = `<div class="alert alert--${type}">${msg}</div>`;
}

function phEsc(v) {
    return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function phPost(url, data) {
    const resp = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
    return resp.json();
}

async function phGet(url) {
    const resp = await fetch(url, { method: 'GET' });
    return resp.json();
}

function phFillSelect(sel, items, preferred) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select table</option>';
    (items || []).forEach(v => sel.appendChild(new Option(v, v)));
    if (preferred && items.includes(preferred)) sel.value = preferred;
}

function phFillColSelect(sel, cols, preferred) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select column</option>';
    (cols || []).forEach(c => sel.appendChild(new Option(c, c)));
    const match = preferred ? (cols || []).find(c => c.toLowerCase() === preferred.toLowerCase()) : null;
    if (match) sel.value = match;
    else if (cols?.length) sel.value = cols[0];
}

// ── Connection ─────────────────────────────────────────────────────────────

async function phConnect(opts = {}) {
    ph.server = document.getElementById('phServer').value.trim();
    ph.driver = document.getElementById('phDriver').value;
    if (!ph.server) { phSetAlert('phConnectionStatus', 'error', 'Enter a server name.'); return null; }

    if (!opts.silent)
        phShowProgress('Connecting to SQL Server', ['Resolving server name…', 'Opening connection…', 'Listing databases…', 'Connection established']);

    const result = await phPost('/Pharmacy/GetDatabases', { server: ph.server, driver: ph.driver });
    if (!opts.silent) phFinishProgress('Connected');

    if (!result.success) { phSetAlert('phConnectionStatus', 'error', `Error: ${phEsc(result.error)}`); return null; }

    const dbSel = document.getElementById('phDatabase');
    dbSel.innerHTML = '<option value="">Select database</option>';
    (result.databases || []).forEach(db => dbSel.appendChild(new Option(db, db)));
    document.getElementById('phDbFieldGroup').style.display = 'block';

    if (opts.preferredDatabase && (result.databases || []).includes(opts.preferredDatabase)) {
        dbSel.value = opts.preferredDatabase;
        ph.database = opts.preferredDatabase;
    }

    phSetAlert('phConnectionStatus', 'success', opts.statusMessage || `Connected. Found ${result.databases?.length || 0} database(s). Select one below.`);
    return result;
}

async function phLoadTables(opts = {}) {
    ph.database = document.getElementById('phDatabase').value;
    if (!ph.database) return null;

    if (!opts.silent)
        phShowProgress('Loading tables', ['Connecting to database…', 'Querying INFORMATION_SCHEMA…', 'Auto-detecting table names…', 'Table list ready']);

    const result = await phPost('/Pharmacy/GetTables', { server: ph.server, database: ph.database, driver: ph.driver });
    if (!opts.silent) phFinishProgress('Tables loaded');

    if (!result.success) { phSetAlert('phConnectionStatus', `error`, `Error: ${phEsc(result.error)}`); return null; }

    phSetAlert('phConnectionStatus', 'success', `Connected to <strong>${phEsc(ph.database)}</strong>. Found ${result.tables?.length || 0} tables.`);

    phFillSelect(document.getElementById('phPharmTable'), result.tables || [], opts.preferredPharm || result.autoPharmacyTable || '');
    phFillSelect(document.getElementById('phProdTable'), result.tables || [], opts.preferredProd || result.autoProductionTable || '');

    const pharmSel = document.getElementById('phPharmTable');
    const prodSel = document.getElementById('phProdTable');
    ph.pharmTable = pharmSel.value;
    ph.prodTable = prodSel.value;

    document.getElementById('phPharmAutoTag').style.display = ph.pharmTable && ph.pharmTable === result.autoPharmacyTable ? 'inline' : 'none';
    document.getElementById('phProdAutoTag').style.display = ph.prodTable && ph.prodTable === result.autoProductionTable ? 'inline' : 'none';

    document.getElementById('ph-body-tables').style.display = 'block';
    document.querySelector('#ph-acc-tables .acc-chevron').textContent = '^';

    if (ph.pharmTable || ph.prodTable)
        await phLoadColumns(opts);

    return result;
}

async function phLoadColumns(opts = {}) {
    const pharmTable = document.getElementById('phPharmTable').value;
    const prodTable = document.getElementById('phProdTable').value;

    if (!ph.server || !ph.database) return;

    if (!opts.silent)
        phShowProgress('Detecting columns', [
            'Reading Pharmacy table schema…', 'Reading Production table schema…',
            'Matching QUALIFICATION column…', 'Matching Surname column…', 'Column detection complete'
        ]);

    const pharmCols = pharmTable ? await phPost('/Pharmacy/GetColumns', {
        server: ph.server, database: ph.database, driver: ph.driver, tableName: pharmTable
    }) : { success: false, columns: [] };

    const prodCols = prodTable ? await phPost('/Pharmacy/GetColumns', {
        server: ph.server, database: ph.database, driver: ph.driver, tableName: prodTable
    }) : { success: false, columns: [] };

    if (!opts.silent) phFinishProgress('Columns ready');

    ph.pharmCols = pharmCols.columns || [];
    ph.prodCols = prodCols.columns || [];

    // QUALIFICATION comes from pharmacy table; Surname also from pharmacy (confirmed against production)
    // Fill qual dropdown from pharmacy columns; surname dropdown from pharmacy columns
    const allCols = [...new Set([...ph.pharmCols, ...ph.prodCols])];

    phFillColSelect(document.getElementById('phQualCol'), allCols, opts.preferredQual || 'QUALIFICATION');
    phFillColSelect(document.getElementById('phSurnameCol'), allCols, opts.preferredSurname || 'Surname');

    ph.qualCol = document.getElementById('phQualCol').value;
    ph.surnameCol = document.getElementById('phSurnameCol').value;

    const qualAuto = allCols.find(c => c.toLowerCase() === 'qualification');
    const surnameAuto = allCols.find(c => c.toLowerCase() === 'surname');
    document.getElementById('phQualAutoTag').style.display = qualAuto ? 'inline' : 'none';
    document.getElementById('phSurnameAutoTag').style.display = surnameAuto ? 'inline' : 'none';

    document.getElementById('ph-body-columns').style.display = 'block';
    document.querySelector('#ph-acc-columns .acc-chevron').textContent = '^';

    phUpdatePreview();
}

function phColChanged() {
    ph.qualCol = document.getElementById('phQualCol').value;
    ph.surnameCol = document.getElementById('phSurnameCol').value;
    phUpdatePreview();
}

function phUpdatePreview() {
    ph.qualCol = document.getElementById('phQualCol').value;
    ph.surnameCol = document.getElementById('phSurnameCol').value;
    ph.pharmTable = document.getElementById('phPharmTable').value;
    ph.prodTable = document.getElementById('phProdTable').value;

    const preview = document.getElementById('phColumnPreview');
    if (!ph.qualCol || !ph.surnameCol || !ph.pharmTable || !ph.prodTable) {
        preview.style.display = 'none';
        return;
    }
    preview.style.display = 'block';
    preview.innerHTML = `
        <div class="preview-inner">
            <strong>Validation Logic:</strong><br>
            PASS: <code>[${phEsc(ph.pharmTable)}].[${phEsc(ph.qualCol)}]</code> found in <code>[${phEsc(ph.prodTable)}].[${phEsc(ph.qualCol)}]</code><br>
            Then confirm <code>[${phEsc(ph.pharmTable)}].[${phEsc(ph.surnameCol)}]</code> matches <code>[${phEsc(ph.prodTable)}].[${phEsc(ph.surnameCol)}]</code><br>
            FAIL: QUALIFICATION not found in production table.
        </div>`;
}

async function phAutoDetect() {
    const pharmTable = document.getElementById('phPharmTable').value;
    const prodTable = document.getElementById('phProdTable').value;

    if (!pharmTable && !prodTable) {
        phSetAlert('phColumnPreview', 'warning', 'Select at least one table first.');
        document.getElementById('phColumnPreview').style.display = 'block';
        return;
    }

    await phLoadColumns({ preferredQual: 'QUALIFICATION', preferredSurname: 'Surname' });
    phSetAlert('phColumnPreview', 'success', `Column detection complete. You can change the selected columns using the dropdowns above.`);
    document.getElementById('phColumnPreview').style.display = 'block';
}

// ── Verify / Run ───────────────────────────────────────────────────────────

async function phVerify() {
    if (!phValidate()) return;
    phShowProgress('Verifying tables', ['Connecting…', 'Counting Pharmacy records…', 'Counting Production records…', 'Comparing QUALIFICATION values…', 'Verification complete']);
    const result = await phPost('/Pharmacy/VerifyTables', phBuildRequest());
    phFinishProgress('Verification done');
    if (!result.success) { phSetAlert('phTableStatus', 'error', `Error: ${phEsc(result.error)}`); return; }
    phSetAlert('phTableStatus', 'success',
        `<strong>Verification Complete</strong><br>
        ${phEsc(ph.pharmTable)}: <strong>${(result.pharmacyRecordCount || 0).toLocaleString()}</strong> records<br>
        ${phEsc(ph.prodTable)}: <strong>${(result.productionRecordCount || 0).toLocaleString()}</strong> records<br>
        QUALIFICATION matches: <strong class="${result.matchedCount > 0 ? 'text-success' : 'text-danger'}">${(result.matchedCount || 0).toLocaleString()}</strong> |
        Missing: <strong class="${result.missingCount > 0 ? 'text-danger' : 'text-success'}">${(result.missingCount || 0).toLocaleString()}</strong><br>
        <em>Ready to run full validation.</em>`);
    document.getElementById('ph-body-tables').style.display = 'block';
}

async function phRun() {
    if (phRole !== 'DataAnalyst') { phSetWsInfo('Only the assigned data analyst can run Rule 72.', 'error'); return; }
    if (!phValidate()) return;

    phShowProgress('Running Pharmacy validation', [
        'Connecting to SQL Server…',
        'Loading Production qualification codes…',
        'Building reference index…',
        'Scanning Pharmacy records…',
        'Comparing QUALIFICATION values…',
        'Confirming Surname matches…',
        'Calculating exception rate…',
        'Saving run to system database…',
        'Finalising results…'
    ]);

    const result = await phPost('/Pharmacy/RunValidation', phBuildRequest());
    phFinishProgress(result.success ? 'Validation complete' : 'Validation error');

    if (!result.success) {
        const el = document.getElementById('phValidationContent');
        el.classList.remove('empty-state');
        el.innerHTML = `<div class="alert alert--error">Error: ${phEsc(result.error)}</div>`;
        phTab('validation');
        return;
    }

    phApplyResult(result);
}

function phApplyResult(result, opts = {}) {
    ph.result = result;
    ph.view = { filter: 'ALL', page: 1, pageSize: phPreviewLimit };
    if (!opts.fromWorkspace) ph.runId = result.savedRunId || ph.runId;
    ph.signedOff = opts.fromWorkspace ? !!ph.signedOff : false;
    ph.daSignoff = opts.fromWorkspace ? !!ph.daSignoff : false;
    if (!opts.fromWorkspace) ph.editAccepted = false;
    ph.dirty = false;

    phUpdateBadge(result.status);
    phRenderValidation(result);
    phRenderExceptions(result);
    if (opts.switchToValidation !== false) phTab('validation');
    phRenderState();
}

// ── Render helpers ─────────────────────────────────────────────────────────

function phUpdateBadge(status) {
    const b = document.getElementById('phStatusBadge');
    if (!b) return;
    if (!status) { b.style.display = 'none'; return; }
    b.style.display = 'inline-block';
    b.className = `rule-header__badge ${status === 'PASS' ? 'badge--pass' : 'badge--fail'}`;
    b.textContent = status.toUpperCase();
}

function phFilterRows(rows, f) {
    return f === 'PASS' || f === 'FAIL' ? rows.filter(r => r.status === f) : rows;
}

function phRenderValidation(r) {
    const rate = parseFloat(r.exceptionRate);
    const rateColor = rate > 5 ? '#C62828' : rate > 1 ? '#E65100' : '#2E7D32';
    const allRows = r.reviewRows || [];
    const filtered = phFilterRows(allRows, ph.view.filter);
    const pageSize = phPreviewLimit;
    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
    const page = Math.min(Math.max(ph.view.page || 1, 1), totalPages);
    ph.view.page = page;
    const start = (page - 1) * pageSize;
    const pageRows = filtered.slice(start, start + pageSize);

    const rowsHtml = pageRows.length === 0
        ? `<div class="alert alert--info">No rows match the selected filter.</div>`
        : `<div class="results-table-shell"><div class="table-wrapper">
            <table class="data-table">
                <thead><tr><th>#</th><th>Result</th><th>Pharmacy QUAL</th><th>Pharmacy Surname</th><th>Production QUAL</th><th>Production Surname</th></tr></thead>
                <tbody>${pageRows.map((row, i) => `
                    <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
                        <td>${start + i + 1}</td>
                        <td><span class="badge badge--${row.status === 'PASS' ? 'pass' : 'fail'}">${phEsc(row.status)}</span></td>
                        <td>${phEsc(row.pharmacyQualification)}</td>
                        <td>${phEsc(row.pharmacySurname)}</td>
                        <td>${phEsc(row.productionQualification)}</td>
                        <td>${phEsc(row.productionSurname)}</td>
                    </tr>`).join('')}
                </tbody>
            </table></div>
            <div class="table-footer">${filtered.length.toLocaleString()} row(s) after filter. Showing ${start + 1}–${start + pageRows.length}.</div>
        </div>`;

    document.getElementById('phValidationContent').classList.remove('empty-state');
    document.getElementById('phValidationContent').innerHTML = `
        <div class="stats-grid">
            <div class="stat-card"><div class="stat-card__label">Records Validated</div><div class="stat-card__value">${r.totalValidated.toLocaleString()}</div></div>
            <div class="stat-card stat-card--pass"><div class="stat-card__label">PASS</div><div class="stat-card__value">${r.passCount.toLocaleString()}</div></div>
            <div class="stat-card stat-card--fail"><div class="stat-card__label">FAIL</div><div class="stat-card__value">${r.failCount.toLocaleString()}</div></div>
            <div class="stat-card"><div class="stat-card__label">Exception Rate</div><div class="stat-card__value" style="color:${rateColor}">${rate.toFixed(2)}%</div></div>
        </div>
        <div class="overall-status ${r.status === 'PASS' ? 'status--pass' : 'status--fail'}">
            ${r.status === 'PASS'
                ? 'VALIDATION PASSED — All Pharmacy QUALIFICATION codes found in Clinical Production'
                : `VALIDATION FAILED — ${r.failCount.toLocaleString()} QUALIFICATION code(s) missing from Clinical Production`}
        </div>
        ${r.warning ? `<div class="alert alert--warning" style="margin-top:10px">${phEsc(r.warning)}</div>` : ''}
        <div class="results-table-panel" style="margin-top:16px">
            <div class="panel-title-row">
                <h4>Validation Rows</h4>
                <span class="panel-title-badge">${filtered.length.toLocaleString()} rows (preview)</span>
            </div>
            <div class="validation-toolbar">
                <div class="validation-toolbar__group">
                    <label>Filter</label>
                    <select onchange="phSetFilter(this.value)">
                        <option value="ALL" ${ph.view.filter === 'ALL' ? 'selected' : ''}>All</option>
                        <option value="PASS" ${ph.view.filter === 'PASS' ? 'selected' : ''}>PASS</option>
                        <option value="FAIL" ${ph.view.filter === 'FAIL' ? 'selected' : ''}>FAIL</option>
                    </select>
                </div>
                <div class="validation-pager">
                    <button class="btn btn-sm btn-info" onclick="phSetPage(-1)" ${page <= 1 ? 'disabled' : ''}>Prev</button>
                    <span class="validation-pager__status">Page ${page} of ${totalPages}</span>
                    <button class="btn btn-sm btn-info" onclick="phSetPage(1)" ${page >= totalPages ? 'disabled' : ''}>Next</button>
                </div>
            </div>
            ${rowsHtml}
        </div>`;
}

function phRenderExceptions(r) {
    const el = document.getElementById('phExceptionsContent');
    el.classList.remove('empty-state');
    if (r.failCount === 0) {
        el.innerHTML = '<div class="alert alert--success">No exceptions — all QUALIFICATION codes found in Clinical Production.</div>';
        return;
    }
    const rows = (r.reviewRows || []).filter(x => x.status === 'FAIL').slice(0, 50);
    el.innerHTML = `
        <div class="results-table-shell"><div class="table-wrapper">
        <table class="data-table">
            <thead><tr><th>#</th><th>Pharmacy QUAL</th><th>Pharmacy Surname</th><th>Result</th></tr></thead>
            <tbody>${rows.map((row, i) => `
                <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
                    <td>${i + 1}</td>
                    <td><strong>${phEsc(row.pharmacyQualification)}</strong></td>
                    <td>${phEsc(row.pharmacySurname)}</td>
                    <td><span class="badge badge--fail">FAIL</span></td>
                </tr>`).join('')}
            </tbody>
        </table></div>
        <div class="table-footer">${r.failCount.toLocaleString()} exception(s) total. Showing up to 50.</div>
        </div>`;
}

function phRenderCharts(r) {
    Object.values(ph.chartInstances).forEach(c => c.destroy());
    ph.chartInstances = {};
    const rate = parseFloat(r.exceptionRate);
    const rateColor = rate > 5 ? '#C62828' : rate > 1 ? '#E65100' : '#2E7D32';
    const el = document.getElementById('phChartsContent');
    el.classList.remove('empty-state');
    el.innerHTML = `
        <div class="charts-grid">
            <div class="chart-card"><h4>Validation Results</h4><canvas id="phChartPassFail"></canvas></div>
            <div class="chart-card"><h4>Exception Rate: ${rate.toFixed(2)}%</h4><canvas id="phChartRate"></canvas></div>
            <div class="chart-card chart-card--status ${r.status === 'PASS' ? 'chart-card--pass' : 'chart-card--fail'}">
                <h4>Validation Status</h4><div class="big-status">${r.status}</div>
            </div>
            <div class="chart-card"><h4>Summary</h4>
                <div class="summary-text">
                    <div><span>Total Records</span><strong>${r.totalValidated.toLocaleString()}</strong></div>
                    <div><span>PASS</span><strong class="text-success">${r.passCount.toLocaleString()}</strong></div>
                    <div><span>FAIL</span><strong class="text-danger">${r.failCount.toLocaleString()}</strong></div>
                    <div><span>Exception Rate</span><strong style="color:${rateColor}">${rate.toFixed(2)}%</strong></div>
                </div>
            </div>
        </div>`;
    ph.chartInstances.passFail = new Chart(document.getElementById('phChartPassFail'), {
        type: 'bar',
        data: { labels: ['PASS', 'FAIL'], datasets: [{ data: [r.passCount, r.failCount], backgroundColor: ['#4CAF50', '#F44336'], borderWidth: 0 }] },
        options: { maintainAspectRatio: false, responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
    ph.chartInstances.rate = new Chart(document.getElementById('phChartRate'), {
        type: 'bar',
        data: { labels: ['Exception Rate'], datasets: [
            { data: [rate], backgroundColor: [rateColor], label: 'Exception %' },
            { data: [Math.max(0, 100 - rate)], backgroundColor: ['#E0E0E0'], label: 'Pass %' }
        ]},
        options: { indexAxis: 'y', maintainAspectRatio: false, responsive: true, plugins: { legend: { display: false } }, scales: { x: { stacked: true, max: 100 }, y: { stacked: true } } }
    });
}

function phSetFilter(f) {
    ph.view.filter = f; ph.view.page = 1;
    if (ph.result) phRenderValidation(ph.result);
}

function phSetPage(delta) {
    if (!ph.result) return;
    ph.view.page = Math.max(1, (ph.view.page || 1) + delta);
    phRenderValidation(ph.result);
}

// ── SQL ────────────────────────────────────────────────────────────────────

async function phGenerateSql() {
    if (phRole !== 'DataAnalyst') { phSetWsInfo('Only the assigned data analyst can generate SQL.', 'error'); return; }
    if (!phValidate()) return;
    phShowProgress('Generating SQL', ['Building validation query…', 'Formatting SQL…', 'SQL ready']);
    const result = await phPost('/Pharmacy/GenerateSql', phBuildRequest());
    phFinishProgress('SQL generated');
    if (!result.success) return;
    const el = document.getElementById('phSqlContent');
    el.classList.remove('empty-state');
    el.innerHTML = `
        <div class="sql-toolbar">
            <button class="btn btn-sm btn-primary" onclick="phCopy('phSqlCode')">Copy</button>
        </div>
        <div class="sql-panel"><pre id="phSqlCode" class="sql-block">${phEsc(result.sql)}</pre></div>`;
    phTab('sql');
}

function phCopy(id) {
    const text = document.getElementById(id)?.textContent || '';
    navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard!'));
}

// ── Workspace save / signoff ───────────────────────────────────────────────

async function phSaveWorkspace() {
    if (phRole !== 'DataAnalyst') { phSetWsInfo('Only the assigned data analyst can save this workspace.', 'error'); return; }
    if (!ph.clientId) { phSetWsInfo('Select an engagement first.', 'error'); return; }
    phShowProgress('Saving workspace', ['Connecting to system database…', 'Writing workspace configuration…', 'Workspace saved']);
    const result = await phPost('/Pharmacy/SaveWorkspace', phBuildRequest());
    phFinishProgress(result.success ? 'Saved' : 'Error');
    if (!result.success) { phSetWsInfo(`Error: ${phEsc(result.error || 'Failed to save.')}`, 'error'); return; }
    ph.workspaceSaved = true;
    ph.dirty = false;
    phSetWsInfo(result.message || 'Workspace saved successfully.', 'success');
    phRenderState();
}

async function phSignOff() {
    if (!ph.runId) { phSetWsInfo('Run validation first so the workspace can be signed off.', 'warning'); return; }
    if (!ph.workspaceSaved) { phSetWsInfo('Save the workspace first before signing off.', 'warning'); return; }
    phShowProgress('Saving signoff', ['Verifying analyst…', 'Writing signoff…', 'Signoff recorded']);
    const result = await phPost('/Pharmacy/SaveWorkspace', {
        ...phBuildRequest(),
        signoffComment: document.getElementById('phSignoffComment').value.trim()
    });
    phFinishProgress('Signed off');
    if (!result.success) { phSetWsInfo(`Error: ${phEsc(result.error || 'Failed to sign off.')}`, 'error'); return; }
    ph.signedOff = true;
    phSetWsInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
    phRenderState();
}

async function phRemoveSignoff() {
    phShowProgress('Removing signoff', ['Verifying…', 'Removing signoff…', 'Done']);
    const result = await phPost('/Pharmacy/SaveWorkspace', phBuildRequest());
    phFinishProgress('Removed');
    ph.signedOff = false;
    phSetWsInfo('Signoff removed.', 'warning');
    phRenderState();
}

// ── State management ───────────────────────────────────────────────────────

function phSetWsRunState(text, type) {
    const el = document.getElementById('phWorkspaceRunState');
    if (!el) return;
    el.className = `badge badge--${type} badge--sm`;
    el.textContent = text;
}

function phSetWsInfo(msg, type) {
    const el = document.getElementById('phWorkspaceInfo');
    if (!el) return;
    el.className = `alert alert--${type}`;
    el.innerHTML = msg;
}

function phRenderState() {
    const canEdit = phRole === 'DataAnalyst';
    const saveBtn = document.getElementById('phSaveWorkspaceBtn');
    const signBtn = document.getElementById('phSignOffBtn');
    const removeBtn = document.getElementById('phRemoveSignoffBtn');
    if (saveBtn) saveBtn.disabled = !canEdit || ph.signedOff;
    if (signBtn) {
        signBtn.style.display = canEdit && ph.runId ? 'inline-flex' : 'none';
        signBtn.disabled = !ph.workspaceSaved || ph.dirty || ph.signedOff;
        signBtn.textContent = ph.signedOff ? 'Signed Off' : 'Sign Off';
    }
    if (removeBtn) removeBtn.style.display = canEdit && ph.signedOff ? 'inline-flex' : 'none';

    if (!ph.clientId) { phSetWsRunState('No engagement selected', 'neutral'); phSetWsInfo('Select an engagement to load the last saved Rule 72 workspace.', 'info'); return; }
    if (!ph.runId) { phSetWsRunState('No saved run loaded', 'neutral'); phSetWsInfo(canEdit ? 'No saved workspace yet. Connect, configure, run validation, then save.' : 'No saved workspace for this engagement yet.', 'info'); return; }
    if (ph.dirty) { phSetWsRunState(`Run #${ph.runId} — unsaved changes`, 'warning'); phSetWsInfo(`Saved run <strong>#${ph.runId}</strong> is loaded but the current screen has unsaved changes.`, 'warning'); return; }
    if (ph.signedOff) { phSetWsRunState(`Run #${ph.runId} signed off`, 'success'); phSetWsInfo(`Saved run <strong>#${ph.runId}</strong> is signed off and available for review.`, 'success'); return; }
    phSetWsRunState(`Run #${ph.runId} saved`, 'info');
    phSetWsInfo(canEdit ? `Saved run <strong>#${ph.runId}</strong> is loaded. Save and sign off to make results visible to other roles.` : `Saved run <strong>#${ph.runId}</strong> is awaiting analyst signoff.`, 'info');
}

function phReset(clearClient) {
    ph.server = ''; ph.database = ''; ph.driver = 'ODBC Driver 17 for SQL Server';
    ph.pharmTable = ''; ph.prodTable = ''; ph.qualCol = ''; ph.surnameCol = '';
    ph.runId = null; ph.result = null;
    ph.view = { filter: 'ALL', page: 1, pageSize: phPreviewLimit };
    ph.engRole = ''; ph.status = ''; ph.signedOff = false; ph.workspaceSaved = false;
    ph.daSignoff = false; ph.resultsVisible = false; ph.dirty = false;
    ph.editAccepted = false; ph.pharmCols = []; ph.prodCols = [];
    if (clearClient) ph.clientId = 0;

    Object.values(ph.chartInstances).forEach(c => c.destroy());
    ph.chartInstances = {};

    ['phServer','phSignoffComment'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    document.getElementById('phDriver').value = 'ODBC Driver 17 for SQL Server';
    document.getElementById('phDatabase').innerHTML = '<option value="">Select database</option>';
    document.getElementById('phDbFieldGroup').style.display = 'none';
    ['phPharmTable','phProdTable','phQualCol','phSurnameCol'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<option value="">Select table</option>';
    });
    ['phPharmAutoTag','phProdAutoTag','phQualAutoTag','phSurnameAutoTag'].forEach(id => {
        const el = document.getElementById(id); if (el) el.style.display = 'none';
    });
    document.getElementById('phColumnPreview').style.display = 'none';
    document.getElementById('phConnectionStatus').innerHTML = '';
    document.getElementById('phTableStatus').innerHTML = '';
    document.getElementById('phValidationContent').className = 'empty-state';
    document.getElementById('phValidationContent').innerHTML = '<p>Run validation to see results here.</p>';
    document.getElementById('phExceptionsContent').className = 'empty-state';
    document.getElementById('phExceptionsContent').innerHTML = '<p>No exceptions data yet. Run validation first.</p>';
    document.getElementById('phChartsContent').className = 'empty-state';
    document.getElementById('phChartsContent').innerHTML = '<p>Charts will appear after running validation.</p>';
    document.getElementById('phSqlContent').className = 'empty-state';
    document.getElementById('phSqlContent').innerHTML = '<p>Click "Generate SQL" or run validation to generate the SQL script.</p>';
    phUpdateBadge('');
    phRenderState();
}

async function phHandleClientChange(value) {
    ph.clientId = parseInt(value || '0') || 0;
    phReset();
    if (!ph.clientId) return;
    await phLoadWorkspace();
}

async function phLoadWorkspace() {
    if (!ph.clientId) { phRenderState(); return; }
    phShowProgress('Loading workspace', ['Querying system database…', 'Restoring last configuration…', 'Reconnecting to SQL Server…', 'Workspace ready']);
    try {
        const result = await phGet(`/Pharmacy/GetWorkspaceState?clientId=${ph.clientId}`);
        if (!result.success) { phSetWsInfo(`Error: ${phEsc(result.error || 'Failed to load workspace.')}`, 'error'); phHideProgress(); return; }
        if (!result.hasWorkspace || !result.workspace) { phHideProgress(); phRenderState(); return; }
        await phHydrate(result.workspace);
        phFinishProgress('Workspace loaded');
    } catch (err) { phHideProgress(); phSetWsInfo(`Error: ${phEsc(err?.message || 'Failed.')}`, 'error'); }
}

async function phHydrate(ws) {
    ph.hydrating = true;
    try {
        ph.runId = ws.lastRunId || null;
        ph.engRole = ws.currentUserEngagementRole || '';
        ph.status = ws.currentStatus || '';
        ph.signedOff = !!ws.currentUserHasSignedOff;
        ph.workspaceSaved = !!ws.isWorkspaceSaved;
        ph.daSignoff = !!ws.hasDataAnalystSignoff;
        ph.resultsVisible = !!ws.resultsVisible;

        document.getElementById('phServer').value = ws.server || '';
        document.getElementById('phDriver').value = ws.driver || 'ODBC Driver 17 for SQL Server';
        document.getElementById('phSignoffComment').value = ws.currentUserSignoffComment || '';
        ph.server = ws.server || '';
        ph.driver = ws.driver || 'ODBC Driver 17 for SQL Server';

        if (ws.summary && ph.resultsVisible) phApplyResult(ws.summary, { switchToValidation: false, fromWorkspace: true });
        else if (ws.summary) phUpdateBadge(ws.summary.status || '');

        if (ws.server) {
            await phConnect({ preferredDatabase: ws.database || '', silent: true,
                statusMessage: ws.database ? `Connected to <strong>${phEsc(ws.database)}</strong>. Restored from saved workspace.` : 'Reconnected.' });
        }
        if (ws.database) {
            await phLoadTables({
                preferredPharm: ws.pharmacyTable || ws.pharmTable || 'Pharmacy',
                preferredProd: ws.productionTable || 'Clinical_Production',
                preferredQual: ws.qualificationColumn || 'QUALIFICATION',
                preferredSurname: ws.surnameColumn || 'Surname',
                silent: true
            });
        }
    } finally {
        ph.hydrating = false;
        ph.dirty = false;
        phRenderState();
    }
}

// ── Validation helpers ─────────────────────────────────────────────────────

function phValidate() {
    const missing = [];
    if (!ph.clientId) missing.push('engagement');
    if (!ph.server) missing.push('server');
    if (!ph.database) missing.push('database');
    if (!ph.pharmTable) missing.push('Pharmacy table');
    if (!ph.prodTable) missing.push('Production table');
    if (!ph.qualCol) missing.push('QUALIFICATION column');
    if (!ph.surnameCol) missing.push('Surname column');
    if (missing.length) {
        phSetWsInfo(`Please select: ${missing.join(', ')}.`, 'warning');
        return false;
    }
    return true;
}

function phBuildRequest() {
    return {
        clientId: ph.clientId,
        server: ph.server,
        database: ph.database,
        driver: ph.driver,
        pharmacyTable: document.getElementById('phPharmTable').value || ph.pharmTable,
        productionTable: document.getElementById('phProdTable').value || ph.prodTable,
        qualificationColumn: document.getElementById('phQualCol').value || ph.qualCol,
        surnameColumn: document.getElementById('phSurnameCol').value || ph.surnameCol
    };
}

// ── Wire up change events ──────────────────────────────────────────────────

document.addEventListener('DOMContentLoaded', async () => {
    document.getElementById('phServer').addEventListener('input', () => { ph.server = document.getElementById('phServer').value.trim(); });
    document.getElementById('phDriver').addEventListener('change', () => { ph.driver = document.getElementById('phDriver').value; });

    document.getElementById('phDatabase').addEventListener('change', async e => {
        ph.database = e.target.value;
        if (ph.database) await phLoadTables();
    });

    document.getElementById('phPharmTable').addEventListener('change', async e => {
        ph.pharmTable = e.target.value;
        if (ph.pharmTable) {
            phShowProgress('Loading Pharmacy columns', ['Reading schema…', 'Matching column names…', 'Done']);
            const r = await phPost('/Pharmacy/GetColumns', { server: ph.server, database: ph.database, driver: ph.driver, tableName: ph.pharmTable });
            phFinishProgress('Columns loaded');
            ph.pharmCols = r.columns || [];
            const allCols = [...new Set([...ph.pharmCols, ...ph.prodCols])];
            phFillColSelect(document.getElementById('phQualCol'), allCols, 'QUALIFICATION');
            phFillColSelect(document.getElementById('phSurnameCol'), allCols, 'Surname');
            ph.qualCol = document.getElementById('phQualCol').value;
            ph.surnameCol = document.getElementById('phSurnameCol').value;
            document.getElementById('ph-body-columns').style.display = 'block';
            document.querySelector('#ph-acc-columns .acc-chevron').textContent = '^';
            phUpdatePreview();
        }
    });

    document.getElementById('phProdTable').addEventListener('change', async e => {
        ph.prodTable = e.target.value;
        if (ph.prodTable) {
            phShowProgress('Loading Production columns', ['Reading schema…', 'Matching column names…', 'Done']);
            const r = await phPost('/Pharmacy/GetColumns', { server: ph.server, database: ph.database, driver: ph.driver, tableName: ph.prodTable });
            phFinishProgress('Columns loaded');
            ph.prodCols = r.columns || [];
            const allCols = [...new Set([...ph.pharmCols, ...ph.prodCols])];
            phFillColSelect(document.getElementById('phQualCol'), allCols, 'QUALIFICATION');
            phFillColSelect(document.getElementById('phSurnameCol'), allCols, 'Surname');
            ph.qualCol = document.getElementById('phQualCol').value;
            ph.surnameCol = document.getElementById('phSurnameCol').value;
            phUpdatePreview();
        }
    });

    document.getElementById('phQualCol').addEventListener('change', phColChanged);
    document.getElementById('phSurnameCol').addEventListener('change', phColChanged);

    phRenderState();
    if (ph.clientId > 0) await phLoadWorkspace();
});
</script>
