function setValidationFilter(filter) {
    state.validationView = state.validationView || { filter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    state.validationView.filter = filter;
    state.validationView.page = 1;
    if (state.validationResult) renderValidationResults(state.validationResult);
}

function setValidationPage(delta) {
    if (!state.validationResult) return;
    state.validationView = state.validationView || { filter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    state.validationView.page = Math.max(1, (state.validationView.page || 1) + delta);
    renderValidationResults(state.validationResult);
}

function escapeHtml(value) {
    return String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function validateConfig() {
    syncStateFromSelects();
    const missing = [];
    if (!state.clientId)          missing.push('engagement');
    if (!state.server)            missing.push('server');
    if (!state.database)          missing.push('database');
    if (!state.studTable)         missing.push('STUD table');
    if (!state.qualTable)         missing.push('QUAL table');
    if (!state.studIdCol)         missing.push('Student ID column');
    if (!state.studQualCodeCol)   missing.push('STUD Qualification Code column');
    if (!state.studFulfilledCol)  missing.push('STUD Fulfilled Status column');
    if (!state.qualCodeCol)       missing.push('QUAL Code column');
    if (!state.qualNameCol)       missing.push('QUAL Name column');
    if (!state.qualTypeCol)       missing.push('QUAL Type column');
    if (!state.qualApprovalCol)   missing.push('QUAL Approval column');

    if (missing.length) {
        if (!state.clientId) setWorkspaceInfo('Select the approved engagement assigned to you before running this rule.', 'warning');
        setStatus('validationContent', `Please select ${missing.join(', ')} first.`, 'warning');
        switchTab('validation');
        return false;
    }
    return true;
}

function buildRequest() {
    syncStateFromSelects();
    return {
        clientId: state.clientId, runId: state.currentRunId,
        server: state.server, database: state.database, driver: state.driver,
        studTable: state.studTable, studIdCol: state.studIdCol,
        studQualCodeCol: state.studQualCodeCol, studFulfilledCol: state.studFulfilledCol,
        studFulfilledFilterValue: state.studFulfilledFilterValue,
        qualTable: state.qualTable, qualCodeCol: state.qualCodeCol,
        qualNameCol: state.qualNameCol, qualTypeCol: state.qualTypeCol,
        qualApprovalCol: state.qualApprovalCol,
        qualApprovalFilterValue: state.qualApprovalFilterValue,
        pqmTable: state.pqmTable,
        pqmQualNameColumn: state.pqmQualNameCol,
        pqmQualTypeColumn: state.pqmQualTypeCol
    };
}

function fileStamp() {
    return new Date().toISOString().replace(/[:.]/g, '-').replace('T', '_').replace('Z', '');
}

async function downloadExcel() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    await downloadPost('/Rule55/DownloadExcel', state.validationResult, `Rule55_WCode_Validation_${fileStamp()}.xlsx`);
}
async function downloadCsv() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    await downloadPost('/Rule55/DownloadCsv', state.validationResult, `Rule55_WCode_Results_${fileStamp()}.csv`);
}
async function downloadExceptionsCsv() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    await downloadPost('/Rule55/DownloadExceptionsCsv', state.validationResult, `Rule55_WCode_Exceptions_${fileStamp()}.csv`);
}
async function downloadSql() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can download the SQL script.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only. SQL download is disabled.', 'error'); return; }
    if (!validateConfig()) return;
    await downloadPost('/Rule55/DownloadSql', buildRequest(), `Rule55_WCode_Validation_${fileStamp()}.sql`);
}
async function downloadAll() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    const tasks = [];
    if (document.getElementById('chkExcel')?.checked) tasks.push(() => downloadExcel());
    if (document.getElementById('chkCsv')?.checked) tasks.push(() => downloadCsv());
    if (document.getElementById('chkExceptionsCsv')?.checked) tasks.push(() => downloadExceptionsCsv());
    if (currentSystemRole === 'DataAnalyst' && document.getElementById('chkSql')?.checked) tasks.push(() => downloadSql());
    if (!tasks.length) { alert('Select at least one download format.'); return; }
    for (const task of tasks) await task();
}

function copyToClipboard(elId) {
    navigator.clipboard.writeText(document.getElementById(elId).textContent).then(() => alert('Copied to clipboard!'));
}

async function saveWorkspace() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can save this workspace.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only. Saving is disabled.', 'error'); return; }
    if (!state.currentRunId) { setWorkspaceInfo('Run validation first so the workspace can be saved.', 'error'); return; }
    showSpinner('Saving workspace...');
    try {
        const result = await post('/Rule55/SaveWorkspace', buildRequest());
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save workspace.')}`, 'error'); return; }
        state.editWarningAccepted = true;
        state.isDirty = false;
        if (result.workspace) {
            state.currentRunId = result.workspace.runId || state.currentRunId;
            state.currentUserEngagementRole = result.workspace.currentUserEngagementRole || state.currentUserEngagementRole;
            state.currentUserHasSignedOff = !!result.workspace.currentUserHasSignedOff;
            state.hasDataAnalystSignoff = !!result.workspace.hasDataAnalystSignoff;
            state.isWorkspaceSaved = !!result.workspace.isWorkspaceSaved;
            document.getElementById('signoffComment').value = result.workspace.currentUserSignoffComment || document.getElementById('signoffComment').value;
            if (result.workspace.summary) applyValidationResult(result.workspace.summary, { switchToValidation: false, fromWorkspace: true });
        }
        setWorkspaceInfo(result.message || 'Workspace saved.', result.signoffsCleared ? 'warning' : 'success');
        renderWorkspaceState();
    } finally { hideSpinner(); }
}

async function signOffWorkspace() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const canSign = !isArchivedWorkspace() && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    if (!canSign) { setWorkspaceInfo('This workspace can only be signed off by the assigned analyst, manager, or director after the analyst review is available.', 'error'); return; }
    if (!state.isWorkspaceSaved) { setWorkspaceInfo('Save the workspace first before signing off.', 'warning'); return; }
    if (state.isDirty) { setWorkspaceInfo('Save the workspace first. Editing removes signoffs and requires a fresh review.', 'warning'); return; }
    showSpinner('Saving analyst signoff...');
    try {
        const result = await post('/Rule55/SignOffWorkspace', {
            clientId: state.clientId, runId: state.currentRunId,
            comment: document.getElementById('signoffComment').value.trim()
        });
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save signoff.')}`, 'error'); return; }
        const visible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible') ? !!result.resultsVisible : !!result.workspace?.resultsVisible;
        if (result.workspace) { result.workspace.resultsVisible = visible; await hydrateWorkspace(result.workspace); }
        state.isDirty = false;
        setWorkspaceInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
        renderWorkspaceState();
        switchTab('downloads');
    } finally { hideSpinner(); }
}

async function removeWorkspaceSignoff() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const canSign = !isArchivedWorkspace() && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    if (!canSign || !state.currentUserHasSignedOff) { setWorkspaceInfo('There is no signoff for your assigned engagement role to remove.', 'error'); return; }
    showSpinner('Removing signoff...');
    try {
        const result = await post('/Rule55/RemoveWorkspaceSignoff', { clientId: state.clientId, runId: state.currentRunId, comment: '' });
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to remove signoff.')}`, 'error'); return; }
        const visible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible') ? !!result.resultsVisible : !!result.workspace?.resultsVisible;
        if (result.workspace) { result.workspace.resultsVisible = visible; await hydrateWorkspace(result.workspace); }
        setWorkspaceInfo('Signoff removed.', 'warning');
        renderWorkspaceState();
    } finally { hideSpinner(); }
}

document.addEventListener('DOMContentLoaded', async () => {
    document.getElementById('serverInput').addEventListener('input', async () => {
        state.server = document.getElementById('serverInput').value.trim();
        await markWorkspaceDirty();
    });
    document.getElementById('driverSelect').addEventListener('change', async () => {
        state.driver = document.getElementById('driverSelect').value;
        await markWorkspaceDirty();
    });
    document.getElementById('databaseSelect').addEventListener('change', async e => {
        state.database = e.target.value;
        await markWorkspaceDirty();
        await loadTables();
    });
    ['studIdColSelect','studQualCodeColSelect','studFulfilledColSelect',
     'qualCodeColSelect','qualNameColSelect','qualTypeColSelect','qualApprovalColSelect'].forEach(id => {
        document.getElementById(id).addEventListener('change', async () => {
            syncStateFromSelects();
            await markWorkspaceDirty();
        });
    });

    renderWorkspaceState();
    if (state.clientId > 0) await loadWorkspaceState();
});
