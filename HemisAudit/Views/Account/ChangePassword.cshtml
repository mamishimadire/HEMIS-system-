@model HemisAudit.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Change Password</h1>
        <p>Update your account password.</p>
    </div>
</div>

<div class="card" style="max-width:480px">
    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()

        @{
            var passwordStatus = Model.PasswordStatus;
            var passwordAlertClass = passwordStatus.IsExpired
                ? "alert--error"
                : passwordStatus.IsExpiringSoon
                    ? "alert--warning"
                    : "alert--info";
        }
        <div class="alert @passwordAlertClass" style="margin-bottom:16px">
            <div><strong>Current password age:</strong> @passwordStatus.AgeDays day(s)</div>
            <div><strong>Counted from:</strong> @(passwordStatus.ReferenceDateUtc?.ToString("dd MMM yyyy") ?? "Not available")</div>
            @if (passwordStatus.IsExpired)
            {
                <div><strong>Status:</strong> Expired. Change it now.</div>
            }
            else
            {
                <div><strong>Expires in:</strong> @passwordStatus.DaysRemaining day(s) of the @passwordStatus.MaxAgeDays-day policy.</div>
            }
        </div>

        <div class="field-group" style="margin-bottom:14px">
            <label>Current Password</label>
            <input asp-for="CurrentPassword" type="password" />
            <span asp-validation-for="CurrentPassword" class="field-error"></span>
        </div>
        <div class="field-group" style="margin-bottom:14px">
            <label>New Password</label>
            <input asp-for="NewPassword" type="password" />
            <span asp-validation-for="NewPassword" class="field-error"></span>
        </div>
        <div class="field-group" style="margin-bottom:20px">
            <label>Confirm New Password</label>
            <input asp-for="ConfirmPassword" type="password" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>

        <div class="action-bar">
            <button type="submit" class="btn btn-success">Change Password</button>
            <a href="/Dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
