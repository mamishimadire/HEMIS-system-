@model HemisAudit.ViewModels.RenewPasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HEMIS Audit - Change Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <script>
        (function () {
            var theme = localStorage.getItem('hemis-theme') || 'light';
            if (theme === 'light') document.documentElement.classList.add('light');
        })();
    </script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-page">
    <div class="login-wrap">
        <div class="login-card login-card--compact">
            <div class="login-brand">
                <div class="login-brand__icon" aria-hidden="true">H</div>
                <div>
                    <div class="login-brand__title">HEMIS Audit</div>
                    <div class="login-brand__sub">Management System</div>
                </div>
            </div>

            <h2 class="login-heading">Change your password</h2>

            <div class="renew-stepper" aria-label="Password change steps">
                <div class="renew-stepper__item @(Model.ShowVerificationStep ? "is-active" : "is-complete")">
                    <span class="renew-stepper__count">1</span>
                    <span>Confirm old password</span>
                </div>
                <div class="renew-stepper__item @(Model.ShowNewPasswordStep ? "is-active" : string.Empty)">
                    <span class="renew-stepper__count">2</span>
                    <span>Create new password</span>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert--error" style="margin-bottom:16px">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            @if (Model.IsPasswordExpiredFlow)
            {
                <div class="alert alert--warning" style="margin-bottom:16px">
                    @(Model.ShowVerificationStep
                        ? "Your password has expired. Step 1 is to confirm your old password."
                        : "Your old password was confirmed. Step 2 is to create a new password to continue.")
                </div>
            }

            @if (Model.ShowVerificationStep)
            {
                <div class="alert alert--info" style="margin-bottom:16px">
                    Enter your email address and old password first. The system will only allow step 2 after this check passes.
                </div>
            }

            @if (Model.ShowVerificationStep)
            {
                <form asp-action="RenewPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IsPasswordExpiredFlow" type="hidden" />
                    <input asp-for="Step" type="hidden" value="1" />

                    <div class="field-group" style="margin-bottom:14px">
                        <label asp-for="Email">Email address</label>
                        <input asp-for="Email" type="email" placeholder="you@sng.gt.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>

                    <div class="field-group" style="margin-bottom:20px">
                        <label asp-for="CurrentPassword">Old password</label>
                        <input asp-for="CurrentPassword" type="password" placeholder="Current password" autocomplete="current-password" />
                        <span asp-validation-for="CurrentPassword" class="field-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;margin-bottom:12px">
                        Confirm old password ->
                    </button>
                </form>
            }
            else
            {
                <div class="alert alert--success" style="margin-bottom:16px">
                    Old password confirmed. You can now create a new password.
                </div>

                <form asp-action="RenewPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IsPasswordExpiredFlow" type="hidden" />
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="Step" type="hidden" value="2" />
                    <input asp-for="IsVerificationConfirmed" type="hidden" value="true" />

                    <div class="field-group" style="margin-bottom:14px">
                        <label asp-for="Email">Email address</label>
                        <input type="email" value="@Model.Email" autocomplete="email" readonly />
                    </div>

                    <div class="field-group" style="margin-bottom:14px">
                        <label asp-for="NewPassword">New password</label>
                        <input asp-for="NewPassword" type="password" placeholder="New password" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="field-error"></span>
                    </div>

                    <div class="field-group" style="margin-bottom:20px">
                        <label asp-for="ConfirmPassword">Confirm new password</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="Confirm new password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>

                    <div class="alert alert--info" style="margin-bottom:20px">
                        Password must be at least 8 characters and include uppercase, lowercase, a digit, and a special character.
                    </div>

                    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;margin-bottom:12px">
                        Save new password ->
                    </button>
                </form>
            }

            <div style="display:flex; justify-content:space-between; gap:12px; align-items:center;">
                <a href="/Account/Login" style="font-size:12px; text-decoration:none; font-weight:600;">Back to sign in</a>
                <div style="display:flex; gap:12px; align-items:center;">
                    @if (Model.ShowNewPasswordStep)
                    {
                        <a href="/Account/RenewPassword?email=@Uri.EscapeDataString(Model.Email)&expired=@Model.IsPasswordExpiredFlow.ToString().ToLowerInvariant()" style="font-size:12px; text-decoration:none; font-weight:600;">Start again</a>
                    }
                    <a href="/Account/ForgotPassword" style="font-size:12px; text-decoration:none; font-weight:600;">Forgot password?</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
