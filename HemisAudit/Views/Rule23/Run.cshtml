@using System.Text.Json
@model HemisAudit.ViewModels.Rule23RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 23 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload = ViewBag.CanDownloadSavedRun is bool allowed && allowed;
    var canManageEngagement = ViewBag.CanManageEngagement is bool manageEngagement && manageEngagement;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool openWorkspace && openWorkspace;
    var isArchived = ViewBag.IsArchived is bool archived && archived;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    var displayedFailRows = Model.Summary.FailRows.Take(10).ToList();
    var reviewRowsJson = JsonSerializer.Serialize(
        Model.Summary.PassSampleRows
            .Concat(Model.Summary.FailRows)
            .Select(row => new
            {
                validationNumber = row.ValidationNumber,
                studStudentNumber = row.StudStudentNumber,
                studQualificationCode = row.StudQualificationCode,
                studIdNumber = row.StudIdNumber,
                auditStudentNumber = row.AuditStudentNumber,
                auditQualificationCode = row.AuditQualificationCode,
                auditIdNumber = row.AuditIdNumber,
                h16StudentNumber = row.H16StudentNumber,
                h16QualificationCode = row.H16QualificationCode,
                h16IdNumber = row.H16IdNumber,
                reconciliationStatus = row.ReconciliationStatus,
                issueDescription = row.IssueDescription,
                resultType = row.ResultType,
                controlType = row.ControlType
            }));
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<style>
    .code-panel { background:#0f172a; border-radius:18px; color:#e2e8f0; overflow:auto; padding:18px; }
    .code-panel pre { margin:0; white-space:pre-wrap; word-break:break-word; }
</style>

<div class="page-header">
    <div>
        <h1>Rule 23 Saved Run</h1>
        <p>
            @Model.EngagementName
            <span style="padding:0 8px">|</span>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            Run #@Model.RunId
            <span style="padding:0 8px">|</span>
            @Model.Summary.Timestamp
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Back to Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The saved run is available for review and download only.
    </div>
}

@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">
        The data analyst signoff is still outstanding. Assigned users can still review and download this run.
    </div>
}

<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary" disabled="@(Model.CurrentUserHasSignedOff ? "disabled" : null)">
                @(Model.CurrentUserHasSignedOff ? $"Signed Off as {Model.CurrentUserEngagementRole}" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>

        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">Remove Signoff</button>
            </form>
        }
    }
    else if (!Model.IsCurrentRun && !isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">History results are read-only for signoff. Signoff is only available on the current run.</div>
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Reviewer</th>
                    <th>Comment</th>
                    <th>Signed At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td><strong>@signoff.ReviewerName</strong><br /><small style="color:#757575">@signoff.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:0 0 24px">
    <div class="review-tabs" role="tablist" aria-label="Rule 23 review tabs">
        <button type="button" class="review-tab is-active" data-review-tab="analysis">Analysis</button>
        <button type="button" class="review-tab" data-review-tab="exceptions">Exceptions</button>
        <button type="button" class="review-tab" data-review-tab="passes">Pass Sample</button>
        <button type="button" class="review-tab" data-review-tab="sql">SQL</button>
        <button type="button" class="review-tab" data-review-tab="downloads">Downloads</button>
    </div>

    <div class="review-panel is-active" data-review-panel="analysis" style="padding:24px">
        <div class="stats-grid" style="margin-bottom:24px">
            <div class="stat-card">
                <div class="stat-card__label">Reconciled Rows</div>
                <div class="stat-card__value">@Model.Summary.TotalValidated.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Matches</div>
                <div class="stat-card__value">@Model.Summary.Matches.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">Mismatches</div>
                <div class="stat-card__value">@Model.Summary.Mismatches.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Mismatch Rate</div>
                <div class="stat-card__value">@Model.Summary.ExceptionRate.ToString("F2")%</div>
            </div>
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Run Summary</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Summary.Warning))
            {
                <div class="alert alert--warning" style="margin-bottom:16px">@Model.Summary.Warning</div>
            }
            <div class="form-grid">
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div>
                    <div>@Model.Summary.Database</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule</div>
                    <div>Rule 23 - Reconcile Datasets</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">dbo_STUD</div>
                    <div>@Model.Summary.StudTable</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Audit</div>
                    <div>@Model.Summary.AuditTable</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">H16</div>
                    <div>@Model.Summary.H16Table</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                    <div>@Model.Summary.Status</div>
                </div>
            </div>

            <div style="margin-top:20px">
                <h4 style="margin:0 0 10px 0">Issue Breakdown</h4>
                @if (Model.Summary.IssueCounts.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Summary.IssueCounts)
                            {
                                <tr>
                                    <td>@item.Status</td>
                                    <td>@item.Count.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert--success">No reconciliation exceptions were found.</div>
                }
            </div>
        </div>
    </div>

    <div class="review-panel" data-review-panel="exceptions" style="padding:24px">
        @if (Model.Summary.PassSampleRows.Any() || Model.Summary.FailRows.Any())
        {
            <div class="card" style="padding:20px">
                <div class="alert alert--info" style="margin-bottom:16px">
                    Use the filters below to review saved PASS and FAIL rows by CONTROL 1 or CONTROL 2. PASS rows come from the saved pass sample; FAIL rows come from the saved exception set.
                </div>
                <div class="form-grid" style="margin-bottom:16px">
                    <div class="field-group">
                        <label for="savedRule23ResultFilter">Result</label>
                        <select id="savedRule23ResultFilter">
                            <option value="ALL">All</option>
                            <option value="PASS">PASS</option>
                            <option value="FAIL">FAIL</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="savedRule23ControlFilter">Control</label>
                        <select id="savedRule23ControlFilter">
                            <option value="ALL">All</option>
                            <option value="CONTROL 1">CONTROL 1</option>
                            <option value="CONTROL 2">CONTROL 2</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="savedRule23IssueFilter">Issue</label>
                        <select id="savedRule23IssueFilter">
                            <option value="ALL">All</option>
                        </select>
                    </div>
                </div>
                <div id="savedRule23FilterInfo" class="alert alert--info" style="margin-bottom:16px"></div>
                <div style="overflow:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Result</th>
                                <th>Control</th>
                                <th>Validation #</th>
                                <th>STUD Student #</th>
                                <th>STUD Qual</th>
                                <th>STUD ID</th>
                                <th>Audit Student #</th>
                                <th>Audit Qual</th>
                                <th>Audit ID</th>
                                <th>H16 Student #</th>
                                <th>H16 Qual</th>
                                <th>H16 ID</th>
                                <th>Status</th>
                                <th>Issue</th>
                            </tr>
                        </thead>
                        <tbody id="savedRule23FilterBody"></tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert--success" style="margin:0">No fail exceptions were saved for this run.</div>
        }
    </div>

    <div class="review-panel" data-review-panel="passes" style="padding:24px">
        @if (Model.Summary.PassSampleRows.Any())
        {
            <div class="card" style="padding:20px">
                <div class="alert alert--info" style="margin-bottom:16px">
                    Showing the saved pass sample of @Model.Summary.PassSampleRows.Count row(s)@(Model.Summary.PassSampleTruncated ? $" out of {Model.Summary.Matches:N0} total matches." : ".")
                </div>
                <div style="overflow:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Validation #</th>
                                <th>STUD Student #</th>
                                <th>STUD Qual</th>
                                <th>STUD ID</th>
                                <th>Audit Student #</th>
                                <th>Audit Qual</th>
                                <th>Audit ID</th>
                                <th>H16 Student #</th>
                                <th>H16 Qual</th>
                                <th>H16 ID</th>
                                <th>Status</th>
                                <th>Issue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Summary.PassSampleRows)
                            {
                                <tr>
                                    <td>@row.ValidationNumber</td>
                                    <td>@row.StudStudentNumber</td>
                                    <td>@row.StudQualificationCode</td>
                                    <td>@row.StudIdNumber</td>
                                    <td>@row.AuditStudentNumber</td>
                                    <td>@row.AuditQualificationCode</td>
                                    <td>@row.AuditIdNumber</td>
                                    <td>@row.H16StudentNumber</td>
                                    <td>@row.H16QualificationCode</td>
                                    <td>@row.H16IdNumber</td>
                                    <td>@row.ReconciliationStatus</td>
                                    <td>@row.IssueDescription</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert--info" style="margin:0">No pass sample rows were saved for this run.</div>
        }
    </div>

    <div class="review-panel" data-review-panel="sql" style="padding:24px">
        <div class="code-panel">
            <pre>@Model.GeneratedSql</pre>
        </div>
    </div>

    <div class="review-panel" data-review-panel="downloads" style="padding:24px">
        @if (canDownload)
        {
            <div class="alert alert--info" style="margin-bottom:16px">
                Excel includes summary, pass sample, fail exceptions, and breakdown. CSV includes fail exceptions only.
            </div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <a asp-action="DownloadSavedExcel" asp-route-runId="@Model.RunId" class="btn btn-primary">Download Excel</a>
                <a asp-action="DownloadSavedCsv" asp-route-runId="@Model.RunId" class="btn btn-secondary">Download CSV</a>
                <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-secondary">Download SQL</a>
            </div>
        }
        else
        {
            <div class="alert alert--warning" style="margin:0">
                Assigned users can download this run even while the data analyst signoff is still outstanding.
            </div>
        }
    </div>
</div>

<script>
(() => {
    const tabs = document.querySelectorAll('[data-review-tab]');
    const panels = document.querySelectorAll('[data-review-panel]');
    const reviewRows = @Html.Raw(reviewRowsJson);
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(item => item.classList.toggle('is-active', item === tab));
            panels.forEach(panel => panel.classList.toggle('is-active', panel.dataset.reviewPanel === tab.dataset.reviewTab));
        });
    });

    const resultFilter = document.getElementById('savedRule23ResultFilter');
    const controlFilter = document.getElementById('savedRule23ControlFilter');
    const issueFilter = document.getElementById('savedRule23IssueFilter');
    const filterInfo = document.getElementById('savedRule23FilterInfo');
    const filterBody = document.getElementById('savedRule23FilterBody');

    if (resultFilter && controlFilter && issueFilter && filterInfo && filterBody) {
        const escapeHtml = value => String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const issueOptions = Array.from(new Set(reviewRows.map(row => row.reconciliationStatus || 'MATCH')))
            .sort((a, b) => String(a).localeCompare(String(b)));
        issueFilter.innerHTML = `<option value="ALL">All</option>${issueOptions.map(issue => `<option value="${escapeHtml(issue)}">${escapeHtml(issue)}</option>`).join('')}`;

        const renderRows = () => {
            const resultValue = resultFilter.value;
            const controlValue = controlFilter.value;
            const issueValue = issueFilter.value;
            const filteredRows = reviewRows.filter(row =>
                (resultValue === 'ALL' || row.resultType === resultValue) &&
                (controlValue === 'ALL' || row.controlType === controlValue) &&
                (issueValue === 'ALL' || row.reconciliationStatus === issueValue));
            const visibleRows = filteredRows.slice(0, 10);
            const previewNote = filteredRows.length > visibleRows.length
                ? ` Showing the first ${visibleRows.length.toLocaleString()} row(s) in the browser.`
                : '';
            filterInfo.textContent = `${filteredRows.length.toLocaleString()} saved row(s) match the selected filters.${previewNote}`;
            filterBody.innerHTML = visibleRows.map(row => `
                <tr>
                    <td>${escapeHtml(row.resultType)}</td>
                    <td>${escapeHtml(row.controlType)}</td>
                    <td>${Number(row.validationNumber || 0).toLocaleString()}</td>
                    <td>${escapeHtml(row.studStudentNumber)}</td>
                    <td>${escapeHtml(row.studQualificationCode)}</td>
                    <td>${escapeHtml(row.studIdNumber)}</td>
                    <td>${escapeHtml(row.auditStudentNumber)}</td>
                    <td>${escapeHtml(row.auditQualificationCode)}</td>
                    <td>${escapeHtml(row.auditIdNumber)}</td>
                    <td>${escapeHtml(row.h16StudentNumber)}</td>
                    <td>${escapeHtml(row.h16QualificationCode)}</td>
                    <td>${escapeHtml(row.h16IdNumber)}</td>
                    <td>${escapeHtml(row.reconciliationStatus)}</td>
                    <td>${escapeHtml(row.issueDescription)}</td>
                </tr>`).join('');
        };

        resultFilter.addEventListener('change', renderRows);
        controlFilter.addEventListener('change', renderRows);
        issueFilter.addEventListener('change', renderRows);
        renderRows();
    }
})();
</script>
